#
# Test Mixed Case Identifiers with --lower-case-table-name=1
#
#
# Show how Mixed Case identifiers are handled for each OS type
#
SHOW VARIABLES LIKE 'lower_case_table_names';
Variable_name	Value
lower_case_table_names	1
CREATE SCHEMA MixedCaseSchema;
CREATE TABLE MixedCaseSchema.MixedCaseTable (MixedCaseColumn INT);
INSERT INTO MixedCaseSchema.MixedCaseTable (MixedCaseColumn) VALUES (1), (2);
CREATE TABLE MixedCaseSchema.MixedCaseSubParititionedTable (col1 INT, col2 DATE)
PARTITION BY RANGE(YEAR(col2))
SUBPARTITION BY HASH(col1) (
PARTITION MixedCaseParititionName0 VALUES LESS THAN (2000) (
SUBPARTITION MixedCaseSubParititionName0,
SUBPARTITION MixedCaseSubParititionName1
),
PARTITION MixedCaseParititionName1 VALUES LESS THAN MAXVALUE (
SUBPARTITION MixedCaseSubParititionName2,
SUBPARTITION MixedCaseSubParititionName3
)
);
INSERT INTO MixedCaseSchema.MixedCaseSubParititionedTable VALUES (1, '2025-12-15'), (2001, '2025-12-15');
SELECT * FROM MixedCaseSchema.MixedCaseTable;
MixedCaseColumn
1
2
SELECT * FROM MixedCaseSchema.MixedCaseSubParititionedTable;
col1	col2
1	2025-12-15
2001	2025-12-15
USE MixedCaseSchema;
SHOW TABLES;
Tables_in_mixedcaseschema
mixedcasesubparititionedtable
mixedcasetable
USE test;
SHOW CREATE TABLE MixedCaseSchema.MixedCaseTable;
Table	Create Table
MixedCaseTable	CREATE TABLE `mixedcasetable` (
  `MixedCaseColumn` int DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
SELECT TABLE_NAME, TABLE_SCHEMA, TABLE_TYPE, ENGINE FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME LIKE '%ixed%';
TABLE_NAME	TABLE_SCHEMA	TABLE_TYPE	ENGINE
mixedcasesubparititionedtable	mixedcaseschema	BASE TABLE	InnoDB
mixedcasetable	mixedcaseschema	BASE TABLE	InnoDB
SELECT FILE_NAME, FILE_TYPE, TABLESPACE_NAME, TABLE_SCHEMA, TABLE_NAME FROM INFORMATION_SCHEMA.FILES WHERE FILE_NAME LIKE '%ixed%';
FILE_NAME	FILE_TYPE	TABLESPACE_NAME	TABLE_SCHEMA	TABLE_NAME
./mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname0.ibd	TABLESPACE	mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname0	NULL	NULL
./mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname1.ibd	TABLESPACE	mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname1	NULL	NULL
./mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname2.ibd	TABLESPACE	mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname2	NULL	NULL
./mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname3.ibd	TABLESPACE	mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname3	NULL	NULL
./mixedcaseschema/mixedcasetable.ibd	TABLESPACE	mixedcaseschema/mixedcasetable	NULL	NULL
SELECT NAME, SPACE_TYPE FROM INFORMATION_SCHEMA.INNODB_TABLES WHERE NAME LIKE '%ixed%';
NAME	SPACE_TYPE
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname0	Single
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname1	Single
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname2	Single
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname3	Single
mixedcaseschema/mixedcasetable	Single
SELECT NAME, SPACE_TYPE FROM INFORMATION_SCHEMA.INNODB_TABLESPACES WHERE NAME LIKE '%ixed%';
NAME	SPACE_TYPE
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname0	Single
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname0#sp#mixedcasesubparititionname1	Single
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname2	Single
mixedcaseschema/mixedcasesubparititionedtable#p#mixedcaseparititionname1#sp#mixedcasesubparititionname3	Single
mixedcaseschema/mixedcasetable	Single
# restart
INSERT INTO MixedCaseSchema.MixedCaseTable (MixedCaseColumn) VALUES (3), (4);
INSERT INTO MixedCaseSchema.MixedCaseSubParititionedTable VALUES (2, '2025-12-16'), (2002, '2025-12-16');
SELECT * FROM MixedCaseSchema.MixedCaseTable;
