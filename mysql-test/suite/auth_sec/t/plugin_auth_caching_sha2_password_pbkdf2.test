
# Save the initial number of concurrent sessions
--source include/count_sessions.inc
--source include/allowed_ciphers.inc

SELECT @@caching_sha2_password_storage_format INTO @saved_value;
SET GLOBAL caching_sha2_password_storage_format="PBKDF2_SHA512";
--source suite/auth_sec/include/plugin_auth_caching_sha2_password_tests.inc
SET GLOBAL caching_sha2_password_storage_format=@saved_value;

# Wait till all disconnects are completed
--source include/wait_until_count_sessions.inc
--source include/force_restart.inc
