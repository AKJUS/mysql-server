
# Save the initial number of concurrent sessions
--source include/count_sessions.inc
--source include/allowed_ciphers.inc

--let $parameter_client_script=$MYSQL_TEST
--let $parameter_client=$MYSQL -P $MASTER_MYPORT --host=127.0.0.1 --protocol=TCP
--let $parameter_test_second_password=1
--source suite/auth_sec/include/plugin_auth_caching_sha2_password_multi_format_support.inc

# Wait till all disconnects are completed
--source include/wait_until_count_sessions.inc
--source include/force_restart.inc
