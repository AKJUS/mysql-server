WHERE variable_name='telemetry.metrics_reader_frequency_2';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.metrics_reader_frequency_2	60
SET GLOBAL telemetry.metrics_reader_frequency_2
='123';
