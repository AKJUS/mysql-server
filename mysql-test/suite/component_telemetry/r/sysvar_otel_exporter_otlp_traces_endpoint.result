@@global.telemetry.otel_exporter_otlp_traces_endpoint
https://somewhere.example.com:4318/v1/traces
SET PERSIST telemetry.otel_exporter_otlp_traces_endpoint
='https://somewhere.else.example.com:4318/v1/traces';
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_traces_endpoint' is a read only variable
SET PERSIST_ONLY telemetry.otel_exporter_otlp_traces_endpoint
='https://somewhere.else.example.com:4318/v1/traces';
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_exporter_otlp_traces_endpoint;
@@global.telemetry.otel_exporter_otlp_traces_endpoint
https://somewhere.else.example.com:4318/v1/traces
