# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_bsp_max_queue_size=1024;
SELECT @@global.telemetry.otel_bsp_max_queue_size;
@@global.telemetry.otel_bsp_max_queue_size
1024
SET PERSIST telemetry.otel_bsp_max_queue_size=900;
ERROR HY000: Variable 'telemetry.otel_bsp_max_queue_size' is a read only variable
SET PERSIST_ONLY telemetry.otel_bsp_max_queue_size=900;
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_bsp_max_queue_size;
@@global.telemetry.otel_bsp_max_queue_size
896
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Cleanup
