Variable_name	Value
telemetry.otel_bsp_max_queue_size	2048
SHOW SESSION VARIABLES LIKE 'telemetry.otel_bsp_max_queue_size';
Variable_name	Value
telemetry.otel_bsp_max_queue_size	2048
SELECT * FROM performance_schema.global_variables
WHERE variable_name='telemetry.otel_bsp_max_queue_size';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.otel_bsp_max_queue_size	2048
SELECT * FROM performance_schema.session_variables
WHERE variable_name='telemetry.otel_bsp_max_queue_size';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.otel_bsp_max_queue_size	2048
SET GLOBAL telemetry.otel_bsp_max_queue_size=1024;
ERROR HY000: Variable 'telemetry.otel_bsp_max_queue_size' is a read only variable
SET SESSION telemetry.otel_bsp_max_queue_size=1024;
