call mtr.add_suppression("\\[OTEL\\]");
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_exporter_otlp_traces_compression;
@@global.telemetry.otel_exporter_otlp_traces_compression
none
SELECT @@session.telemetry.otel_exporter_otlp_traces_compression;
