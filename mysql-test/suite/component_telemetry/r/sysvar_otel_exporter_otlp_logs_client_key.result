call mtr.add_suppression("\\[OTEL\\]");
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_exporter_otlp_logs_client_key;
@@global.telemetry.otel_exporter_otlp_logs_client_key

SELECT @@session.telemetry.otel_exporter_otlp_logs_client_key;
