# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_logs_client_key
='/path/to/client_key.pem';
SELECT @@global.telemetry.otel_exporter_otlp_logs_client_key;
@@global.telemetry.otel_exporter_otlp_logs_client_key
/path/to/client_key.pem
SET PERSIST telemetry.otel_exporter_otlp_logs_client_key
='/path/to/another/client_key.pem';
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_logs_client_key' is a read only variable
SET PERSIST_ONLY telemetry.otel_exporter_otlp_logs_client_key
='/path/to/another/client_key.pem';
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_exporter_otlp_logs_client_key;
@@global.telemetry.otel_exporter_otlp_logs_client_key
/path/to/another/client_key.pem
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Cleanup
RESET PERSIST;
