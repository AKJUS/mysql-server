telemetry.otel_exporter_otlp_logs_client_key	
SET GLOBAL telemetry.otel_exporter_otlp_logs_client_key
='/path/to/client_key.pem';
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_logs_client_key' is a read only variable
SET SESSION telemetry.otel_exporter_otlp_logs_client_key
='/path/to/client_key.pem';
