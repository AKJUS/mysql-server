call mtr.add_suppression("\\[OTEL\\]");
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.log_enabled;
@@global.telemetry.log_enabled
0
SELECT @@session.telemetry.log_enabled;
ERROR HY000: Variable 'telemetry.log_enabled' is a GLOBAL variable
SHOW GLOBAL VARIABLES LIKE 'telemetry.log_enabled';
Variable_name	Value
telemetry.log_enabled	OFF
SHOW SESSION VARIABLES LIKE 'telemetry.log_enabled';
Variable_name	Value
telemetry.log_enabled	OFF
SELECT * FROM performance_schema.global_variables
WHERE variable_name='telemetry.log_enabled';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.log_enabled	OFF
SELECT * FROM performance_schema.session_variables
WHERE variable_name='telemetry.log_enabled';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.log_enabled	OFF
SET GLOBAL telemetry.log_enabled=OFF;
SET SESSION telemetry.log_enabled=OFF;
ERROR HY000: Variable 'telemetry.log_enabled' is a GLOBAL variable and should be set with SET GLOBAL
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.log_enabled=OFF;
SELECT @@global.telemetry.log_enabled;
@@global.telemetry.log_enabled
0
SET PERSIST telemetry.log_enabled=ON;
SET PERSIST_ONLY telemetry.log_enabled=ON;
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.log_enabled;
@@global.telemetry.log_enabled
1
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Cleanup
RESET PERSIST;
