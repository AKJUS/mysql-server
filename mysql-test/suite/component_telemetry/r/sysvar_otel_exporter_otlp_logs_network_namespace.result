# Ok, network namespace platform support
# Ok, mysqld has cap_sys_admin
# Ok, red network exists
# Ok, blue network exists
# Ok, /run/netns/red file exists
# Ok, /run/netns/blue file exists
# All network namespace pre requisites checked
call mtr.add_suppression("\\[OTEL\\]");
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_exporter_otlp_logs_network_namespace;
@@global.telemetry.otel_exporter_otlp_logs_network_namespace

SELECT @@session.telemetry.otel_exporter_otlp_logs_network_namespace;
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_logs_network_namespace' is a GLOBAL variable
SHOW GLOBAL VARIABLES LIKE 'telemetry.otel_exporter_otlp_logs_network_namespace';
Variable_name	Value
telemetry.otel_exporter_otlp_logs_network_namespace	
SHOW SESSION VARIABLES LIKE 'telemetry.otel_exporter_otlp_logs_network_namespace';
Variable_name	Value
telemetry.otel_exporter_otlp_logs_network_namespace	
SELECT * FROM performance_schema.global_variables
WHERE variable_name='telemetry.otel_exporter_otlp_logs_network_namespace';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.otel_exporter_otlp_logs_network_namespace	
SELECT * FROM performance_schema.session_variables
WHERE variable_name='telemetry.otel_exporter_otlp_logs_network_namespace';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.otel_exporter_otlp_logs_network_namespace	
SET GLOBAL telemetry.otel_exporter_otlp_logs_network_namespace
='red';
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_logs_network_namespace' is a read only variable
SET SESSION telemetry.otel_exporter_otlp_logs_network_namespace
='red';
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_logs_network_namespace' is a read only variable
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_logs_network_namespace
='red';
SELECT @@global.telemetry.otel_exporter_otlp_logs_network_namespace;
@@global.telemetry.otel_exporter_otlp_logs_network_namespace
red
SET PERSIST telemetry.otel_exporter_otlp_logs_network_namespace
='blue';
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_logs_network_namespace' is a read only variable
SET PERSIST_ONLY telemetry.otel_exporter_otlp_logs_network_namespace
='blue';
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_exporter_otlp_logs_network_namespace;
@@global.telemetry.otel_exporter_otlp_logs_network_namespace
blue
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Cleanup
RESET PERSIST;
