# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_metrics_certificates
='/path/to/ca.pem';
SELECT @@global.telemetry.otel_exporter_otlp_metrics_certificates;
@@global.telemetry.otel_exporter_otlp_metrics_certificates
/path/to/ca.pem
SET PERSIST telemetry.otel_exporter_otlp_metrics_certificates
='/path/to/another/ca.pem';
ERROR HY000: Variable 'telemetry.otel_exporter_otlp_metrics_certificates' is a read only variable
SET PERSIST_ONLY telemetry.otel_exporter_otlp_metrics_certificates
='/path/to/another/ca.pem';
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.otel_exporter_otlp_metrics_certificates;
@@global.telemetry.otel_exporter_otlp_metrics_certificates
/path/to/another/ca.pem
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Cleanup
RESET PERSIST;
