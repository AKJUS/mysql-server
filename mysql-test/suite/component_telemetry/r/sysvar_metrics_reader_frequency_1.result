# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.metrics_reader_frequency_1
= 123;
SELECT @@global.telemetry.metrics_reader_frequency_1;
@@global.telemetry.metrics_reader_frequency_1
123
SET PERSIST telemetry.metrics_reader_frequency_1
= 456;
ERROR HY000: Variable 'telemetry.metrics_reader_frequency_1' is a read only variable
SET PERSIST_ONLY telemetry.metrics_reader_frequency_1
= 456;
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Install component
INSTALL COMPONENT 'file://component_telemetry';
SELECT @@global.telemetry.metrics_reader_frequency_1;
@@global.telemetry.metrics_reader_frequency_1
456
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Cleanup
RESET PERSIST;
