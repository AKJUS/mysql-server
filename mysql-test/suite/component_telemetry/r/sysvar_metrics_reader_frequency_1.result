Variable_name	Value
telemetry.metrics_reader_frequency_1	10
SELECT * FROM performance_schema.global_variables
WHERE variable_name='telemetry.metrics_reader_frequency_1';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.metrics_reader_frequency_1	10
SELECT * FROM performance_schema.session_variables
WHERE variable_name='telemetry.metrics_reader_frequency_1';
VARIABLE_NAME	VARIABLE_VALUE
telemetry.metrics_reader_frequency_1	10
SET GLOBAL telemetry.metrics_reader_frequency_1
='123';
ERROR HY000: Variable 'telemetry.metrics_reader_frequency_1' is a read only variable
SET SESSION telemetry.metrics_reader_frequency_1
='123';
