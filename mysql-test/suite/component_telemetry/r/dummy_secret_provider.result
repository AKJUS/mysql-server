call mtr.add_suppression("\\[OTEL\\]");
call mtr.add_suppression("telemetry: Failed to start.");
call mtr.add_suppression("telemetry: Failed to decode secrets.");
call mtr.add_suppression("telemetry: Can not open secret <secret-unknown>");
call mtr.add_suppression("telemetry: Found invalid key/value pair in http headers");
call mtr.add_suppression("telemetry: Failed to acquire service <telemetry_secret_provider.component_test_telemetry_secret_provider>, will wait");
call mtr.add_suppression("telemetry: Failed to configure");
# Install a secret provider before telemetry
# 1) Install dummy secret provider
INSTALL COMPONENT 'file://component_test_telemetry_secret_provider';
# 2) Install component with dummy secret provider (traces)
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='component_test_telemetry_secret_provider',
telemetry.otel_exporter_otlp_traces_secret_headers = "secret-unknown";
SHOW STATUS LIKE "telemetry.run_level";
Variable_name	Value
telemetry.run_level	FAILED
UNINSTALL COMPONENT 'file://component_telemetry';
# 2) Install component with dummy secret provider (traces)
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='component_test_telemetry_secret_provider',
telemetry.otel_exporter_otlp_traces_secret_headers = "secret-1234";
SHOW STATUS LIKE "telemetry.run_level";
Variable_name	Value
telemetry.run_level	READY
SELECT "Secret provider loaded for traces" as message;
message
Secret provider loaded for traces
UNINSTALL COMPONENT 'file://component_telemetry';
# 2) Install component with dummy secret provider (metrics)
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='component_test_telemetry_secret_provider',
telemetry.otel_exporter_otlp_metrics_secret_headers = "secret-5678";
SHOW STATUS LIKE "telemetry.run_level";
Variable_name	Value
telemetry.run_level	READY
SELECT "Secret provider loaded for metrics" as message;
message
Secret provider loaded for metrics
UNINSTALL COMPONENT 'file://component_telemetry';
# 2) Install component with dummy secret provider (logs)
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='component_test_telemetry_secret_provider',
telemetry.otel_exporter_otlp_logs_secret_headers = "secret-90ab";
SHOW STATUS LIKE "telemetry.run_level";
Variable_name	Value
telemetry.run_level	READY
SELECT "Secret provider loaded for logs" as message;
message
Secret provider loaded for logs
UNINSTALL COMPONENT 'file://component_telemetry';
# 2) Install component with dummy secret provider (all)
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='component_test_telemetry_secret_provider',
telemetry.otel_exporter_otlp_traces_secret_headers = "secret-1234",
telemetry.otel_exporter_otlp_metrics_secret_headers = "secret-5678",
telemetry.otel_exporter_otlp_logs_secret_headers = "secret-90ab";
SHOW STATUS LIKE "telemetry.run_level";
Variable_name	Value
telemetry.run_level	READY
SELECT "Secret provider loaded for all" as message;
message
Secret provider loaded for all
UNINSTALL COMPONENT 'file://component_telemetry';
# 2) Install component with dummy secret provider (broken)
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='component_test_telemetry_secret_provider',
telemetry.otel_exporter_otlp_traces_secret_headers = "secret-broken";
SELECT "Secret provider loading for broken secret" as message;
message
Secret provider loading for broken secret
SHOW STATUS LIKE "telemetry.run_level";
Variable_name	Value
telemetry.run_level	READY
SELECT "Secret provider loaded for broken secret" as message;
message
Secret provider loaded for broken secret
UNINSTALL COMPONENT 'file://component_telemetry';
UNINSTALL COMPONENT 'file://component_test_telemetry_secret_provider';
# Install telemetry before a secret provider
# 1) Install component with (unloaded) dummy secret provider (traces)
