RESET PERSIST telemetry.otel_exporter_otlp_metrics_headers;
call mtr.add_suppression("Found invalid key/value pair in http headers");
# Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_metrics_headers
='A=1, broken, B=2, ok_empty=, B=3, ok_weird=x=y, C=4, broken_again';
SELECT @@global.telemetry.otel_exporter_otlp_metrics_headers;
@@global.telemetry.otel_exporter_otlp_metrics_headers
A=1, broken, B=2, ok_empty=, B=3, ok_weird=x=y, C=4, broken_again
# Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';
# Cleanup
RESET PERSIST;
