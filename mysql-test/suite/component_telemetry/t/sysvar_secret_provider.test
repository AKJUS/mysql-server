
--source include/linux.inc
--source include/have_server_telemetry_traces.inc
--source include/have_no_telemetry_component.inc

call mtr.add_suppression("\\[OTEL\\]");
call mtr.add_suppression("telemetry: Failed to acquire service <telemetry_secret_provider.my_provider>, will wait.");

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

#
# Only global
#

SELECT @@global.telemetry.secret_provider;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SELECT @@session.telemetry.secret_provider;

SHOW GLOBAL VARIABLES LIKE 'telemetry.secret_provider';

SHOW SESSION VARIABLES LIKE 'telemetry.secret_provider';

SELECT * FROM performance_schema.global_variables
  WHERE variable_name='telemetry.secret_provider';

SELECT * FROM performance_schema.session_variables
  WHERE variable_name='telemetry.secret_provider';

#
# Read-only
#

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET GLOBAL telemetry.secret_provider='provider_x';

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET SESSION telemetry.secret_provider='provider_x';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='provider_y';

SELECT @@global.telemetry.secret_provider;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET PERSIST telemetry.secret_provider='provider_z';

SET PERSIST_ONLY telemetry.secret_provider='provider_z';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

SELECT @@global.telemetry.secret_provider;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

--echo # Cleanup
RESET PERSIST;

-- echo # Install component with a trace secret
INSTALL COMPONENT 'file://component_telemetry'
  SET
    telemetry.secret_provider='my_provider',
    otel_exporter_otlp_traces_secret_headers = "SECRET-TRACE";

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with a metric secret
INSTALL COMPONENT 'file://component_telemetry'
  SET
    telemetry.secret_provider='my_provider',
    otel_exporter_otlp_metrics_secret_headers = "SECRET-METRIC";

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with a log secret
INSTALL COMPONENT 'file://component_telemetry'
  SET
    telemetry.secret_provider='my_provider',
    otel_exporter_otlp_logs_secret_headers = "SECRET-LOG";

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

--let $MYSQLD_DATADIR= `select @@datadir`
--remove_file $MYSQLD_DATADIR/mysqld-auto.cnf
