
--source include/linux.inc
--source include/have_server_telemetry_traces.inc
--source include/have_no_telemetry_component.inc

call mtr.add_suppression("\\[OTEL\\]");
call mtr.add_suppression("telemetry: Failed to acquire service <telemetry_resource_provider.provider_y>, will wait.");
call mtr.add_suppression("telemetry: Failed to acquire service <telemetry_resource_provider.provider_z>, will wait.");

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

#
# Only global
#

SELECT @@global.telemetry.resource_provider;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SELECT @@session.telemetry.resource_provider;

SHOW GLOBAL VARIABLES LIKE 'telemetry.resource_provider';

SHOW SESSION VARIABLES LIKE 'telemetry.resource_provider';

SELECT * FROM performance_schema.global_variables
  WHERE variable_name='telemetry.resource_provider';

SELECT * FROM performance_schema.session_variables
  WHERE variable_name='telemetry.resource_provider';

#
# Read-only
#

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET GLOBAL telemetry.resource_provider='provider_x';

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET SESSION telemetry.resource_provider='provider_x';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.resource_provider='provider_y';

SELECT @@global.telemetry.resource_provider;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET PERSIST telemetry.resource_provider='provider_z';

SET PERSIST_ONLY telemetry.resource_provider='provider_z';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

SELECT @@global.telemetry.resource_provider;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

--echo # Cleanup
RESET PERSIST;
--let $MYSQLD_DATADIR= `select @@datadir`
--remove_file $MYSQLD_DATADIR/mysqld-auto.cnf
