-- echo # 1) Install component with (unloaded) dummy secret provider (all)
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.secret_provider='component_test_telemetry_secret_provider',
    telemetry.otel_exporter_otlp_traces_secret_headers = "secret-1234",
