
--source include/linux.inc
--source include/have_server_telemetry_traces.inc
--source include/have_no_telemetry_component.inc

call mtr.add_suppression("\\[OTEL\\]");

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

#
# Only global
#

SELECT @@global.telemetry.query_text_enabled;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SELECT @@session.telemetry.query_text_enabled;

SHOW GLOBAL VARIABLES LIKE 'telemetry.query_text_enabled';

SHOW SESSION VARIABLES LIKE 'telemetry.query_text_enabled';

SELECT * FROM performance_schema.global_variables
  WHERE variable_name='telemetry.query_text_enabled';

SELECT * FROM performance_schema.session_variables
  WHERE variable_name='telemetry.query_text_enabled';

#
# Read-only
#

SET GLOBAL telemetry.query_text_enabled=OFF;

--error ER_GLOBAL_VARIABLE
SET SESSION telemetry.query_text_enabled=OFF;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.query_text_enabled=OFF;

SELECT @@global.telemetry.query_text_enabled;

SET PERSIST telemetry.query_text_enabled=ON;

SET PERSIST_ONLY telemetry.query_text_enabled=ON;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

SELECT @@global.telemetry.query_text_enabled;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

--echo # Cleanup
RESET PERSIST;
--let $MYSQLD_DATADIR= `select @@datadir`
--remove_file $MYSQLD_DATADIR/mysqld-auto.cnf
