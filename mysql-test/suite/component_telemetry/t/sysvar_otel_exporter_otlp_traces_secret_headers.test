
--source include/linux.inc
--source include/have_server_telemetry_traces.inc
--source include/have_no_telemetry_component.inc

call mtr.add_suppression("\\[OTEL\\]");
call mtr.add_suppression("telemetry: Ignoring secrets, no secret_provider defined.");

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

#
# Only global
#

SELECT @@global.telemetry.otel_exporter_otlp_traces_secret_headers;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SELECT @@session.telemetry.otel_exporter_otlp_traces_secret_headers;

SHOW GLOBAL VARIABLES LIKE 'telemetry.otel_exporter_otlp_traces_secret_headers';

SHOW SESSION VARIABLES LIKE 'telemetry.otel_exporter_otlp_traces_secret_headers';

SELECT * FROM performance_schema.global_variables
  WHERE variable_name='telemetry.otel_exporter_otlp_traces_secret_headers';

SELECT * FROM performance_schema.session_variables
  WHERE variable_name='telemetry.otel_exporter_otlp_traces_secret_headers';

#
# Read-only
#

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET GLOBAL telemetry.otel_exporter_otlp_traces_secret_headers
  = 'SECRET_NAME_1234';

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET SESSION telemetry.otel_exporter_otlp_traces_secret_headers
  = 'SECRET_NAME_5678';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_traces_secret_headers
    = 'SECRET_NAME_1234';

SELECT @@global.telemetry.otel_exporter_otlp_traces_secret_headers;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET PERSIST telemetry.otel_exporter_otlp_traces_secret_headers
  ='my helper knows how to decode this';

SET PERSIST_ONLY telemetry.otel_exporter_otlp_traces_secret_headers
  ='my helper knows how to decode this';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

SELECT @@global.telemetry.otel_exporter_otlp_traces_secret_headers;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

RESET PERSIST telemetry.otel_exporter_otlp_traces_secret_headers;

call mtr.add_suppression("Found invalid key/value pair in http headers");

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_traces_secret_headers
    ='the secret is elsewhere anyway';

SELECT @@global.telemetry.otel_exporter_otlp_traces_secret_headers;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

--echo # Cleanup
RESET PERSIST;
--let $MYSQLD_DATADIR= `select @@datadir`
--remove_file $MYSQLD_DATADIR/mysqld-auto.cnf
