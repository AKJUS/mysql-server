
--source include/linux.inc
--source include/have_server_telemetry_traces.inc
--source include/have_no_telemetry_component.inc

call mtr.add_suppression("\\[OTEL\\]");

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

#
# Only global
#

SELECT @@global.telemetry.otel_exporter_otlp_traces_headers;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SELECT @@session.telemetry.otel_exporter_otlp_traces_headers;

SHOW GLOBAL VARIABLES LIKE 'telemetry.otel_exporter_otlp_traces_headers';

SHOW SESSION VARIABLES LIKE 'telemetry.otel_exporter_otlp_traces_headers';

SELECT * FROM performance_schema.global_variables
  WHERE variable_name='telemetry.otel_exporter_otlp_traces_headers';

SELECT * FROM performance_schema.session_variables
  WHERE variable_name='telemetry.otel_exporter_otlp_traces_headers';

#
# Read-only
#

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET GLOBAL telemetry.otel_exporter_otlp_traces_headers
  ='TENANT_ID=1000, AUTH_TOKEN=2000';

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET SESSION telemetry.otel_exporter_otlp_traces_headers
  ='TENANT_ID=1000, AUTH_TOKEN=2000';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_traces_headers
    ='TENANT_ID=1000, AUTH_TOKEN=2000';

SELECT @@global.telemetry.otel_exporter_otlp_traces_headers;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET PERSIST telemetry.otel_exporter_otlp_traces_headers
  ='SOURCE=PROD, AUTH=This is me';

SET PERSIST_ONLY telemetry.otel_exporter_otlp_traces_headers
  ='SOURCE=PROD, AUTH=This is me';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

SELECT @@global.telemetry.otel_exporter_otlp_traces_headers;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

RESET PERSIST telemetry.otel_exporter_otlp_traces_headers;

call mtr.add_suppression("Found invalid key/value pair in http headers");

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_traces_headers
    ='A=1, broken, B=2, ok_empty=, B=3, ok_weird=x=y, C=4, broken_again';

SELECT @@global.telemetry.otel_exporter_otlp_traces_headers;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

--echo # Cleanup
RESET PERSIST;
--let $MYSQLD_DATADIR= `select @@datadir`
--remove_file $MYSQLD_DATADIR/mysqld-auto.cnf
