
--source include/linux.inc
--source include/have_server_telemetry_metrics.inc
--source include/have_no_telemetry_component.inc

call mtr.add_suppression("\\[OTEL\\]");

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

#
# Only global
#

SELECT @@global.telemetry.otel_exporter_otlp_metrics_min_tls;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SELECT @@session.telemetry.otel_exporter_otlp_metrics_min_tls;

SHOW GLOBAL VARIABLES LIKE 'telemetry.otel_exporter_otlp_metrics_min_tls';

SHOW SESSION VARIABLES LIKE 'telemetry.otel_exporter_otlp_metrics_min_tls';

SELECT * FROM performance_schema.global_variables
  WHERE variable_name='telemetry.otel_exporter_otlp_metrics_min_tls';

SELECT * FROM performance_schema.session_variables
  WHERE variable_name='telemetry.otel_exporter_otlp_metrics_min_tls';

#
# Read-only
#

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET GLOBAL telemetry.otel_exporter_otlp_metrics_min_tls
  ='1.1';

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET SESSION telemetry.otel_exporter_otlp_metrics_min_tls
  ='1.1';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component with set var
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.otel_exporter_otlp_metrics_min_tls
    ='1.2';

SELECT @@global.telemetry.otel_exporter_otlp_metrics_min_tls;

--error ER_INCORRECT_GLOBAL_LOCAL_VAR
SET PERSIST telemetry.otel_exporter_otlp_metrics_min_tls
  ='1.3';

SET PERSIST_ONLY telemetry.otel_exporter_otlp_metrics_min_tls
  ='1.3';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

SELECT @@global.telemetry.otel_exporter_otlp_metrics_min_tls;

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

--echo # Cleanup
RESET PERSIST;
--let $MYSQLD_DATADIR= `select @@datadir`
--remove_file $MYSQLD_DATADIR/mysqld-auto.cnf
