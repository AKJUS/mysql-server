  
--source include/linux.inc
--source include/have_server_telemetry_traces.inc
--source include/have_no_telemetry_component.inc

call mtr.add_suppression("\\[OTEL\\]");

#
# The purpose of this test is to verify that
# the count of live sessions,
# and the tagging of which session is active or not,
# is maintained correctly.
#
# Notation used:
# - CON1 (C) = connection CON1 connects
# - CON1 (W) = connection CON1 performs work,
#   which can detect telemetry installed/uninstalled
# - CON1 (D) = connection CON1 disconnects
# - LOAD = the telemetry component is loaded
# - UNLOAD = the telemetry component is unloaded
# - UNLOAD(B) = the telemetry component is unloaded,
#   but the unload operation is blocked
#
# Test scenario:
# - CON1 : (C), LOAD, UNLOAD, (D)
# - CON2 : (C), LOAD, (W), UNLOAD(B), (D)
# - CON3 : (C), LOAD, (W), UNLOAD(B), (W), (D)
# - CON4 : (C), LOAD, UNLOAD, (W), (D)
# - CON5 : (C), LOAD, (D), UNLOAD
# - CON6 : (C), LOAD, (W), (D), UNLOAD
# - CON7 : LOAD, (C), (D), UNLOAD
# - CON8 : LOAD, (C), (W), (D), UNLOAD
# - CON9 : LOAD, (C), UNLOAD(B), (D)
# - CON10 : LOAD, (C), UNLOAD(B), (W), (D)
# - CON11 : UNLOAD(B), (C), (D)
#

-- echo # Connection con1

connect (con1, localhost, root, , );

let $con1_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo # Connection con2

connect (con2, localhost, root, , );

let $con2_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo # Connection con3

connect (con3, localhost, root, , );

let $con3_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo # Connection con4

connect (con4, localhost, root, , );

let $con4_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo # Connection con5

connect (con5, localhost, root, , );

let $con5_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo # Connection con6

connect (con6, localhost, root, , );

let $con6_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo # Connection otel

connect (otel, localhost, root, , );

let $otel_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo # Connection ctrl

connect (ctrl, localhost, root, , );

let $ctrl_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

-- echo
-- echo # State before install
-- echo

--disable_query_log
eval SELECT "con1" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con1_THREAD_ID;
eval SELECT "con2" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con2_THREAD_ID;
eval SELECT "con3" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con3_THREAD_ID;
eval SELECT "con4" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con4_THREAD_ID;
eval SELECT "con5" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con5_THREAD_ID;
eval SELECT "con6" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con6_THREAD_ID;
eval SELECT "otel" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $otel_THREAD_ID;
eval SELECT "ctrl" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $ctrl_THREAD_ID;
--enable_query_log

SELECT COUNT(*) FROM performance_schema.threads
  WHERE TELEMETRY_ACTIVE = 'YES';

SELECT VARIABLE_NAME, VARIABLE_VALUE
  FROM performance_schema.global_status
  WHERE VARIABLE_NAME = 'telemetry.live_sessions';

--connection otel

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry'
  SET telemetry.trace_enabled = 'ON',
      telemetry.otel_exporter_otlp_traces_endpoint = 'http://localhost:4318/v1/traces';

# Wait for the component_telemetry init thread to complete.
let $wait_condition=  SELECT count(*) = 1
  FROM performance_schema.global_status
  WHERE VARIABLE_NAME = 'telemetry.run_level' AND VARIABLE_VALUE = 'READY';
--source include/wait_condition.inc

-- echo
-- echo # State after install
-- echo

--disable_query_log
eval SELECT "con1" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con1_THREAD_ID;
eval SELECT "con2" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con2_THREAD_ID;
eval SELECT "con3" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con3_THREAD_ID;
eval SELECT "con4" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con4_THREAD_ID;
eval SELECT "con5" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con5_THREAD_ID;
eval SELECT "con6" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $con6_THREAD_ID;
eval SELECT "otel" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $otel_THREAD_ID;
eval SELECT "ctrl" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $ctrl_THREAD_ID;
--enable_query_log

SELECT COUNT(*) FROM performance_schema.threads
  WHERE TELEMETRY_ACTIVE = 'YES';

SELECT VARIABLE_NAME, VARIABLE_VALUE
  FROM performance_schema.global_status
  WHERE VARIABLE_NAME = 'telemetry.live_sessions';

--connection con2
SELECT "Con2 now detects telemetry" as MARKER;

-- echo # Connection con7

connect (con7, localhost, root, , );

let $con7_THREAD_ID=`select thread_id from performance_schema.threads
  where PROCESSLIST_ID = connection_id()`;

