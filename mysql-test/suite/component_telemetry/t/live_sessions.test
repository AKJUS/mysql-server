--reap

--connection ctrl

-- echo
-- echo # Enforce UNINSTALL is complete

# Wait for UNINSTALL to complete, idle on next command
let $wait_condition=  select count(*) = 1
  from performance_schema.events_waits_current
  where
  EVENT_NAME='idle' and
  THREAD_ID=$otel_THREAD_ID;
--source include/wait_condition.inc

