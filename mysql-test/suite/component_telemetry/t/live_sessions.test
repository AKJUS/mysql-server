# Wait for con1(D), CON3(D), CON4(D) and con11(D)
let $wait_condition=  SELECT count(*) = 0
  FROM performance_schema.threads
  WHERE THREAD_ID IN ($con1_THREAD_ID, $con3_THREAD_ID, $con4_THREAD_ID, $con11_THREAD_ID);
--source include/wait_condition.inc

-- echo
-- echo # State after CON1(D), CON3(D), CON4(D), CON11(D)
-- echo

--disable_query_log
eval SELECT "otel" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $otel_THREAD_ID;
eval SELECT "ctrl" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $ctrl_THREAD_ID;
--enable_query_log

SELECT COUNT(*) FROM performance_schema.threads
  WHERE TELEMETRY_ACTIVE = 'YES';

--disconnect otel
--disconnect ctrl

--connection default

# Wait for otel(D) and ctrl(D)
let $wait_condition=  SELECT count(*) = 0
  FROM performance_schema.threads
  WHERE THREAD_ID IN ($otel_THREAD_ID, $ctrl_THREAD_ID);
--source include/wait_condition.inc

-- echo # Install component
INSTALL COMPONENT 'file://component_telemetry';

-- echo # Uninstall component
UNINSTALL COMPONENT 'file://component_telemetry';

