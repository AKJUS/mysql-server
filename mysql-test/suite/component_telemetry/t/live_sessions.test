eval SELECT "otel" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $otel_THREAD_ID;
eval SELECT "ctrl" as NAME, TELEMETRY_ACTIVE FROM performance_schema.threads
  WHERE THREAD_ID = $ctrl_THREAD_ID;
--enable_query_log

SELECT COUNT(*) FROM performance_schema.threads
  WHERE TELEMETRY_ACTIVE = 'YES';

SELECT VARIABLE_NAME, VARIABLE_VALUE
  FROM performance_schema.global_status
  WHERE VARIABLE_NAME = 'telemetry.live_sessions';

--connection con3
SELECT "Con3 now detects telemetry" as MARKER;

--disconnect con5

--connection con6
SELECT "Con6 now detects telemetry" as MARKER;

--disconnect con7

--connection con8
SELECT "Con8 now detects telemetry" as MARKER;

--connection otel

# Wait for con5(D) and con7(D)
let $wait_condition=  SELECT count(*) = 0
  FROM performance_schema.threads
  WHERE THREAD_ID IN ($con5_THREAD_ID, $con7_THREAD_ID);
--source include/wait_condition.inc

