--connection ctrl
# Do this before, not during, UNINSTALL, to get reproducible results
SELECT "ctrl now detects telemetry" as MARKER;

--connection otel

-- echo # Uninstall component, will block
--send UNINSTALL COMPONENT 'file://component_telemetry'

--connection ctrl

-- echo
-- echo # Enforce UNINSTALL is blocked

# Wait for UNINSTALL to wait on live sessions
let $wait_condition=  select count(*) = 1
  from performance_schema.events_stages_current
  where
  EVENT_NAME='stage/telemetry/session' and
  THREAD_ID=$otel_THREAD_ID;
--source include/wait_condition.inc

