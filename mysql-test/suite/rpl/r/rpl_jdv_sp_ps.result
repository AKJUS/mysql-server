# Initialize the Replication setup
include/rpl/init_source_replica.inc
Warnings:
Note	####	Sending passwords in plain text without SSL/TLS is extremely insecure.
Note	####	Storing MySQL user name or password information in the connection metadata repository is not secure and is therefore not recommended. Please consider using the USER and PASSWORD connection options for START REPLICA; see the 'START REPLICA Syntax' in the MySQL Manual for more information.
[connection master]
################################################
################################################
# PART 1: Test with stored procedure, stored function and a
# trigger that will be replicated.
################################################
#
# Create some tables on the source
#
CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);
CREATE TABLE t3 (f1 INT);
CREATE TABLE t4 (f1 JSON);
#
# Create a JSON duality view on the source and wait for it to be
# replicated.
#
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : f11,
"f12" : f12,
"child" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"f1" : f1,
"f2" : f2
) FROM t1 WHERE t1.f1 = t2.f11))
FROM t2;
# Waiting for events to sync to replica
include/rpl/sync_to_replica.inc
[connection master]
CREATE PROCEDURE p1()
BEGIN
INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
SELECT * FROM dv1;
UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
SELECT * FROM dv1;
DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
END;
$
CREATE FUNCTION f1() RETURNS INT
BEGIN
INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
RETURN 1;
END;
$
CREATE TRIGGER t3_trigger BEFORE INSERT ON t3
FOR EACH ROW
BEGIN
INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
INSERT INTO t4 SELECT * FROM dv1;
DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
END;
$
# Waiting for events to sync to replica
include/rpl/sync_to_replica.inc
[connection master]
CALL p1();
data
{"_id": 1, "f12": 1, "child": {"f1": 1, "f2": 1}, "_metadata": {"etag": "c6f09ae7f2564bad1b337bee934c6b27"}}
data
{"_id": 1, "f12": 2, "child": {"f1": 1, "f2": 2}, "_metadata": {"etag": "342c2b19b4a29b2d14ecdf8644aaa45f"}}
include/rpl/sync_to_replica.inc
include/diff_servers.inc [servers=1 2]
[connection master]
SELECT f1();
f1()
1
include/rpl/sync_to_replica.inc
include/diff_servers.inc [servers=1 2]
[connection master]
INSERT INTO t3 VALUES (1);
include/rpl/sync_to_replica.inc
include/diff_servers.inc [servers=1 2]
[connection master]
