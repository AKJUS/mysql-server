#
# Test file contains cases to verify duality view DDL and DML with
# stored programs.
#


CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);
CREATE TABLE t3 (f1 INT);
CREATE TABLE t4 (f1 JSON);

--echo #
--echo # Test case to verify duality view DDL statements with stored programs.
--echo #

DELIMITER $;

CREATE PROCEDURE p1()
BEGIN
  CREATE JSON DUALITY VIEW dv1 AS
        SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                   "_id" : f1,
                                   "f2"  : f2) FROM t1;
  CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
         SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    "_id" : f11,
                    "f12" : f12,
                    "child" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                          "f1" : f1,
                                                          "f2" : f2
                                                         ) FROM t1 WHERE t1.f1 = t2.f11))
                    FROM t2;
   DROP VIEW dv1;
END;
$

DELIMITER ;$

CALL p1();
CALL p1();


--echo #
--echo # Test case to verify re-prepare of duality view DDL statements in stored procedure.
--echo #

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1 (f1 INT, f2 INT);
CREATE TABLE t2 (f11 INT, f12 INT);

--error ER_JDV_INVALID_DEFINITION_TABLE_WITHOUT_PK_FOUND
CALL p1();

--error ER_JDV_INVALID_DEFINITION_TABLE_WITHOUT_PK_FOUND
CALL p1();

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);

CALL p1();
CALL p1();

DROP PROCEDURE p1;


--echo #
--echo # Test case to verify duality view DML statements with stored procedure,
--echo # stored function and triggers.
--echo #

CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
       SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                  "_id" : f11,
                  "f12" : f12,
                  "child" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                        "f1" : f1,
                                                        "f2" : f2
                                                       ) FROM t1 WHERE t1.f1 = t2.f11))
       FROM t2;

DELIMITER $;
CREATE PROCEDURE p1()
BEGIN
 INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
 SELECT * FROM dv1;
 UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
 SELECT * FROM dv1;
 DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
END;
$

CREATE FUNCTION f1() RETURNS INT
BEGIN
 INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
 UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
 DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
 RETURN 1;
END;
$

CREATE TRIGGER t3_trigger BEFORE INSERT ON t3
FOR EACH ROW
BEGIN
 INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
 UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
 INSERT INTO t4 SELECT * FROM dv1;
 DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
END;
$
DELIMITER ;$

CALL p1();
CALL p1();

SELECT f1();
SELECT f1();

INSERT INTO t3 VALUES (1);
INSERT INTO t3 VALUES (1);
SELECT * FROM t4;
TRUNCATE TABLE t3;
TRUNCATE TABLE t4;


--echo #
--echo # Test case to verify execution of stored program using invalid duality view.
--echo #

RENAME TABLE t2 TO t2_copy;
RENAME TABLE t1 TO t1_copy;

--error ER_VIEW_INVALID
CALL p1();

--error ER_NO_SUCH_TABLE
SELECT f1();

--error ER_NO_SUCH_TABLE
INSERT INTO t3 VALUES (1);

RENAME TABLE t2_copy TO t2;
RENAME TABLE t1_copy TO t1;


--echo #
--echo # Test case to verify re-prepare of duality view DML statements in stored program.
--echo #

DROP TABLE t1, t2;

CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);

CALL p1();
CALL p1();

SELECT f1();
SELECT f1();

INSERT INTO t3 VALUES (1);
INSERT INTO t3 VALUES (1);
SELECT * FROM t4;
TRUNCATE TABLE t3;
TRUNCATE TABLE t4;

DROP VIEW dv1;
DROP PROCEDURE p1;


--echo #
--echo # Test case to verify duality view DDL and DML statements with prepared statements
--echo # in stored programs.
--echo #

DELIMITER $;
CREATE PROCEDURE p1()
BEGIN
  PREPARE create_dv_stmt FROM 'CREATE OR REPLACE JSON DUALITY VIEW dv1 AS SELECT
                               JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                "_id" : f11,
                                                "f12" : f12,
                                                "child" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                                                      "f1" : f1,
                                                                                      "f2" : f2
                                                                                     ) FROM t1 WHERE t1.f1 = t2.f11))
                                                FROM t2';
  PREPARE drop_dv_stmt FROM 'DROP VIEW dv1';

  EXECUTE create_dv_stmt;
  EXECUTE drop_dv_stmt;
  EXECUTE create_dv_stmt;

  PREPARE insert_stmt FROM 'INSERT INTO dv1 VALUES (\' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} \')';
  PREPARE update_stmt FROM 'UPDATE dv1 SET data = \' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } \'';
  PREPARE delete_stmt FROM 'DELETE FROM dv1 WHERE JSON_VALUE(data, \'$._id\') = 1';

  EXECUTE insert_stmt;
  EXECUTE delete_stmt;
  EXECUTE insert_stmt;

  EXECUTE update_stmt;
  EXECUTE delete_stmt;
  EXECUTE insert_stmt;
  EXECUTE update_stmt;
  EXECUTE delete_stmt;

  EXECUTE drop_dv_stmt;

  DROP PREPARE create_dv_stmt;
  DROP PREPARE drop_dv_stmt;
  DROP PREPARE insert_stmt;
  DROP PREPARE update_stmt;
  DROP PREPARE delete_stmt;
END;
$
DELIMITER ;$

CALL p1();
CALL p1();

--echo # With invalid duality view.
DROP TABLE t1, t2;

CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT, f12 INT);
--error ER_JDV_INVALID_DEFINITION_TABLE_WITHOUT_PK_FOUND
CALL p1();
--error ER_JDV_INVALID_DEFINITION_TABLE_WITHOUT_PK_FOUND
CALL p1();

DROP TABLE t2;
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);
CALL p1();
CALL p1();

DROP PROCEDURE p1;
DROP FUNCTION f1;
DROP TABLE t1, t2, t3, t4;
