#
# Test file contains cases to verify DML operations on JSON duality view.
#
#
#


--echo ################################################################################
--echo # INSERT statement restrictions for JSON duality view.
--echo ################################################################################

CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);

INSERT INTO p_t2 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
               "f4" : f4
            ) FROM p_t2;


--error ER_JDV_OPERATION_NOT_SUPPORTED
REPLACE INTO p_dv1 VALUES (' { "_id" : 2, "f4" : 300 } ');

--error ER_JDV_OPERATION_NOT_SUPPORTED
REPLACE INTO p_dv1 SELECT * FROM p_dv1;

--error ER_JDV_OPERATION_NOT_SUPPORTED
INSERT INTO p_dv1 SELECT * FROM p_dv1;

--error ER_JDV_OPERATION_NOT_SUPPORTED
INSERT INTO p_dv1 VALUES (' { "_id" : 2, "f4" : 300 } ') ON DUPLICATE KEY UPDATE data = ' { "_id" : 2, "f4" : 444 }';

--error ER_JDV_OPERATION_NOT_SUPPORTED
INSERT HIGH_PRIORITY INTO p_dv1 VALUES (' { "_id" : 2, "f4" : 300 } ');

--error ER_JDV_OPERATION_NOT_SUPPORTED
INSERT LOW_PRIORITY INTO p_dv1 VALUES (' { "_id" : 2, "f4" : 300 } ');

--error ER_JDV_OPERATION_NOT_SUPPORTED
INSERT IGNORE INTO p_dv1 VALUES (' { "_id" : 2, "f4" : 300 } ');

--error ER_JDV_OPERATION_NOT_SUPPORTED
INSERT INTO p_dv1(data) VALUES (' { "_id" : 2, "f4" : 300 } ');

--error ER_JDV_OPERATION_NOT_SUPPORTED
INSERT INTO p_dv1 VALUES (' { "_id" : 2, "f4" : 300 } '), ('{"_id" : 3, "f4" : 300}');

SELECT * FROM p_dv1;

DROP TABLE p_t2;


--echo #################################################################################
--echo # Verify warnings aggregation for JSON duality view object insert.
--echo #################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
              "f4" : f4,
              "ChildNode" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                               "f1" : f1,
                                               "f2" : f2)
                            FROM p_t1
                            WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

INSERT INTO p_dv1 VALUES ('{ "_id" : 2, "f4" : 300, "ChildNode" : {"f1" : 2, "f2" : 300 } }');

SET @orig_sql_mode = @@sql_mode;
SET sql_mode = 0;
INSERT INTO p_dv1 VALUES (' { "_id" : 3, "f4" : "123abcd", "ChildNode" : {"f1" : 3, "f2" : "123abcd" } }');
SET @@sql_mode = @orig_sql_mode;

SELECT * FROM p_dv1;

DROP TABLE p_t1;
DROP TABLE p_t2;


--echo ################################################################################
--echo # Inserting new Root object. (No Subject for view)
--echo # Root object - Primary key   Table annotations: READ_ONLY
--echo ################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');

DROP TABLE p_t1;


--echo ################################################################################
--echo # Inserting new Root object. No Subject.
--echo # Root object - Primary key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT DEFAULT 24);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (' {} ');

--error ER_JDV_NULL_INSERT_VALUE
INSERT INTO p_dv1 VALUES (NULL);
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 2, "f2" : null } ');
SELECT * FROM p_dv1;

DROP TABLE p_t1;


--echo ################################################################################
--echo # Inserting new Root Object and new Sub-object.
--echo # Root object - Foreign Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: READ ONLY
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1 WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

--error ER_JDV_MISSING_READONLY_SUBOBJECT
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : {
                      "f1" : 2,
                      "f2" : 3
                    }
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Inserting new Root Object and new Sub-object.
--echo # Root object - Foreign Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1  WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : {
                      "f1" : 2,
                      "f2" : 3
                    }
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Inserting new Root Object and referencing an Existing Sub-object.
--echo # Root object - Foreign Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE
--echo ################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

INSERT INTO p_t1 VALUES (3, 4);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1  WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 3,
     "f4" : 400,
     "ChildNode" : {
                      "f1" : 3,
                      "f2" : 4
                    }
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


