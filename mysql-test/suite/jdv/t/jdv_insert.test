--echo #
--echo # Bug#38319365: Disallow explicit generation request 0 for AUTO_INCREMENT columns in JDVs
--echo #

CREATE TABLE customers (
  customer_id INT PRIMARY KEY AUTO_INCREMENT,
  name VARCHAR(100)
);

CREATE TABLE orders (
  order_id INT PRIMARY KEY AUTO_INCREMENT,
  customer_id INT,
  product VARCHAR(100),
  amount DECIMAL(10,2),
  FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
);

CREATE OR REPLACE JSON RELATIONAL DUALITY VIEW customers_orders_dv AS
SELECT JSON_DUALITY_OBJECT( WITH(INSERT,UPDATE,DELETE)
    '_id': customer_id,
    'customer_name': name,
    'orders': (
        SELECT JSON_ARRAYAGG(
            JSON_DUALITY_OBJECT( WITH(INSERT,UPDATE,DELETE)
                'order_id': order_id,
                'product': product,
                'amount': amount
            )
        )
        FROM orders
        WHERE orders.customer_id = customers.customer_id
    )
)
FROM customers;

--error ER_JDV_PK_DUPLICATES_NOT_IDENTICAL
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Alice",
    "_id": 1,
    "orders": [
      {"order_id": 1, "product": "Laptop", "amount": 1299.99},
      {"order_id": 1, "product": "Mouse", "amount": 19.99}
    ]
}');
SELECT * FROM orders;

--error ER_JDV_PK_DUPLICATES_NOT_IDENTICAL
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Alice",
    "_id": 1,
    "orders": [
      {"order_id": 0, "product": "Laptop", "amount": 1299.99},
      {"order_id": 0, "product": "Mouse", "amount": 19.99}
    ]
}');
SELECT * FROM orders;

--echo # The use of 0 here must be rejected as it is transformed
--echo # to a different value. If that value is 1 the check for non-identical
--echo # PK duplicates is lost and the result is that the first recordr
--echo # inserted gets updated.
--error ER_JDV_EXPLICIT_AUTO_INCREMENT_NOT_ALLOWED
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Alice",
    "_id": 1,
    "orders": [
      {"order_id": 0, "product": "Laptop", "amount": 1299.99},
      {"order_id": 1, "product": "Mouse", "amount": 19.99}
    ]
}');

--echo # Explicitly providing non-0 values for AUTO_INCREMENT column is ok
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Alice",
    "_id": 1,
    "orders": [
      {"order_id": 1, "product": "Laptop", "amount": 1299.99},
      {"order_id": 2, "product": "Mouse", "amount": 19.99}
    ]
}');

SELECT * FROM orders;

DROP VIEW customers_orders_dv;
DROP TABLE orders;
DROP TABLE customers;


--echo # Allowing the use of 0 for and AUTO_INCREMENT column that is part of
--echo # the join-condition could lead to a broken join-condition (one side
--echo # gets the value 0 and the other the next generated value). Verify that
--echo # this is rejected.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY, t2c2 INT UNIQUE AUTO_INCREMENT);
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : t2c1,
               "k_t2c2" : t2c2,
               "k_singleton_t1" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                            "k_t1c1" : t1c1,
                                            "k_t1c2" : t1c2
                                          ) FROM t1  WHERE t1.t1c1 = t2.t2c2)
            ) FROM t2;

--error ER_JDV_EXPLICIT_AUTO_INCREMENT_NOT_ALLOWED
INSERT INTO dv1 VALUES (
' {
     "_id" : 2,
     "k_t2c2": 0,
     "k_singleton_t1" : {
                      "k_t1c2" : 4
                    }
  } ');

DELETE FROM t1;
DELETE FROM t2;

--error ER_JDV_EXPLICIT_AUTO_INCREMENT_NOT_ALLOWED
INSERT INTO dv1 VALUES (
' {
     "_id" : 3,
     "k_singleton_t1" : {
                      "k_t1c1": 0,
                      "k_t1c2" : 5
                    }
  } ');

DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;

--echo ################################################################################
--echo # Verify that omitting value for auto-increment columns is only permitted
--echo # when column is not part of join-condition.
--echo ################################################################################

--echo #
--echo # Bug#38179925: Insert into a JDV with AUTO_INCREMNT colunn is rejected
--echo # even if not part of join condition
--echo #

--echo # Verify that singleton child with non-pk auto-increment parent
--echo # join condition column rejects insert if value is not explicitly
--echo # provided in JSON.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY, t2c2 INT UNIQUE AUTO_INCREMENT);

INSERT INTO t1 VALUES (1, 2);
INSERT INTO t2(t2c1,t2c2) VALUES (200, 1);

CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : t2c1,
               "k_t2c2" : t2c2,
               "k_singleton_t1" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                            "k_t1c1" : t1c1,
                                            "k_t1c2" : t1c2
                                          ) FROM t1  WHERE t1.t1c1 = t2.t2c2)
            ) FROM t2;

SELECT * FROM dv1;
SELECT * FROM t1;
SELECT * FROM t2;

--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO dv1 VALUES (
' {
     "_id" : 2,
     "k_singleton_t1" : {
                      "k_t1c2" : 4
                    }
  } ');

DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;


--echo # Verify that nested child with non-pk auto-increment
--echo # join condition column rejects insert if value is not explicitly
--echo # provided in JSON.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT UNIQUE AUTO_INCREMENT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY, t2c2 INT);

INSERT INTO t1 VALUES (1, 2);
INSERT INTO t2(t2c1,t2c2) VALUES (2, 10);

CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : t2c1,
               "k_t2c2" : t2c2,
               "nested_t1" : (SELECT JSON_ARRAYAGG(
                   JSON_DUALITY_OBJECT(
                     WITH (INSERT, UPDATE, DELETE)
                       "k_t1c1" : t1c1,
                        "k_t1c2" : t1c2
                   )) FROM t1 WHERE t1.t1c2 = t2.t2c1)
            ) FROM t2;


SELECT * FROM dv1;
SELECT * FROM t1;
SELECT * FROM t2;

--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO dv1 VALUES (
' {
     "k_t2c2" : 400,
     "nested_t1" : [{
                      "k_t1c1" : 42
                    }]
  } ');

DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;


--echo # Verify that insert is permitted and gives expected results when
--echo # AUTO_INCREMENT is used on a column which is not part of a
--echo # join-condition.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY REFERENCES t1(t1c1), t2c2 INT UNIQUE AUTO_INCREMENT);

INSERT INTO t1 VALUES (1, 2);
INSERT INTO t2(t2c1,t2c2) VALUES (1, 200);

CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : t2c1,
               "k_t2c2" : t2c2,
               "k_singleton_t1" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                            "k_t1c1" : t1c1,
                                            "k_t1c2" : t1c2
                                          ) FROM t1  WHERE t1.t1c1 = t2.t2c1)
            ) FROM t2;

SELECT * FROM dv1;
SELECT * FROM t1;
SELECT * FROM t2;

INSERT INTO dv1 VALUES (
' {
     "_id" : 3,
     "k_singleton_t1" : {
                      "k_t1c1" : 3,
                      "k_t1c2" : 4
                    }
  } ');

SELECT * FROM dv1;
SELECT * FROM t1;
SELECT * FROM t2;

INSERT INTO dv1 VALUES (
' {

     "_id" : 4,
     "k_singleton_t1" : {
                      "k_t1c1" : 4
       }
  } ');

SELECT * FROM dv1;
SELECT * FROM t1;
SELECT * FROM t2;

DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;
