# Inserting generated value for AI column is not supported in V1.  When allowed,
# should instead fail with ER_BAD_NULL_ERROR (1048)
--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (
' {
     "_id" : null,
     "f2" : 400,
     "ChildNode" : [{
                      "f3" : null,
                      "f4" : 4
                    }]
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Inserting new Root Object and new Sub-object with null value for PK columns.
--echo # Root object - Primary Key Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key, Auto-increment   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY AUTO_INCREMENT REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
             '_id' : f1,
             'f2'  : f2,
             'ChildNode' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                       'f3' : f3,
                                       'f4' : f4
                                     )) FROM p_t2 WHERE p_t2.f3 = p_t1.f1
                         )
            ) FROM p_t1;

SELECT * FROM p_dv1;

# Inserting generated value for AI column is not supported in V1.  When allowed,
# should instead fail with ER_BAD_NULL_ERROR (1048)
--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (
' {
     "_id" : null,
     "f2" : 400,
     "ChildNode" : [{
                      "f3" : null,
                      "f4" : 4
                    }]
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Inserting new Root Object and new Sub-object. Verify trigger execution.
--echo # Triggers:
--echo #     For INSERT event on Root table.
--echo #     For INSERT event on Sub-object's  table.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

CREATE TABLE p_t1_trigger_tbl(msg VARCHAR(500));
CREATE TRIGGER p_t1_trigger1 BEFORE INSERT ON p_t1
     FOR EACH ROW INSERT INTO p_t1_trigger_tbl VALUES("BEFORE INSERT EVENT");
CREATE TRIGGER p_t1_trigger2 AFTER INSERT ON p_t1
     FOR EACH ROW INSERT INTO p_t1_trigger_tbl VALUES("AFTER INSERT EVENT");

CREATE TABLE p_t2_trigger_tbl(msg VARCHAR(500));
CREATE TRIGGER p_t2_trigger1 BEFORE INSERT ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("BEFORE INSERT EVENT");
CREATE TRIGGER p_t2_trigger2 AFTER INSERT ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("AFTER INSERT EVENT");

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
             '_id' : f1,
             'f2'  : f2,
             'ChildNode' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                       'f3' : f3,
                                       'f4' : f4
                                     )) FROM p_t2 WHERE p_t2.f3 = p_t1.f1
                         )
            ) FROM p_t1;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f2" : 300,
     "ChildNode" : [{
                      "f3" : 2,
                      "f4" : 3
                    }]
  } ');

SELECT * FROM p_dv1;
SELECT * FROM p_t1_trigger_tbl;
SELECT * FROM p_t2_trigger_tbl;

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP TABLE p_t1_trigger_tbl;
DROP TABLE p_t2_trigger_tbl;


--echo ################################################################################
--echo # Inserting new Root Object and multiple Sub-objects.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT REFERENCES p_t1(f1));

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
             '_id' : f1,
             'f2'  : f2,
             'ChildNode' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                       'f3' : f3,
                                       'f4' : f4
                                     )) FROM p_t2 WHERE p_t2.f4 = p_t1.f1
                         )
            ) FROM p_t1;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f2" : 300,
     "ChildNode" : [
                     {
                      "f3" : 111,
                      "f4" : 2
                     },
                     {
                      "f3" : 112,
                      "f4" : 2
                     }
                   ]
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Inserting into Root object and Sub object using table with self referencing FK.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE
--echo ################################################################################
CREATE TABLE p_employee (empid INT PRIMARY KEY,
                         name VARCHAR(100),
                         mgrid INT REFERENCES p_employee(empid));

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
            '_id' : empid,
            'name' : name,
            'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                   'empid': empid,
                                   'name' : name,
                                   'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                          'empid' : empid,
                                                          'name'  : name
                                                         ) FROM p_employee MM  WHERE MM.empid = M.mgrid)
                                 ) FROM p_employee M  WHERE M.empid = emp.mgrid)
            ) FROM p_employee emp;

INSERT INTO p_dv1 VALUES ('
{
  "_id" : 10,
  "name"  : "FirstEmployee",
  "mgr"   : {
              "empid" : 2,
              "name"  : "Mgr",
              "mgr"   : {
                           "empid" : 1,
                           "name"  : "M1"
                        }
            }
} ' );

SELECT * FROM p_dv1;
SELECT * FROM p_employee;

DROP TABLE p_employee;


#--echo ################################################################################
#--echo # Inserting into Root object and Sub object using table with circular referencing.
#--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
#--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE
#--echo ################################################################################

CREATE TABLE p_department (deptid INT PRIMARY KEY,
                           name varchar(100),
                           mgrid INT);
CREATE TABLE p_employee (empid INT PRIMARY KEY,
                         name VARCHAR(100),
                         deptid INT REFERENCES p_department(deptid));

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
  '_id' : empid,
  'name' : name,
  'dept' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                          'deptid' : deptid,
                          'name'   : name,
                          'dept_mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                      'empid' : empid,
                                                      'name'  : name
                                               ) FROM p_employee DM
                                          WHERE DM.empid = D.mgrid)
                   ) FROM p_department D WHERE D.deptid = E.deptid)
) FROM p_employee E;

INSERT INTO p_dv1 VALUES (
' {
    "_id" : 10,
    "name" : "FirstEmployee",
    "dept" : { "deptid" : 888,
               "name"   : "IMPACT",
               "dept_mgr" : {
                              "empid" : 1,
                              "name"  : "M1"
                            }
              }
    }');

SELECT * FROM p_dv1;
SELECT * FROM p_department;
SELECT * FROM p_employee;

DROP TABLE p_employee;
DROP TABLE p_department;


#--echo ################################################################################
#--echo # Inserting new Root Object and multiple Sub-objects.
#--echo # Root object - Primary Key, Foreign Key  Table annotations: INSERT, UPDATE, DELETE
#--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE
#--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (2, 1);
INSERT INTO p_t2 VALUES (2, 200);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
             '_id' : f3,
             'f4'  : f4,
             'ChildN1' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                       'f1' : f1,
                                       'f2' : f2
                                  ) FROM p_t1 WHERE p_t2.f3 = p_t1.f1
                         ),
             'ChildN2' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                       'f1' : f1,
                                       'f2' : f2
                                  ) FROM p_t1 WHERE p_t2.f3 = p_t1.f1
                         )
            ) FROM p_t2;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 3,
     "f4" : 30,
     "ChildN1" :  {
                      "f1" : 3,
                      "f2" : 111
                   },
     "ChildN2" :  {
                      "f1" : 3,
                      "f2" : 111
                  }
  } ');

SELECT * FROM p_dv1;
SELECT * FROM p_t1;
SELECT * FROM p_t2;

--error ER_JDV_PK_DUPLICATES_NOT_IDENTICAL 
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 4,
     "f4" : 3,
     "ChildN1" :  {
                      "f1" : 4,
                      "f2" : 111
                   },
     "ChildN2" :  {
                      "f1" : 4,
                      "f2" : 222
                  }
  } ');

SELECT * FROM p_dv1;
SELECT * FROM p_t1;
SELECT * FROM p_t2;

DROP TABLE p_t2;
DROP TABLE p_t1;

