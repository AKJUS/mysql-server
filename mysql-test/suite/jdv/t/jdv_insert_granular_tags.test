' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : [{
                      "f1" : 2,
                      "f2" : 2
                    }]
  } ');

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP VIEW p_dv1;

