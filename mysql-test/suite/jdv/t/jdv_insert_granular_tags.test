# should instead fail with ER_BAD_NULL_ERROR (1048)
--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (
' {
     "_id" : null,
     "f2" : 400,
     "ChildNode" : [{
                      "f3" : null,
                      "f4" : 4
                    }]
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP VIEW p_dv1;

--echo ## Root object - Primary Key Table annotations: INSERT
--echo ## Sub-object - Foreign Key, Auto-increment   Table annotations: INSERT

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY AUTO_INCREMENT REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH INSERT
             '_id' : f1,
             'f2'  : f2,
             'ChildNode' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH INSERT
                                       'f3' : f3,
                                       'f4' : f4
                                     )) FROM p_t2 WHERE p_t2.f3 = p_t1.f1
                         )
            ) FROM p_t1;

SELECT * FROM p_dv1;

# Inserting generated value for AI column is not supported in V1.  When allowed,
# should instead fail with ER_BAD_NULL_ERROR (1048)
--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (
' {
     "_id" : null,
     "f2" : 400,
     "ChildNode" : [{
                      "f3" : null,
                      "f4" : 4
                    }]
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP VIEW p_dv1;

--echo ################################################################################

--echo # Inserting new Root Object and new Sub-object. Verify trigger execution.
--echo # Triggers:
--echo #     For INSERT event on Root table.
--echo #     For INSERT event on Sub-object's  table.
--echo # Root object - Primary Key  Table annotations: INSERT
--echo # Sub-object - Foreign Key   Table annotations: INSERT

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

CREATE TABLE p_t1_trigger_tbl(msg VARCHAR(500));
CREATE TRIGGER p_t1_trigger1 BEFORE INSERT ON p_t1
     FOR EACH ROW INSERT INTO p_t1_trigger_tbl VALUES("BEFORE INSERT EVENT");
CREATE TRIGGER p_t1_trigger2 AFTER INSERT ON p_t1
     FOR EACH ROW INSERT INTO p_t1_trigger_tbl VALUES("AFTER INSERT EVENT");

CREATE TABLE p_t2_trigger_tbl(msg VARCHAR(500));
CREATE TRIGGER p_t2_trigger1 BEFORE INSERT ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("BEFORE INSERT EVENT");
CREATE TRIGGER p_t2_trigger2 AFTER INSERT ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("AFTER INSERT EVENT");

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH INSERT
             '_id' : f1,
             'f2'  : f2,
             'ChildNode' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH INSERT
                                       'f3' : f3,
                                       'f4' : f4
                                     )) FROM p_t2 WHERE p_t2.f3 = p_t1.f1
                         )
            ) FROM p_t1;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f2" : 300,
     "ChildNode" : [{
                      "f3" : 2,
                      "f4" : 3
                    }]
  } ');

SELECT * FROM p_dv1;
SELECT * FROM p_t1_trigger_tbl;
SELECT * FROM p_t2_trigger_tbl;

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP TABLE p_t1_trigger_tbl;
DROP TABLE p_t2_trigger_tbl;
DROP VIEW p_dv1;

--echo ################################################################################

--echo # Inserting new Root Object and multiple Sub-objects.
--echo # Root object - Primary Key  Table annotations: INSERT
--echo # Sub-object - Foreign Key   Table annotations: INSERT

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT REFERENCES p_t1(f1));

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH INSERT
             '_id' : f1,
             'f2'  : f2,
             'ChildNode' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH INSERT
                                       'f3' : f3,
                                       'f4' : f4
                                     )) FROM p_t2 WHERE p_t2.f4 = p_t1.f1
                         )
            ) FROM p_t1;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f2" : 300,
     "ChildNode" : [
                     {
                      "f3" : 111,
                      "f4" : 2
                     },
                     {
                      "f3" : 112,
                      "f4" : 2
                     }
                   ]
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
