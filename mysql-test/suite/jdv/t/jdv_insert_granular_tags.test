DROP VIEW p_dv1;

--echo ################################################################################

--echo # Inserting into Root object and Sub object using table with self referencing FK.
--echo # Root object - Primary Key  Table annotations: INSERT
--echo # Sub-object - Foreign Key   Table annotations: INSERT

CREATE TABLE p_employee (empid INT PRIMARY KEY,
                         name VARCHAR(100),
                         mgrid INT REFERENCES p_employee(empid));

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
            '_id' : empid,
            'name' : name,
            'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
                                   'empid': empid,
                                   'name' : name,
                                   'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
                                                          'empid' : empid,
                                                          'name'  : name
                                                         ) FROM p_employee MM  WHERE MM.empid = M.mgrid)
                                 ) FROM p_employee M  WHERE M.empid = emp.mgrid)
            ) FROM p_employee emp;

INSERT INTO p_dv1 VALUES ('
{
  "_id" : 10,
  "name"  : "FirstEmployee",
  "mgr"   : {
              "empid" : 2,
              "name"  : "Mgr",
              "mgr"   : {
                           "empid" : 1,
                           "name"  : "M1"
                        }
            }
} ' );

SELECT * FROM p_dv1;
SELECT * FROM p_employee;

DROP TABLE p_employee;
DROP VIEW p_dv1;

--echo ################################################################################

#--echo # Inserting into Root object and Sub object using table with circular referencing.
#--echo # Root object - Primary Key  Table annotations: INSERT
#--echo # Sub-object - Foreign Key   Table annotations: INSERT

CREATE TABLE p_department (deptid INT PRIMARY KEY,
                           name varchar(100),
                           mgrid INT);
CREATE TABLE p_employee (empid INT PRIMARY KEY,
                         name VARCHAR(100),
                         deptid INT REFERENCES p_department(deptid));

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
  '_id' : empid,
  'name' : name,
  'dept' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
                          'deptid' : deptid,
                          'name'   : name,
                          'dept_mgr' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
                                                      'empid' : empid,
                                                      'name'  : name
                                               ) FROM p_employee DM
                                          WHERE DM.empid = D.mgrid)
                   ) FROM p_department D WHERE D.deptid = E.deptid)
) FROM p_employee E;

INSERT INTO p_dv1 VALUES (
' {
    "_id" : 10,
    "name" : "FirstEmployee",
    "dept" : { "deptid" : 888,
               "name"   : "IMPACT",
               "dept_mgr" : {
                              "empid" : 1,
                              "name"  : "M1"
                            }
              }
    }');

SELECT * FROM p_dv1;
SELECT * FROM p_department;
SELECT * FROM p_employee;

DROP TABLE p_employee;
DROP TABLE p_department;
DROP VIEW p_dv1;

