--echo ################################################################################
--echo # Inserting new Root object.
--echo # Root object - Primary key   Table annotations: READ_ONLY

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);

--echo ## Providing no tags
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');

--echo ## Providing UPDATE, DELETE tags
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
                  WITH (UPDATE, DELETE)
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');

--echo ## Providing NO INSERT tag
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
                  WITH NO INSERT
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');

--echo ## Providing NO INSERT, UPDATE, DELETE tags
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
                  WITH (NO INSERT, UPDATE, DELETE)
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');

--echo ## Providing NO INSERT, NO UPDATE, NO DELETE tags
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
                    WITH (NO INSERT, NO UPDATE, NO DELETE)
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');

--echo ## Providing INSERT tag

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (' {} ');

--error ER_JDV_NULL_INSERT_VALUE
INSERT INTO p_dv1 VALUES (NULL);
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 2, "f2" : null } ');
SELECT * FROM p_dv1;

DROP TABLE p_t1;

--echo ## Providing INSERT, NO UPDATE tags

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT DEFAULT 24);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, NO UPDATE)
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (' {} ');

--error ER_JDV_NULL_INSERT_VALUE
INSERT INTO p_dv1 VALUES (NULL);
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 2, "f2" : null } ');
SELECT * FROM p_dv1;

DROP TABLE p_t1;

--echo ## Providing INSERT, NO UPDATE, NO DELETE tags

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT DEFAULT 24);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, NO UPDATE, NO DELETE)
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
INSERT INTO p_dv1 VALUES (' {} ');

--error ER_JDV_NULL_INSERT_VALUE
INSERT INTO p_dv1 VALUES (NULL);
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 1, "f2" : 1 } ');
SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (' { "_id" : 2, "f2" : null } ');
SELECT * FROM p_dv1;

DROP TABLE p_t1;
DROP VIEW p_dv1;

--echo ################################################################################

--echo # Inserting new Root Object and new Sub-object.

--echo ## Root object - Foreign Key  Table annotations: INSERT
--echo ## Sub-object - Primary Key   Table annotations: NO INSERT

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 200);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(
                                          WITH NO INSERT
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1 WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

--error ER_JDV_MISSING_READONLY_SUBOBJECT
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : {
                      "f1" : 2,
                      "f2" : 3
                    }
  } ');

SELECT * FROM p_dv1;

--echo ## Root object - Foreign Key  Table annotations: NO INSERT
--echo ## Sub-object - Primary Key   Table annotations: INSERT

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH NO INSERT
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(
                                          WITH INSERT
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1 WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : {
                      "f1" : 2,
                      "f2" : 3
                    }
  } ');

SELECT * FROM p_dv1;

--echo ## Root object - Foreign Key  Table annotations: READ ONLY
--echo ## Sub-object - Primary Key   Table annotations: INSERT

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(
                                          WITH INSERT
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1 WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

--error ER_JDV_MISSING_INSERT_TAG
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : {
                      "f1" : 2,
                      "f2" : 3
                    }
  } ');

SELECT * FROM p_dv1;

--echo ## Root object - Foreign Key  Table annotations: INSERT
--echo ## Sub-object - Primary Key   Table annotations: READ ONLY

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(
                                          WITH (NO INSERT, NO UPDATE, NO DELETE)
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1 WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

--error ER_JDV_MISSING_READONLY_SUBOBJECT
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : {
                      "f1" : 2,
                      "f2" : 3
                    }
  } ');

SELECT * FROM p_dv1;

--echo ## Root object - Foreign Key  Table annotations: INSERT
--echo ## Sub-object - Primary Key   Table annotations: INSERT

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
                                            "f1" : f1,
                                            "f2" : f2
                                          ) FROM p_t1  WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4" : 300,
     "ChildNode" : {
                      "f1" : 2,
                      "f2" : 3
                    }
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP VIEW p_dv1;

