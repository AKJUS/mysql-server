INSERT INTO p_t1 VALUES (3, 3);
INSERT INTO p_t1 VALUES (4, 3);
INSERT INTO p_t1 VALUES (5, 3);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH INSERT
                                            "f1" : f1,
                                            "f2" : f2
                                          )) FROM p_t1 WHERE p_t1.f2 = p_t2.f3)
            ) FROM p_t2;

SELECT * FROM p_dv1;

INSERT INTO p_dv1 VALUES (
' {
     "_id" : 3,
     "f4" : 300,
     "ChildNode" : [
                     { "f1" : 2, "f2" : 3 },
                     { "f1" : 3, "f2" : 3 }
                   ]
  } ');

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP VIEW p_dv1;

