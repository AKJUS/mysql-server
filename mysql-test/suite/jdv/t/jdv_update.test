#
# Test file contains cases to verify update operations on JSON duality view.
#
#
#

--echo ################################################################################
--echo # UPDATE statement restrictions for JSON duality view.
--echo ################################################################################

CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);

INSERT INTO p_t2 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
               "f4" : f4
            ) FROM p_t2 ;

--error ER_JDV_OPERATION_NOT_SUPPORTED
UPDATE LOW_PRIORITY p_dv1 SET data =  ' { "_id" : 1, "f4" : 4 }';

--error ER_JDV_OPERATION_NOT_SUPPORTED
UPDATE IGNORE p_dv1 SET data =  ' { "_id" : 1, "f4" : 4 }';

--error ER_JDV_OPERATION_NOT_SUPPORTED
UPDATE p_dv1, p_t2 SET p_dv1.data = '{ "_id" : 1, "f4" : 4 }', p_t2.f4 = 4;

UPDATE p_dv1 SET data = JSON_SET(data, '$.f4', 3);

INSERT INTO p_t2 VALUES (2, 3);
--error ER_JDV_OPERATION_NOT_SUPPORTED
UPDATE p_dv1 SET data = JSON_SET(data, '$.f4', 4);

DROP TABLE p_t2;


--echo #################################################################################
--echo # Verify warning messages aggregation for JSON duality view object update.
--echo #################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);

INSERT INTO p_t1 VALUES (1, 1);
INSERT INTO p_t2 VALUES (1, 1);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
              "f4" : f4,
              "ChildNode" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                               "f1" : f1,
                                               "f2" : f2)
                            FROM p_t1
                            WHERE p_t1.f1 = p_t2.f3)
            ) FROM p_t2 ;

SELECT * FROM p_dv1;
UPDATE p_dv1 SET data = ' { "_id" : 1, "f4" : 4, "ChildNode" : {"f1" : 1, "f2" : 4 }, "_metadata": {"etag": "1ec721700727fedd824e5146fad497e5"} }';
SELECT * FROM p_dv1;

UPDATE p_dv1 SET data = JSON_SET(data, '$.f4', 5);
SELECT * FROM p_dv1;

SET @orig_sql_mode = @@sql_mode;
SET sql_mode = 0;
UPDATE p_dv1 SET data = ' { "_id" : 1, "f4" : "123abcd", "ChildNode" : {"f1" : 1, "f2" : "123abcd" }, "_metadata": {"etag": "5b02ec9cc10b96a4e4d9cfa3fe12d718"} }';
SET @@sql_mode = @orig_sql_mode;

SELECT * FROM p_dv1;

DROP TABLE p_t1;
DROP TABLE p_t2;


--echo ################################################################################
--echo # Updating new Root object. (No Subject for view)
--echo # Root object - Primary key   Table annotations: READ_ONLY
--echo ################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);

INSERT INTO p_t1 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1;

--error ER_JDV_MISSING_UPDATE_TAG
UPDATE p_dv1 SET data = '{ "_id" : 1, "f2" : 1 } ';

DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating new Root object.
--echo # Root object - Primary key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);

INSERT INTO p_t1 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    "_id" : f1,
                    "f2" : f2
                  ) FROM p_t1 ;

--error ER_JDV_PRIMARY_KEY_MUST_BE_PROVIDED
UPDATE p_dv1 SET data = '{}';
SELECT * FROM p_dv1;

--error ER_JDV_NULL_UPDATE_VALUE
UPDATE p_dv1 SET data = NULL;
SELECT * FROM p_dv1;

--error ER_JDV_MISSING_VALUE
UPDATE p_dv1 SET data = '{ "_id" : 1 } ';

UPDATE p_dv1 SET data = '{ "_id" : 1, "f2" : 1, "_metadata": {"etag": "c05bfee044e2572d142725a5bf6e8bf4"} } ';
SELECT * FROM p_dv1;

DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object's Primary Key column.
--echo # Root object - Foreign Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY REFERENCES p_t1(f1), f12 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
    '_id' : f11,
    'f12' : f12,
    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                        'f1' : f1,
                        'f2' : f2
                        )) FROM p_t1
                        WHERE p_t1.f1 = p_t2.f11)
) FROM p_t2 ;

SELECT * FROM p_dv1;

--error ER_JDV_JOIN_CONDITION_NOT_SATISFIED
UPDATE p_dv1 SET data = ' {
    "_id" : 4,
    "f12" : 2,
    "childN" : [{
                "f1" : 1,
                "f2" : 30
               }]
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;



--echo ################################################################################
--echo # Updating Root Object's non-primary Key columns. No changes to Sub-object.
--echo # Root object - Foreign Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY REFERENCES p_t1(f1), f12 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
    '_id' : f11,
    'f12' : f12,
    'childN' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                        'f1' : f1,
                        'f2' : f2
                    ) FROM p_t1  WHERE p_t1.f1 = p_t2.f11)
) FROM p_t2 ;

SELECT * FROM p_dv1;

UPDATE p_dv1 SET data = ' {
    "_id" : 1,
    "f12" : 3,
    "childN" : {
                "f1" : 1,
                "f2" : 2
               },
    "_metadata": {"etag": "fc4814ef839b66d33df1a52c8dc67d60"}
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object's and Sub-object's non-primary Key columns.
--echo # Root object - Foreign Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: READ_ONLY
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY REFERENCES p_t1(f1), f12 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
    '_id' : f11,
    'f12' : f12,
    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(
                        'f1' : f1,
                        'f2' : f2
                        )) FROM p_t1 WHERE p_t1.f1 = p_t2.f11)
) FROM p_t2 ;

SELECT * FROM p_dv1;

--error ER_JDV_MISSING_UPDATE_TAG
UPDATE p_dv1 SET data = ' {
    "_id" : 1,
    "f12" : 3,
    "childN" : [{
                "f1" : 1,
                "f2" : 333
               }]
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object's and Sub-object's non-primary Key columns.
--echo # Root object - Foreign Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY REFERENCES p_t1(f1), f12 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
    '_id' : f11,
    'f12' : f12,
    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                        'f1' : f1,
                        'f2' : f2
                        )) FROM p_t1
                        WHERE p_t1.f1 = p_t2.f11)
) FROM p_t2 ;

SELECT * FROM p_dv1;

UPDATE p_dv1 SET data = ' {
    "_id" : 1,
    "f12" : 3,
    "childN" : [{
                "f1" : 1,
                "f2" : 333
               }],
    "_metadata": {"etag": "8a7cd20305686a6f0127bbf08749fcfe"}
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object and inserting Sub-object.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: READ ONLY
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT);

INSERT INTO p_t1 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
    '_id' : f1,
    'f2' : f2,
    'childN' : (SELECT JSON_DUALITY_OBJECT(
                        'f11' : f11,
                        'f12' : f12
                    ) FROM p_t2 WHERE p_t1.f1 = p_t2.f11)
) FROM p_t1 ;

SELECT * FROM p_dv1;

--error ER_JDV_MISSING_INSERT_TAG
UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : {"f11" : 1, "f12" : 1 }
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object and inserting Sub-object.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT);

INSERT INTO p_t1 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
    '_id' : f1,
    'f2' : f2,
    'childN' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                        'f11' : f11,
                        'f12' : f12
                    ) FROM p_t2  WHERE p_t1.f1 = p_t2.f11)
) FROM p_t1 ;

SELECT * FROM p_dv1;

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : {"f11" : 1, "f12" : 1 },
      "_metadata": {"etag": "6c529e2adb31bc08ce63c57af35ffae4"}
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object and no changes to Sub-object.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY REFERENCES p_t1(f1), f12 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f12' : f12
                                            )) FROM p_t2  WHERE p_t2.f11 = p_t1.f1
                                )
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 333,
      "childN" : [{"f11" : 1, "f12":2}],
      "_metadata": {"etag": "073a8c14e558c59d028bc2a64d9aad2d"}
} ';


SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object and Inserting Sub-object.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: READ ONLY
--echo ################################################################################

