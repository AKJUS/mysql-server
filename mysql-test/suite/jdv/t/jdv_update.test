--echo ################################################################################
--echo # Updating root object and Sub object using table with self referencing FK.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE
--echo ################################################################################
CREATE TABLE p_employee (empid INT PRIMARY KEY,
                         name VARCHAR(100),
                         mgrid INT REFERENCES p_employee(empid));

INSERT INTO p_employee VALUES(1, "M1", NULL);
INSERT INTO p_employee VALUES(2, "Mgr", 1);
INSERT INTO p_employee VALUES(10, "FirstEmployee", 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
            '_id' : empid,
            'name' : name,
            'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                   'empid': empid,
                                   'name' : name,
                                   'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                          'empid' : empid,
                                                          'name'  : name
                                                         ) FROM p_employee MM  WHERE MM.empid = M.mgrid)
                                 ) FROM p_employee M  WHERE M.empid = emp.mgrid)
            ) FROM p_employee emp ;

SELECT * FROM p_dv1;

UPDATE p_dv1 SET data = '
{
  "_id" : 10,
  "name"  : "Manu",
  "_metadata": {"etag": "c751d860368bbae08179c07e686f2d07"},
  "mgr"   : {
              "empid" : 2,
              "name"  : "Manager",
              "mgr"   : {
                           "empid" : 1,
                           "name"  : "SeniorManager"
                        }
            }
} ' WHERE JSON_EXTRACT(data, "$._id") = 10;

SELECT * FROM p_dv1;
SELECT * FROM p_employee;

DROP TABLE p_employee;


--echo ################################################################################
--echo # Updating Root object and Sub object using table with circular referecing.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE
--echo ################################################################################

CREATE TABLE p_department (deptid INT PRIMARY KEY,
                           name varchar(100),
                           mgrid INT);
CREATE TABLE p_employee (empid INT PRIMARY KEY,
                         name VARCHAR(100),
                         deptid INT REFERENCES p_department(deptid));

INSERT INTO p_department VALUES(888, 'IMPACT', 1);
INSERT INTO p_employee VALUES(1, "M1", NULL), (10, "FirstEmployee", 888);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
  '_id' : empid,
  'name' : name,
  'dept' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                          'deptid' : deptid,
                          'name'   : name,
                          'dept_mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                      'empid' : empid,
                                                      'name'  : name
                                               ) FROM p_employee DM
                                          WHERE DM.empid = D.mgrid)
                   ) FROM p_department D  where D.deptid = E.deptid)
) FROM p_employee E ;

SELECT * FROM p_dv1;
SELECT * FROM p_department;
SELECT * FROM p_employee;

UPDATE p_dv1 SET data =
' {
    "_id" : 10,
    "name" : "Manu",
    "dept" : { "deptid" : 888,
               "name"   : "ACT",
               "dept_mgr" : {
                              "empid" : 1,
                              "name"  : "SeniorManager"
                            }
              }
    }' WHERE JSON_EXTRACT(data, '$._id') = 10;

SELECT * FROM p_dv1;
SELECT * FROM p_department;
SELECT * FROM p_employee;

DROP TABLE p_employee;
DROP TABLE p_department;


--echo ################################################################################
--echo # Updating Root Object's Primary Key column.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Primary Key   Table annotations: INSERT, UPDATE, DELETE
--echo # Join_condition - Root object.PK = sub_object.non_pk_column
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);

INSERT INTO p_t1 VALUES (1, 1);
INSERT INTO p_t2 VALUES (1, 200);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
              "_id" : f3,
               "f4" : f4,
               "ChildNode" : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                            "f1" : f1,
                                            "f2" : f2
                                            )) FROM p_t1  WHERE p_t1.f2 = p_t2.f3)
            ) FROM p_t2 ;

SELECT * FROM p_dv1;

--error ER_JDV_JOIN_CONDITION_NOT_SATISFIED
UPDATE p_dv1 SET data = ' {
    "_id" : 10,
    "f4" : 200,
    "ChildNode" : [ {
                    "f1" : 1,
                    "f2" : 1
                  }]
} ';

UPDATE p_dv1 SET data = ' {
    "_id" : 1,
    "f4" : 200,
    "_metadata": {"etag": "33863249072731430253fae08f2c9a7e"},
    "ChildNode" : [ {
                    "f1" : 10,
                    "f2" : 1
                  }]
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


