      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2 WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

--error ER_JDV_MISSING_INSERT_TAG
UPDATE p_dv1 SET data = ' {
     "_id" : 1,
     "f2" : 222,
     "childN" : [ {"f11" : 1, "f13":333} ]
} ';


SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object and Inserting Sub-object.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT REFERENCES p_t1(f1), f13 INT);

INSERT INTO p_t1 VALUES (1, 2);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2  WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

--error ER_JDV_MISSING_VALUE
UPDATE p_dv1 SET data = ' {
     "_id" : 1,
     "childN" : [ {"f11" : 1, "f13":333} ]
} ';

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
     "f2" : 222,
     "childN" : [ {"f11" : 1, "f13":333} ],
     "_metadata": {"etag": "6c529e2adb31bc08ce63c57af35ffae4"}
} ';


SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object, inserting Sub-object and existing Sub-object elements
--echo # are not modified.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT REFERENCES p_t1(f1), f13 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1, 1);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2  WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : [ {"f11" : 1, "f13":1 }, {"f11" : 2, "f13" : 2 } ],
      "_metadata": {"etag": "70237a28cb5ac90c8fef4f093eb6bd4d"}
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object, inserting Sub-object, deleting Sub-object element
--echo # and remaining Sub-object elements are not modified.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT REFERENCES p_t1(f1), f13 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1, 1);
INSERT INTO p_t2 VALUES (2, 1, 11);
INSERT INTO p_t2 VALUES (3, 1, 111);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2  WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : [ {"f11" : 2, "f13":11}, {"f11" : 3, "f13":111}, {"f11" : 4, "f13" : 1111} ],
      "_metadata": {"etag": "e5cb81a89db490b991f6ac00d3755ef6"}
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object, inserting Sub-object, deleting Sub-object element
--echo # modifying sub-object element and remaining Sub-object elements are not modified.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT REFERENCES p_t1(f1), f13 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1, 1);
INSERT INTO p_t2 VALUES (2, 1, 11);
INSERT INTO p_t2 VALUES (3, 1, 111);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2  WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : [ {"f11" : 2, "f13":99}, {"f11" : 3, "f13":111}, {"f11" : 4, "f13" : 1111} ],
      "_metadata": {"etag": "e5cb81a89db490b991f6ac00d3755ef6"}
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object and inserting Sub-objects with same PK value and
--echo # different non-PK values.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT REFERENCES p_t1(f1), f13 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1, 1);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2  WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

--error ER_JDV_PK_DUPLICATES_NOT_IDENTICAL
UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : [ {"f11" : 1, "f13":222}, {"f11" : 1, "f13":111} ]
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object and inserting Sub-objects with same PK value and
--echo # same non-PK values.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT REFERENCES p_t1(f1), f13 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1, 1);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2  WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : [ {"f11" : 1, "f13":222}, {"f11" : 1, "f13":222} ],
      "_metadata": {"etag": "70237a28cb5ac90c8fef4f093eb6bd4d"}
} ';

SELECT * FROM p_dv1;

DROP TABLE p_t2;
DROP TABLE p_t1;


--echo ################################################################################
--echo # Updating Root Object, inserting Sub-object, deleting Sub-object element
--echo # modifying sub-object element and remaining Sub-object elements are not modified.
--echo # Test verifies trigger execution.
--echo # Triggers:
--echo #     For UPDATE event on Root table.
--echo #     For INSERT, UPDATE, DELETE event on Sub-object's  table.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################

CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f11 INT PRIMARY KEY, f12 INT REFERENCES p_t1(f1), f13 INT);

INSERT INTO p_t1 VALUES (1, 2);
INSERT INTO p_t2 VALUES (1, 1, 1);
INSERT INTO p_t2 VALUES (2, 1, 11);
INSERT INTO p_t2 VALUES (3, 1, 111);

CREATE TABLE p_t1_trigger_tbl(msg VARCHAR(500));
CREATE TRIGGER p_t1_trigger1 BEFORE UPDATE ON p_t1
     FOR EACH ROW INSERT INTO p_t1_trigger_tbl VALUES("BEFORE UPDATE EVENT");
CREATE TRIGGER p_t1_trigger2 AFTER UPDATE ON p_t1
     FOR EACH ROW INSERT INTO p_t1_trigger_tbl VALUES("AFTER UPDATE EVENT");

CREATE TABLE p_t2_trigger_tbl(msg VARCHAR(500));
CREATE TRIGGER p_t2_trigger1 BEFORE INSERT ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("BEFORE INSERT EVENT");
CREATE TRIGGER p_t2_trigger2 AFTER INSERT ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("AFTER INSERT EVENT");
CREATE TRIGGER p_t2_trigger3 BEFORE UPDATE ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("BEFORE UPDATE EVENT");
CREATE TRIGGER p_t2_trigger4 AFTER UPDATE ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("AFTER UPDATE EVENT");
CREATE TRIGGER p_t2_trigger5 BEFORE DELETE ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("BEFORE DELETE EVENT");
CREATE TRIGGER p_t2_trigger6 AFTER DELETE ON p_t2
     FOR EACH ROW INSERT INTO p_t2_trigger_tbl VALUES("AFTER DELETE EVENT");

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
      JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                    '_id' : f1,
                    'f2'  : f2,
                    'childN' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                'f11' : f11,
                                                'f13' : f13
                                            )) FROM p_t2  WHERE p_t2.f12 = p_t1.f1)
            ) FROM p_t1 ;

SELECT * FROM  p_dv1;

UPDATE p_dv1 SET data = ' {
     "_id" : 1,
      "f2" : 222,
      "childN" : [ {"f11" : 2, "f13":99}, {"f11" : 3, "f13":111}, {"f11" : 4, "f13" : 1111} ],
      "_metadata": {"etag": "e5cb81a89db490b991f6ac00d3755ef6"}
} ';

SELECT * FROM p_dv1;
SELECT * FROM p_t1_trigger_tbl;
SELECT * FROM p_t2_trigger_tbl;

DROP TABLE p_t2;
DROP TABLE p_t1;
DROP TABLE p_t1_trigger_tbl;
DROP TABLE p_t2_trigger_tbl;


--echo ################################################################################
--echo # Updating Root table and replacing sub-object with an existing object.
--echo # Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
--echo # Sub-object - Foreign Key   Table annotations: INSERT, UPDATE, DELETE
--echo ################################################################################
CREATE TABLE p_department(dept_id INT PRIMARY KEY, dname VARCHAR(100));
CREATE TABLE p_student(suid INT PRIMARY KEY, sname VARCHAR(100), dept_id INT REFERENCES p_department(dept_id));

INSERT INTO p_department VALUES (1, 'ENGLISH');
INSERT INTO p_department VALUES (2, 'MATHS');

INSERT INTO p_student VALUES (101, 'Manu', 1);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
       '_id' : suid,
       'name' : sname,
       'department': (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                   'dept_id'  : dept_id,
                                   'dname' : dname
                                  ) FROM p_department WHERE p_department.dept_id = p_student.dept_id
                     )
     ) FROM p_student ;
SELECT * FROM p_dv1;
SELECT * FROM p_student;

--echo # Replacing department to MATHS from ENGLISH.
UPDATE p_dv1 SET data = '
 {
   "_id" : 101,
   "name" : "Manu",
   "_metadata": {"etag": "0e7e5ac91ef6886a02a3798ecb2dc3f2"},
   "department" : { "dept_id" : 2, "dname" : "MATHS" }
 } ';

SELECT * FROM p_dv1;
SELECT * FROM p_student;

DROP TABLE p_student;
DROP TABLE p_department;


