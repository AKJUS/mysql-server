--echo #################################################################

--echo # Requirement-13: Restrictions for creation options of JSON DUALITY VIEW:
--echo # 13.1 The ALGORITHM = TEMPTABLE option is not supported and must
--echo # result into a semantic error if used.

--error ER_JDV_ALGO_TEMPTABLE_NOT_SUPPORTED
CREATE ALGORITHM = TEMPTABLE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1,
    "C2"  : C2
)
FROM T1;

CREATE OR REPLACE ALGORITHM = UNDEFINED JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1,
    "C2"  : C2
)
FROM T1;

CREATE OR REPLACE ALGORITHM = MERGE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1,
    "C2"  : C2
)
FROM T1;

--echo # 13.2 The [WITH [CASCADED | LOCAL] CHECK OPTION] clause is not
--echo # supported and must report a semantic error if used.

--error ER_JDV_WITH_CHECK_OPTION_NOT_SUPPORTED
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1,
    "C2"  : C2
)
FROM T1
WITH CHECK OPTION;

--error ER_JDV_WITH_CHECK_OPTION_NOT_SUPPORTED
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1,
    "C2"  : C2
)
FROM T1
WITH CASCADED CHECK OPTION;

--error ER_JDV_WITH_CHECK_OPTION_NOT_SUPPORTED
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1,
    "C2"  : C2
)
FROM T1
WITH LOCAL CHECK OPTION;

--echo #################################################################

--echo # Requirement-14: Existence Check for JSON Duality Views in the ALTER Statement
--echo # During the execution of ALTER statement, if view_name does not
--echo # exist or isn't a duality view, a syntax error should be generated.

--error ER_NO_SUCH_TABLE
ALTER JSON DUALITY VIEW non_existent_view
AS SELECT JSON_DUALITY_OBJECT(
    "_id" : C1
) FROM T1;

--echo #################################################################

--echo # Requirement-15: Restrictions on the ALTER Statement for Duality Views

--echo # 15.1 The ALTER statement for JSON duality views does not support
--echo # specifying a column list.

--error ER_JDV_INVALID_DEFINITION_COLUMN_LIST_NOT_SUPPORTED
ALTER JSON DUALITY VIEW dv1 (data)
AS SELECT JSON_DUALITY_OBJECT(
    "_id" : C1
) FROM T1;

--echo # 15.2 ALTER-ing a JSON DUALITY VIEW with a normal VIEW definition
--echo # and vice versa is not supported, and must result into an error
--echo # if attempted.

--error ER_JDV_ALTER_OR_REPLACE_NOT_SUPPORTED
ALTER VIEW dv1 AS
SELECT * FROM T1;

--error ER_JDV_ALTER_OR_REPLACE_NOT_SUPPORTED
ALTER JSON DUALITY VIEW V1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1
) FROM T1;

--error ER_WRONG_OBJECT
ALTER JSON DUALITY VIEW T1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1
) FROM T1;

--error ER_WRONG_OBJECT
ALTER JSON DUALITY VIEW T4 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1
) FROM T1;

--echo #################################################################

--echo # Requirement-16: Compliance of json_duality_select_statement with Defined
--echo # Syntax and Semantic Rules (Since codepath taken by both CREATE
--echo # and ALTER for syntax/semantic check is same, they should work
--echo # out of the box for ALTER)

--error ER_JDV_INVALID_DEFINITION_DUPLICATE_KEYS_NOT_SUPPORTED
ALTER JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "_id" : C1,
    "C2"  : C2,
    "C2"  : C2
) FROM T1;

--error ER_JDV_INVALID_DEFINITION_ID_KEY_NOT_USED_BY_ROOT_TABLE
ALTER JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
    "C1" : C1
) FROM T1;

--echo #################################################################

--echo # Requirement-17: Requirements for SHOW CREATE TABLE/VIEW
--echo # The statement SHOW CREATE VIEW view_name must return the
--echo # CREATE JSON DUALITY VIEW statement that was used to create the
--echo # specified view. The output must contain table annotations
--echo # specified in the duality view definition.

SHOW CREATE VIEW dv1;

CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
       "_id": T2.C1,
       "C2":  T2.C2,
       "T2": (
              SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                     "C1": T1.C1,
                     "C2": T1.C2
              )
              FROM T1
              WHERE T1.C1 = T2.C1
       )
) FROM T2;

SHOW CREATE VIEW dv1;

--echo #################################################################
--echo # Successful CREATE scenario

CREATE TABLE T6 (C1 INT PRIMARY KEY, C2 INT);
ALTER TABLE T2 ADD C4 INT REFERENCES T6(C1);

CREATE OR REPLACE
ALGORITHM = MERGE
DEFINER = current_user()
SQL SECURITY DEFINER
JSON RELATIONAL DUALITY VIEW dv1
AS SELECT JSON_DUALITY_OBJECT(
    WITH (INSERT, UPDATE, DELETE)
    "_id" : C1,
    "C2"  : C2,
    "T2"  : (
                SELECT JSON_ARRAYAGG(
                            JSON_DUALITY_OBJECT(
                                "C1" : C1,
                                "C2" : C2,
                                "T6" : (
                                            SELECT JSON_DUALITY_OBJECT(
                                                WITH (INSERT, UPDATE)
                                                "C1" : C1,
                                                "C2" : C2
                                            )
                                            FROM T6
                                            WHERE T6.C1 = T2.C4
                                       )
                            )
                )
                FROM T2
                WHERE T1.C1 = T2.C2
            )
)
FROM T1;

--echo #################################################################

--echo # Requirement-18: Requirements for INFORMATION_SCHEMA.VIEWS

# Test I_S views for JSON duality views created with
# upper case schema name. Output from I_S will differ:
# LCTN=2 will retain case of schema name, LCTN=1 will not.
# Using replace_regex to mask win/mac difference.

CREATE SCHEMA Sch;

CREATE TABLE Sch.EMPLOYEE (
    ID INT PRIMARY KEY,
    NAME VARCHAR(20),
    CITY VARCHAR(20),
    MANAGER INT REFERENCES EMPLOYEE(ID)
);

CREATE OR REPLACE JSON DUALITY VIEW Sch.DV AS
SELECT JSON_DUALITY_OBJECT(
  "_id": e.ID,
  "NAME": e.NAME,
  "CITY": e.CITY,
  "MANAGER": (
    SELECT JSON_DUALITY_OBJECT(
      "ID": m.ID,
      "NAME": m.NAME,
      "CITY": m.CITY
    )
    FROM Sch.EMPLOYEE m
    WHERE e.MANAGER = m.ID
  )
)
FROM Sch.EMPLOYEE e;
SHOW CREATE VIEW Sch.DV;

CREATE VIEW Sch.Vv AS SELECT * FROM Sch.EMPLOYEE;
SHOW CREATE VIEW Sch.Vv;

if (!$on_case_sensitive_file_system)
{
  --replace_regex /Sch/sch/
}
SELECT * FROM INFORMATION_SCHEMA.VIEW_TABLE_USAGE WHERE TABLE_SCHEMA = 'Sch' ORDER BY VIEW_NAME;
if (!$on_case_sensitive_file_system)
{
  --replace_regex /Sch/sch/
}
SELECT * FROM INFORMATION_SCHEMA.JSON_DUALITY_VIEWS ORDER BY TABLE_NAME;
if (!$on_case_sensitive_file_system)
{
  --replace_regex /Sch/sch/
}
SELECT * FROM INFORMATION_SCHEMA.JSON_DUALITY_VIEW_TABLES ORDER BY TABLE_NAME;
if (!$on_case_sensitive_file_system)
{
  --replace_regex /Sch/sch/
}
SELECT * FROM INFORMATION_SCHEMA.JSON_DUALITY_VIEW_COLUMNS ORDER BY TABLE_NAME;
if (!$on_case_sensitive_file_system)
{
  --replace_regex /Sch/sch/
}
SELECT * FROM INFORMATION_SCHEMA.JSON_DUALITY_VIEW_LINKS ORDER BY TABLE_NAME;

DROP VIEW Sch.Vv;
DROP VIEW Sch.DV;
DROP TABLE Sch.EMPLOYEE;
DROP SCHEMA Sch;

--echo #################################################################

--echo # Requirement-19: Requirements for DROP VIEW

--echo # 19.1 If a duality view with the view_name is present, regardless
--echo # of whether IF EXISTS clause is there or not, the statement
--echo # DROP VIEW must drop the view.

DROP VIEW V1;
DROP VIEW IF EXISTS dv1, dv2;

--echo # 19.2 If duality view with the view_name is not present and
--echo # IF EXISTS flag:
--echo # 19.2.1 is supplied, the statement must succeed with warning.

# warning ER_BAD_TABLE_ERROR
DROP VIEW IF EXISTS non_existent_view;

--echo # 18.2.2 is not supplied, the statement must report an error.

--error ER_BAD_TABLE_ERROR
DROP VIEW non_existent_view;

--echo #################################################################

DROP TABLE T1, T2, T3, T4, T5, T6, T1_TEMP, T2_TEMP, T3_TEMP;

--echo #################################################################
