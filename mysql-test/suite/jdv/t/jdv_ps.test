#
# Test file contains cases to verify duality view DDL and DML with
# prepared statements.
#

CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);

--echo #
--echo # Test case to verify duality view DDL statements with prepared statement.
--echo #

PREPARE create_dv_stmt FROM 'CREATE JSON DUALITY VIEW dv1 AS SELECT
                             JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                               "_id" : f1,
                                               "f2" : f2) FROM t1';

PREPARE replace_dv_stmt FROM 'CREATE OR REPLACE JSON DUALITY VIEW dv1 AS SELECT
                              JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
                                                "_id" : f11,
                                                "f12" : f12,
                                                "child" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
                                                                                      "f1" : f1,
                                                                                      "f2" : f2
                                                                                     ) FROM t1 WHERE t1.f1 = t2.f11))
                                                FROM t2';
PREPARE drop_dv_stmt FROM 'DROP VIEW dv1';

EXECUTE create_dv_stmt;
EXECUTE drop_dv_stmt;
EXECUTE create_dv_stmt;

EXECUTE replace_dv_stmt;
EXECUTE drop_dv_stmt;
EXECUTE replace_dv_stmt;
EXECUTE drop_dv_stmt;


--echo #
--echo # Test case to verify re-prepare of prepared duality view DDL statements.
--echo #

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1 (f1 INT, f2 INT);
CREATE TABLE t2 (f11 INT, f12 INT);

--error ER_JDV_INVALID_DEFINITION_TABLE_WITHOUT_PK_FOUND
EXECUTE create_dv_stmt;

--error ER_JDV_INVALID_DEFINITION_TABLE_WITHOUT_PK_FOUND
EXECUTE replace_dv_stmt;

DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);

EXECUTE create_dv_stmt;
EXECUTE drop_dv_stmt;
EXECUTE replace_dv_stmt;

DROP PREPARE create_dv_stmt;
DROP PREPARE replace_dv_stmt;
DROP PREPARE drop_dv_stmt;


--echo #
--echo # Test case to verify duality view DML statements with prepared statement.
--echo #

PREPARE insert_stmt FROM 'INSERT INTO dv1 VALUES (\' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} \')';
EXECUTE insert_stmt;
SELECT * FROM dv1;
delete from t2;
delete from t1;
EXECUTE insert_stmt;
SELECT * FROM dv1;

PREPARE update_stmt FROM 'UPDATE dv1 SET data = \' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } \'';
EXECUTE update_stmt;
SELECT * FROM dv1;
delete from t2;
delete from t1;
EXECUTE insert_stmt;
EXECUTE update_stmt;
SELECT * FROM dv1;

PREPARE delete_stmt FROM 'DELETE FROM dv1 WHERE JSON_VALUE(data, \'$._id\') = 1';
EXECUTE delete_stmt;
SELECT * FROM dv1;
EXECUTE insert_stmt;
EXECUTE delete_stmt;
SELECT * FROM dv1;

DROP PREPARE insert_stmt;
DROP PREPARE update_stmt;
DROP PREPARE delete_stmt;


--echo #
--echo # Test case to verify duality view DML statements with prepared statement using parameters.
--echo #

SET @json_object1 = '{ "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}}';
PREPARE insert_stmt FROM 'INSERT INTO dv1 VALUES (?)';
EXECUTE insert_stmt USING @json_object1;
SELECT * FROM dv1;
delete from t2;
delete from t1;
EXECUTE insert_stmt USING @json_object1;
SELECT * FROM dv1;

SET @json_object2 = '{ "_id" : 1, "f12" : 2, "child" : {"f1" : 1, "f2" : 2}}';
PREPARE update_stmt FROM 'UPDATE dv1 SET data = ?';
EXECUTE update_stmt USING @json_object2;
SELECT * FROM dv1;
delete from t2;
delete from t1;
EXECUTE insert_stmt USING @json_object1;
EXECUTE update_stmt USING @json_object2;
SELECT * FROM dv1;

SET @id = 1;
PREPARE delete_stmt FROM 'DELETE FROM dv1 WHERE JSON_VALUE(data, \'$._id\') = ?';
EXECUTE delete_stmt USING @id;
SELECT * FROM dv1;
EXECUTE insert_stmt USING @json_object1;
EXECUTE delete_stmt USING @id;
SELECT * FROM dv1;


--echo #
--echo # Test case to verify execution of prepared statement on a invalid duality view.
--echo #

RENAME TABLE t2 TO t2_copy;
RENAME TABLE t1 TO t1_copy;

--error ER_VIEW_INVALID
EXECUTE insert_stmt USING @json_object1;

--error ER_VIEW_INVALID
EXECUTE update_stmt USING @json_object2;

--error ER_VIEW_INVALID
EXECUTE delete_stmt USING @id;

RENAME TABLE t2_copy TO t2;
RENAME TABLE t1_copy TO t1;


--echo #
--echo # Test case to verify re-prepare of prepared duality view DML statements.
--echo #

DROP TABLE t1, t2;

CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);

EXECUTE insert_stmt USING @json_object1;
EXECUTE update_stmt USING @json_object2;
EXECUTE delete_stmt USING @id;

DROP PREPARE insert_stmt;
DROP PREPARE update_stmt;
DROP PREPARE delete_stmt;

DROP TABLE t2;
DROP TABLE t1;
DROP VIEW dv1;
