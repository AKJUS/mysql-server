AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
#################################################################
# Requirement-3: Requirements for schema name in the view name
# 3.1 If schema name is specified, and doesn't exist, an error
# must be reported.
CREATE JSON DUALITY VIEW IF NOT EXISTS DB.dv2
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
ERROR 42000: Unknown database 'db'
# Since, schema name comparisons are case-insensitive
# here, "DB" and "db" are the same schemas.
CREATE SCHEMA db;
CREATE TABLE dB.t(i int primary key);
CREATE OR REPLACE JSON DUALITY VIEW Db.dv1 AS
SELECT JSON_DUALITY_OBJECT(
'_id': DB.T.I
)
FROM db.t;
DROP SCHEMA DB;
