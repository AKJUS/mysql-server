#################################################################
# Requirement-11: Projection requirements for child tables
# Child tables being projected as part of JSON DUALITY VIEW can
# be related to parent tables in one of below 2 types:
#    1. PK - FK Relationship (or Referential Integrity)
#    2. PK - Any Column Relationship
CREATE TABLE T5 (
C1 INT PRIMARY KEY,
C2 INT,
FOREIGN KEY (C1) REFERENCES T1(C1)
);
# 11.1 PK-FK Relationship (or Referential Integrity):
# 11.1.1 Singleton descendent JSON Object Projection (singleton_descendent_json_object):
# When a child table is projected as singleton_descendent_json_object,
# the WHERE clause must enforce the following format:
# child_table.PK = parent_table.FK
# This ensures that the child_table is the foreign key (FK)
# parent of the parent_table, creating a sigleton (i.e. 1:1)
# relationship. A semantic error must be reported if this
# format is not present, indicating that the WHERE clause
# does not maintain the required referential integrity.
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id": T5.C1,
"C2": T5.C2,
"T1": (
SELECT JSON_DUALITY_OBJECT(
"C1": T1.C1,
"C2": T1.C2
)
FROM T1 WHERE T1.C2 = T5.C2
)
) FROM T5;
ERROR HY000: Invalid JSON duality view definition: For singleton descendant object, the primary key column of a current object's table must be used in the WHERE condition. For a nested descendant object, the primary key column of the parent object's table must be used in where condition. Object "T1" violates the rule.
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id": T1.C1,
"C2": T1.C2,
"T5": (
SELECT JSON_DUALITY_OBJECT(
"C1": T5.C1,
"C2": T5.C2
)
FROM T5 WHERE T1.C1 = T5.C1
)
) FROM T1;
# 11.1.2 Nested descendent JSON Object Projection (nested_descendent_json_objects):
# When a child table is projected as nested_descendent_json_objects,
# the WHERE clause must enforce the following format:
# child_table.FK = parent_table.PK
# This ensures that the parent_table is the FK parent of the
# child_table, establishing a nested (i.e. 1:N) relationship.
# A semantic error must be reported if this format is not present,
# indicating that the WHERE clause does not maintain the required
# referential integrity.
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id": T1.C1,
"C2": T1.C2,
"T5": (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"C1": T5.C1,
"C2": T5.C2
)
)
FROM T5 WHERE T1.C2 = T5.C2
)
) FROM T1;
ERROR HY000: Invalid JSON duality view definition: For singleton descendant object, the primary key column of a current object's table must be used in the WHERE condition. For a nested descendant object, the primary key column of the parent object's table must be used in where condition. Object "T5" violates the rule.
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id": T5.C1,
"C2": T5.C2,
"T1": (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"C1": T1.C1,
"C2": T1.C2
)
)
FROM T1 WHERE T1.C1 = T5.C1
)
) FROM T5;
# 11.2 PK - Any column Relationship:
# In this type of relationship, the WHERE clause in the child
# table is of the below form:
# child_table.PK = parent_table.any_column
# OR
# child_table.any_column = parent_table.PK
# Primary Key column from parent_table or child_table must be
# used in the join condition. Please note, columns in the join
# condition can be of different but compatible data types. Child
# table can be projected as singleton_descendent_json_object or
# nested_descedent_json_objects with this relationship. During
# SELECT, if a projection results in multiple sub-objects for
# the singleton_descendent_json_object, then an error is
# reported by the server.
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id": T5.C1,
"C2": T5.C2,
"T1": (
SELECT JSON_DUALITY_OBJECT(
"C1": T1.C1,
"C2": T1.C2
)
FROM T1 WHERE T1.C1 = T5.C2
)
) FROM T5;
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id": T1.C1,
"C2": T1.C2,
"T5": (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"C1": T5.C1,
"C2": T5.C2
)
)
FROM T5 WHERE T1.C1 = T5.C2
)
) FROM T1;
#################################################################
# Requirement-12: Compatiablity requirements for table_annotations_expression
# Building on top of FR-6: In a case where a parent_table
# is Foreign key child of a child_table, usage of the
# DELETE tag with the child_table must result in a semantic error.
