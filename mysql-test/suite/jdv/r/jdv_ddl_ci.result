"_id" : T1.C1,
"C2" : T1.C2,
"T2" : (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"C1" : T2.C1,
"C2" : T2.C2
)
)
FROM T2
WHERE T1.C1 = T2.C2
)
)
FROM T1;
SELECT * FROM dv1;
