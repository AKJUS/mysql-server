dv	CREATE ALGORITHM=UNDEFINED DEFINER=`root`@`localhost` SQL SECURITY DEFINER JSON RELATIONAL DUALITY VIEW `sch`.`dv` AS select json_duality_object('_id':`e`.`ID`,'NAME':`e`.`NAME`,'CITY':`e`.`CITY`,'MANAGER':(select json_duality_object('ID':`m`.`ID`,'NAME':`m`.`NAME`,'CITY':`m`.`CITY`) from `sch`.`employee` `m` where (`e`.`MANAGER` = `m`.`ID`))) AS `Name_exp_1` from `sch`.`employee` `e`	utf8mb4	utf8mb4_0900_ai_ci
CREATE VIEW Sch.Vv AS SELECT * FROM Sch.EMPLOYEE;
