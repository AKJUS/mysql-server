# Requirement-18: Requirements for INFORMATION_SCHEMA.VIEWS
CREATE SCHEMA Sch;
CREATE TABLE Sch.EMPLOYEE (
ID INT PRIMARY KEY,
NAME VARCHAR(20),
CITY VARCHAR(20),
MANAGER INT REFERENCES EMPLOYEE(ID)
);
CREATE OR REPLACE JSON DUALITY VIEW Sch.DV AS
SELECT JSON_DUALITY_OBJECT(
"_id": e.ID,
"NAME": e.NAME,
"CITY": e.CITY,
"MANAGER": (
SELECT JSON_DUALITY_OBJECT(
"ID": m.ID,
"NAME": m.NAME,
"CITY": m.CITY
)
FROM Sch.EMPLOYEE m
WHERE e.MANAGER = m.ID
)
)
FROM Sch.EMPLOYEE e;
SHOW CREATE VIEW Sch.DV;
