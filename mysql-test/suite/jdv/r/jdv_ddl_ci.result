SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id": T1.C1,
"C2": T1.C2,
"T2": (
SELECT JSON_DUALITY_OBJECT(WITH DELETE
"C1": T2.C1,
"C2": T2.C2
)
FROM T2
WHERE T1.C1 = T2.C1
)
) FROM T1;
