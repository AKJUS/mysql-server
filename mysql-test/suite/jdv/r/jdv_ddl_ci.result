#################################################################
# Requirement-7: Requirements for table_annotations_expression
# 7.1 Tables being projected (i.e. root_table_name or child_table_name
# clauses) in the duality view can optionally have table annotations.
# The following table annotations must be supported:
#    INSERT
#    DELETE
#    UPDATE
CREATE OR REPLACE JSON DUALITY VIEW dv1
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
CREATE OR REPLACE JSON DUALITY VIEW dv1
AS SELECT JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
"_id" : C1,
"C2" : C2
)
FROM T1;
# 7.2 There can be order-agnostic combinations of these annotations.
# These annotations must be enclosed with round brackets i.e. "(" and ")",
# and must be separated by comma ",": WITH (INSERT, UPDATE, DELETE)
CREATE OR REPLACE JSON DUALITY VIEW dv1
AS SELECT JSON_DUALITY_OBJECT(
WITH (UPDATE, INSERT, DELETE)
"_id" : C1,
"C2" : C2
)
FROM T1;
