CREATE JSON DUALITY VIEW T2
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
ERROR 42S01: Table 'T2' already exists
# 2.3 Vice versa of point-2 is also valid i.e. An attempt to
# create a normal view with the name already used by a table or a
