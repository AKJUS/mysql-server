# Requirement-13: Restrictions for creation options of JSON DUALITY VIEW:
# 13.1 The ALGORITHM = TEMPTABLE option is not supported and must
# result into a semantic error if used.
CREATE ALGORITHM = TEMPTABLE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2"  : C2
)
FROM T1;
ERROR HY000: ALGORITHM = TEMPTABLE is not supported for duality views.
CREATE OR REPLACE ALGORITHM = UNDEFINED JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2"  : C2
)
FROM T1;
CREATE OR REPLACE ALGORITHM = MERGE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2"  : C2
)
FROM T1;
# 13.2 The [WITH [CASCADED | LOCAL] CHECK OPTION] clause is not
# supported and must report a semantic error if used.
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2"  : C2
)
FROM T1
WITH CHECK OPTION;
ERROR HY000: Invalid JSON duality view definition: WITH [LOCAL/CASCADED] CHECK OPTION clause is not supported.
