#################################################################
# Requirement-2: Name conflict handling for view_name
# 2.1 If duality view with name view_name is already present in
# the current schema, and if the statement is not CREATE OR
# REPLACE, an error must be reported.
# It also covers 1.3.1 : If lower_case_table_names = 0, view_name
# equality implies same character case. i.e. view_name stored on
# disk using the character case specified in the statement.
# Name comparisons are case-sensitive.
CREATE JSON DUALITY VIEW dv1
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
ERROR 42S01: Table 'dv1' already exists
# 1.3.2 If lower_case_table_names != 0, character case used for
# view_name does not matter.
CREATE JSON DUALITY VIEW DV1
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
ERROR 42S01: Table 'DV1' already exists
# 2.2 If a normal view or table with name view_name are present
# in the current schema, regardless of whether OR REPLACE clause
# used or not, an error must be reported.
CREATE VIEW V1 AS SELECT * FROM T1;
CREATE OR REPLACE JSON DUALITY VIEW V1
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
ERROR HY000: View 'test.v1' of 'SQL' type already exists. Replacing view with mismatched type is not supported.
CREATE JSON DUALITY VIEW V1
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
ERROR 42S01: Table 'V1' already exists
CREATE TABLE T2 (C1 INT PRIMARY KEY, C2 INT REFERENCES T1(C1));
CREATE OR REPLACE JSON DUALITY VIEW T2
AS SELECT JSON_DUALITY_OBJECT(
"_id" : C1,
"C2" : C2
)
FROM T1;
