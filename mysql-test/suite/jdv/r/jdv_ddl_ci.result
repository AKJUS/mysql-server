DROP VIEW IF EXISTS dv1, dv2;
# 19.2 If duality view with the view_name is not present and
# IF EXISTS flag:
# 19.2.1 is supplied, the statement must succeed with warning.
DROP VIEW IF EXISTS non_existent_view;
