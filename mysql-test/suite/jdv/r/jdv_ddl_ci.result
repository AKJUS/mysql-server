CREATE OR REPLACE JSON RELATIONAL DUALITY VIEW `dv` AS
SELECT JSON_DUALITY_OBJECT(
"_id" : `T1_TEMP`.`C1`,
"C2"  : `T1_TEMP`.`C2`,
"T2_TEMP"  : (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"C1" : `T2_TEMP`.`C1`,
"C2" : `T2_TEMP`.`C2`,
"T3_TEMP" : (
SELECT JSON_DUALITY_OBJECT(
"C4" : `T3_TEMP`.`C1`,
"T4" : (
SELECT JSON_DUALITY_OBJECT(
"C1" : `T1_TEMP`.`C1`,
"C2" : `T1_TEMP`.`C2`
                                                            )
FROM `T1_TEMP`
                                                            WHERE `T1_TEMP`.`C1` = `T2_TEMP`.`C1`
                                                )
)
FROM `T3_TEMP`
                                    WHERE `T3_TEMP`.`C1` = `T1_TEMP`.`C1`
                                )
)
)
FROM `T2_TEMP`
                WHERE `T2_TEMP`.`C1` = `T1_TEMP`.`C1`
            )
) AS `Name_exp_1`
FROM `T1_TEMP`;
