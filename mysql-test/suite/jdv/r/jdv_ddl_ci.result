DROP TABLE T3;
CREATE TABLE T3_2 (C1 INT PRIMARY KEY);
CREATE JSON DUALITY VIEW T3 AS
SELECT JSON_DUALITY_OBJECT("_id" : C1)
FROM T3_2;
