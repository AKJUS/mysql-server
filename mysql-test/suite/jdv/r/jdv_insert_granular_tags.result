################################################################################
# Inserting into Root object and Sub object using table with self referencing FK.
# Root object - Primary Key  Table annotations: INSERT
# Sub-object - Foreign Key   Table annotations: INSERT
CREATE TABLE p_employee (empid INT PRIMARY KEY,
name VARCHAR(100),
mgrid INT REFERENCES p_employee(empid));
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
'_id' : empid,
'name' : name,
'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
'empid': empid,
'name' : name,
'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
'empid' : empid,
'name'  : name
) FROM p_employee MM  WHERE MM.empid = M.mgrid)
) FROM p_employee M  WHERE M.empid = emp.mgrid)
) FROM p_employee emp;
INSERT INTO p_dv1 VALUES ('
{
  "_id" : 10,
  "name"  : "FirstEmployee",
  "mgr"   : {
              "empid" : 2,
              "name"  : "Mgr",
              "mgr"   : {
                           "empid" : 1,
                           "name"  : "M1"
                        }
            }
} ' );
SELECT * FROM p_dv1;
