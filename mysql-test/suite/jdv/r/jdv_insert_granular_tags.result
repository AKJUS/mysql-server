################################################################################
# Handling cases with missing rows and join condition violation
# when standalone DELETE or UPDATE tags are provided.
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 INT);
CREATE TABLE t2 (c1 INT PRIMARY KEY, c2 INT);
INSERT INTO t1 VALUES (1,1), (2,2), (3,3);
INSERT INTO t2 VALUES (1,1);
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id' : t2.c1,
'c2' : t2.c2,
't1' : (
SELECT JSON_DUALITY_OBJECT(WITH UPDATE
'c1' : t1.c1,
'c2' : t1.c2
) FROM t1
WHERE t1.c1 = t2.c1
)
) FROM t2;
CREATE OR REPLACE JSON DUALITY VIEW dv2 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id' : t1.c1,
'c2' : t1.c2,
't2' : (
SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(
WITH DELETE
'c1' : t2.c1,
'c2' : t2.c2
)) FROM t2
WHERE t1.c1 = t2.c1
)
) FROM t1;
CREATE OR REPLACE JSON DUALITY VIEW dv3 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id' : t1.c1,
'c2' : t1.c2,
't2' : (
SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH UPDATE
'c1' : t2.c1,
'c2' : t2.c2
)) FROM t2
WHERE t1.c1 = t2.c1
)
) FROM t1;
## Only DELETE tag is specified for the sub-object
### Row for sub-object is `not` available in the table?
INSERT INTO dv2 VALUES ('{
        "_id" : 4,
        "c2"  : 4,
        "t2"  : [{
            "c1" : 4,
            "c2" :4
        }]
}');
ERROR HY000: Read-only subobject with path '$.t2[0]', maps to row where `test`.`t2`.c1 = (4), which does not exist.
### Row being inserted violates the JOIN condition?
INSERT INTO dv2 VALUES ('{
        "_id" : 1,
        "c2"  : 1,
        "t2"  : [{
            "c1" : 2,
            "c2" : 4
        }]
}');
ERROR HY000: Join condition is not satisfied as path '$.t2[0].c1' for child column `test`.`t2`.c1 is not equal to path '$._id' for parent column `test`.`t1`.c1.
## Only UPDATE tag is specified for the sub-object
### Row for sub-object is `not` available in the table?
INSERT INTO dv3 VALUES ('{
    "_id" : 4,
    "c2"  : 4,
    "t2"  : [{
        "c1" : 4,
        "c2" :4
        }]
}');
ERROR HY000: Read-only subobject with path '$.t2[0]', maps to row where `test`.`t2`.c1 = (4), which does not exist.
### Row being inserted violates the JOIN condition
INSERT INTO dv1 VALUES ('{
    "_id" : 1,
    "c2"  : 1,
    "t1"  : {
        "c1" : 2,
        "c2" : 4
    }
}');
ERROR HY000: Join condition is not satisfied as path '$.t1.c1' for child column `test`.`t1`.c1 is not equal to path '$._id' for parent column `test`.`t2`.c1.
DROP VIEW dv1, dv2, dv3;
DROP TABLE t1, t2;
################################################################################
# Update skipped: the subobject has a no-update restriction, so updates to its rows are ignored.
CREATE TABLE `t1` (
`id` int NOT NULL,
`Name` varchar(20) DEFAULT NULL,
`age` int DEFAULT NULL,
`child_id` int DEFAULT NULL,
PRIMARY KEY (`id`)
);
CREATE TABLE t2 LIKE t1;
INSERT INTO t1 VALUES (1, 'aa', 10, 1), (2, 'bb',12, 2), (3, 'cc', 15, 2);
INSERT INTO t2 SELECT * FROM t1;
CREATE JSON DUALITY VIEW dv AS
SELECT JSON_DUALITY_OBJECT(
WITH INSERT
"_id" : id,
"name" : name,
"age":age,
"child" : (
SELECT JSON_DUALITY_OBJECT(
WITH (INSERT, NO UPDATE)
"id": id,
"name" : name
) FROM t2 WHERE t2.id = t1.child_id
)
)
FROM t1;
SELECT * FROM t1;
id	Name	age	child_id
1	aa	10	1
2	bb	12	2
3	cc	15	2
SELECT * FROM t2;
id	Name	age	child_id
1	aa	10	1
2	bb	12	2
3	cc	15	2
INSERT INTO dv VALUES ('{"_id": 111, "age": 10, "name": "bbvbbv", "child": {"id": 3, "name": "hhh"}}');
SELECT * FROM t1;
id	Name	age	child_id
1	aa	10	1
2	bb	12	2
3	cc	15	2
111	bbvbbv	10	3
SELECT * FROM t2;
id	Name	age	child_id
1	aa	10	1
2	bb	12	2
3	cc	15	2
DROP VIEW dv;
DROP TABLE t1, t2;
################################################################################
