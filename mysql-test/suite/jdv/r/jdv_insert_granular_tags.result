################################################################################
CREATE TABLE p_department (deptid INT PRIMARY KEY,
name varchar(100),
mgrid INT);
CREATE TABLE p_employee (empid INT PRIMARY KEY,
name VARCHAR(100),
deptid INT REFERENCES p_department(deptid));
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
'_id' : empid,
'name' : name,
'dept' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
'deptid' : deptid,
'name'   : name,
'dept_mgr' : (SELECT JSON_DUALITY_OBJECT(WITH INSERT
'empid' : empid,
'name'  : name
) FROM p_employee DM
WHERE DM.empid = D.mgrid)
) FROM p_department D WHERE D.deptid = E.deptid)
) FROM p_employee E;
INSERT INTO p_dv1 VALUES (
' {
    "_id" : 10,
    "name" : "FirstEmployee",
    "dept" : { "deptid" : 888,
               "name"   : "IMPACT",
               "dept_mgr" : {
                              "empid" : 1,
                              "name"  : "M1"
                            }
              }
    }');
SELECT * FROM p_dv1;
data
{"_id": 1, "dept": null, "name": "M1", "_metadata": {"etag": "b9bdc63f2cbbca0aa44276bf63acf318"}}
{"_id": 10, "dept": {"name": "IMPACT", "deptid": 888, "dept_mgr": {"name": "M1", "empid": 1}}, "name": "FirstEmployee", "_metadata": {"etag": "2338fc6b6d7415894ca1c839fc558fc3"}}
SELECT * FROM p_department;
deptid	name	mgrid
888	IMPACT	1
SELECT * FROM p_employee;
empid	name	deptid
1	M1	NULL
10	FirstEmployee	888
DROP TABLE p_employee;
DROP TABLE p_department;
