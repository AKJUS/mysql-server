# Bug38936645 Allow 0/null in singleton parent join AUTO_INCREMENT
CREATE TABLE fk_parent_ai (pid INT PRIMARY KEY AUTO_INCREMENT, pdata INT);
CREATE TABLE fk_child_noai (cid INT PRIMARY KEY, pid INT REFERENCES fk_parent_ai(pid), cdata INT);
CREATE OR REPLACE JSON DUALITY VIEW dv_singleton_noai_ai AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
"_id" : cid,
"pid" : pid,
"cdata": cdata,
"parent": (SELECT JSON_DUALITY_OBJECT(WITH INSERT
"pid": pid,
"pdata": pdata
) FROM fk_parent_ai
WHERE fk_parent_ai.pid = fk_child_noai.pid
)
) FROM fk_child_noai;
CREATE VIEW cv AS SELECT p.pid, p.pdata, c.cid, c.cdata FROM fk_parent_ai p, fk_child_noai c
WHERE p.pid = c.pid;
INSERT INTO dv_singleton_noai_ai VALUES (
'{
  "_id" : 10,
  "cdata": 10,
  "parent": {
    "pdata": 20
  }
}');
# Expect pid=1 (generated from auto_increment (absent))
SELECT * FROM cv WHERE pid = 1;
pid	pdata	cid	cdata
1	20	10	10
INSERT INTO dv_singleton_noai_ai VALUES (
'{
  "_id" : 20,
  "cdata": 21,
  "parent": {
    "pid" : 0,
    "pdata": 22
  }
}');
# Expect pid=2 (generated from auto_increment (0))
SELECT * FROM cv WHERE pid = 2;
pid	pdata	cid	cdata
2	22	20	21
INSERT INTO dv_singleton_noai_ai VALUES (
'{
  "_id" : 30,
  "cdata": 31,
  "parent": {
    "pid" : null,
    "pdata": 32
  }
}');
# Expect pid=3 (generated from auto_increment (null))
SELECT * FROM cv WHERE pid = 3;
pid	pdata	cid	cdata
3	32	30	31
SELECT pid, pdata FROM fk_parent_ai ORDER BY pid;
pid	pdata
1	20
2	22
3	32
SELECT cid, pid, cdata FROM fk_child_noai ORDER BY cid;
cid	pid	cdata
10	1	10
20	2	21
30	3	31
DROP VIEW dv_singleton_noai_ai;
DROP TABLES fk_parent_ai, fk_child_noai;
DROP VIEW cv;
# Bug38958650 Mixing explicit and generated keys rejected
CREATE TABLE fk_parent_ai (pid INT PRIMARY KEY AUTO_INCREMENT, pdata INT);
CREATE TABLE fk_child_noai (cid INT PRIMARY KEY AUTO_INCREMENT, pid INT REFERENCES fk_parent_ai(pid), cdata INT);
CREATE OR REPLACE JSON DUALITY VIEW dv_singleton_ai_noai AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
"_id" : pid,
"pdata": pdata,
"child": (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH INSERT
"cid": cid,
"pid": pid,
"pdata": cdata
)) FROM fk_child_noai
WHERE fk_parent_ai.pid = fk_child_noai.pid
)
) FROM fk_parent_ai;
INSERT INTO dv_singleton_ai_noai VALUES ('{
  "pdata" : 1,
  "child" : [
    {
      "cid"   : null,
      "pdata" : 1
    },
    {
      "cid" : 2,
      "pdata" : 1
    }
  ]
}');
ERROR HY000: Paths $.child[0] and $.child[1] use generated and explicit values for the same primary key, which is not allowed.
# Covers below scenarios:
# 1. Omission of A_I column: "_id" in the parent, "pid" in 2nd and 3rd child
# 2. Auto generation of A_I column on "0" value: 2nd child
# 3. Auto generation of A_I column on "null" value: 3rd child
# 4. Providing correct value of dependent join column, whole A_I column is auto generated: 1st child
INSERT INTO dv_singleton_ai_noai VALUES ('{
  "pdata" : 1,
  "child" : [
    {
      "pid" : 1,
      "pdata" : 1
    },
    {
      "cid"   : 0,
      "pdata" : 1
    },
    {
      "cid" : null,
      "pdata" : 1
    }
  ]
}');
SELECT * FROM dv_singleton_ai_noai;
data
{"_id": 1, "child": [{"cid": 1, "pid": 1, "pdata": 1}, {"cid": 2, "pid": 1, "pdata": 1}, {"cid": 3, "pid": 1, "pdata": 1}], "pdata": 1, "_metadata": {"etag": "546f1bbd8c60497b5f1f99b7fbf9baca"}}
DROP VIEW dv_singleton_ai_noai;
DROP TABLES fk_parent_ai, fk_child_noai;
# Bug38936645 nested child inherits generated parent key
CREATE TABLE parent_nested_ai (pid INT PRIMARY KEY AUTO_INCREMENT, pdata INT);
CREATE TABLE child_nested_noai (cid INT PRIMARY KEY, pid INT REFERENCES parent_nested_ai(pid), cdata INT);
CREATE OR REPLACE JSON DUALITY VIEW dv_nested_parent_ai AS
SELECT JSON_DUALITY_OBJECT(WITH INSERT
"_id" : pid,
"pdata": pdata,
"child": (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH INSERT
"cid": cid,
"pid": pid,
"cdata": cdata
)) FROM child_nested_noai
WHERE child_nested_noai.pid = parent_nested_ai.pid
)
) FROM parent_nested_ai;
INSERT INTO dv_nested_parent_ai VALUES ('{
  "pdata" : 101,
  "child" : [
    {
      "cid" : 11,
      "cdata" : 1100
    }
  ]
}');
