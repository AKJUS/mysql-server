    {
      "cid" : 12,
      "pid" : 2,
      "cdata" : 1200
    }
  ]
}');
INSERT INTO dv_nested_parent_ai VALUES ('{
  "_id"   : null,
  "pdata" : 103,
  "child" : [
    {
      "cid" : 13,
