# -------------------------------------
# Part-1 NO_AUTO_VALUE_ON_ZERO = OFF
# -------------------------------------
# A singleton child with AUTO_INCREMENT primary key that is part of join condition
CREATE TABLE parent(ppk INT PRIMARY KEY, pc2 INT);
CREATE TABLE singleton(spkai INT PRIMARY KEY AUTO_INCREMENT, sc2 INT);
CREATE JSON DUALITY VIEW singleton_dv AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : ppk,
"k_pc2" : pc2,
"k_singleton" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"k_spkai" : spkai,
"k_sc2" : sc2
) FROM singleton WHERE
singleton.spkai = parent.ppk)
) FROM parent;
INSERT INTO singleton_dv VALUES ('{ "k_pc2": 42, "k_singleton": { "k_sc2": 43 }}');
INSERT INTO singleton_dv VALUES ('{ "k_pc2": 420, "k_singleton": { "k_sc2": 430 }}');
SELECT * FROM singleton_dv;
data
{"_id": 1, "k_pc2": 42, "_metadata": {"etag": "0f7233d64732c01f01c6a590ed0195f5"}, "k_singleton": {"k_sc2": 43, "k_spkai": 1}}
{"_id": 2, "k_pc2": 420, "_metadata": {"etag": "b36f7b6044a3b917d35307659a395faa"}, "k_singleton": {"k_sc2": 430, "k_spkai": 2}}
SELECT * FROM parent;
ppk	pc2
1	42
2	420
SELECT * FROM singleton;
spkai	sc2
1	43
2	430
DROP VIEW singleton_dv;
DROP TABLE parent;
DROP TABLE singleton;
# A singleton child where the parent has AUTO_INCREMENT
# primary key that is part of join condition. Generated
# value cannot be inferred for singleton child due to
# insertion order.
CREATE TABLE parent(ppkai INT PRIMARY KEY AUTO_INCREMENT, pc2 INT);
CREATE TABLE singleton(spk INT PRIMARY KEY, sc2 INT);
CREATE JSON DUALITY VIEW singleton_dv AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : ppkai,
"k_pc2" : pc2,
"k_singleton" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"k_spk" : spk,
"k_sc2" : sc2
) FROM singleton WHERE
singleton.spk = parent.ppkai)
) FROM parent;
INSERT INTO singleton_dv VALUES ('{ "k_pc2": 42, "k_singleton": { "k_sc2": 43 }}');
ERROR HY000: Primary key column `test`.`singleton`.spk must be provided as path '$.k_singleton.k_spk'.
# This works - the explicit value 55 is propagated to the parent and value for
# ppk is not generated automatically
INSERT INTO singleton_dv VALUES ('{ "k_pc2": 420, "k_singleton": { "k_spk": 55, "k_sc2": 430 }}');
SELECT * FROM singleton_dv;
data
{"_id": 55, "k_pc2": 420, "_metadata": {"etag": "c4d7d3b376989a9b5f5cc97b3575b14e"}, "k_singleton": {"k_sc2": 430, "k_spk": 55}}
SELECT * FROM parent;
ppkai	pc2
55	420
SELECT * FROM singleton;
spk	sc2
55	430
DROP VIEW singleton_dv;
DROP TABLE parent;
DROP TABLE singleton;
# Testing insert with generated PKs
CREATE TABLE parent(ppkai INT PRIMARY KEY AUTO_INCREMENT, pc2 INT);
CREATE TABLE nested(npkai INT PRIMARY KEY AUTO_INCREMENT, nc2 INT, nc3 INT);
INSERT INTO parent VALUES (1, 1);
INSERT INTO nested VALUES (1, 100, 1000);
CREATE JSON DUALITY VIEW nested_dv AS SELECT
JSON_DUALITY_OBJECT( WITH (INSERT, UPDATE, DELETE)
'_id' : ppkai,
'k_pc2'  : pc2,
'k_nested' : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'k_npkai' : npkai,
'k_nc2' : nc2,
'k_nc3' : nc3
)) FROM nested WHERE nested.nc2 = parent.ppkai
)
) FROM parent;
SELECT * FROM nested_dv;
data
{"_id": 1, "k_pc2": 1, "k_nested": null, "_metadata": {"etag": "a5d11d2a54fa9c6202c0733c943f8317"}}
# All generated
INSERT INTO nested_dv VALUES ('{ "k_pc2": 1000, "k_nested": [{"k_nc3": 2000},{"k_nc3": 3000},{"k_nc3":4000}]}');
# Combination of generated and explicit primary key is not allowed
INSERT INTO nested_dv VALUES ('{ "k_pc2": 1001, "k_nested": [{"k_nc3":5000},{"k_npkai": 42, "k_nc3":6000},{"k_nc3":7000}]}');
ERROR HY000: Paths $.k_nested[1] and $.k_nested[0] use generated and explicit values for the same primary key, which is not allowed.
INSERT INTO nested_dv VALUES ('{
   "k_pc2": 666, "k_nested": [
    { "k_npkai": 0, "k_nc3":5000},
    {"k_npkai": 42, "k_nc3":6000},
    {"k_npkai": -103, "k_nc3":-2000},
    {"k_nc3":7000}]}');
ERROR HY000: Paths $.k_nested[2] and $.k_nested[0] use generated and explicit values for the same primary key, which is not allowed.
# Explicit keys with acceptable duplicate
INSERT INTO nested_dv VALUES ('{ "k_pc2": 1002, "k_nested": [{"k_npkai": 43, "k_nc3":5000},{"k_npkai": 44, "k_nc3":6000},{"k_npkai":44, "k_nc3":6000}]}');
# Explicit keys with pk duplicate where k_nc3 does not have identical values
INSERT INTO nested_dv VALUES ('{ "k_pc2": 1003, "k_nested": [{"k_npkai": 46, "k_nc3":5000},{"k_npkai": 46, "k_nc3":5000},{"k_npkai":46, "k_nc3":7000}]}');
ERROR HY000: Path '$.k_nested[2]' is a duplicate for primary key column `test`.`nested`.npkai but has conflicting values for column nc3: path '$.k_nested[2].k_nc3' vs path '$.k_nested[0].k_nc3'
SELECT * FROM nested_dv;
data
{"_id": 1, "k_pc2": 1, "k_nested": null, "_metadata": {"etag": "a5d11d2a54fa9c6202c0733c943f8317"}}
{"_id": 2, "k_pc2": 1000, "k_nested": [{"k_nc2": 2, "k_nc3": 2000, "k_npkai": 2}, {"k_nc2": 2, "k_nc3": 3000, "k_npkai": 3}, {"k_nc2": 2, "k_nc3": 4000, "k_npkai": 4}], "_metadata": {"etag": "9147660215bcaa8deb965b6476e3f394"}}
{"_id": 3, "k_pc2": 1002, "k_nested": [{"k_nc2": 3, "k_nc3": 5000, "k_npkai": 43}, {"k_nc2": 3, "k_nc3": 6000, "k_npkai": 44}], "_metadata": {"etag": "962c0e873f0065ff5e6ecd8053022142"}}
# Same applies for UPDATE.
UPDATE nested_dv SET data = '{ "_id": 3,  "k_pc2": 1003, "k_nested": [
