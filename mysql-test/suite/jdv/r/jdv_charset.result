CREATE TABLE p_student(
suid INT PRIMARY KEY,
sname VARCHAR(100) CHARSET latin1,
sname_u8 VARCHAR(100) CHARSET utf8mb4);
SHOW CREATE TABLE p_student;
Table	Create Table
p_student	CREATE TABLE `p_student` (
  `suid` int NOT NULL,
  `sname` varchar(100) CHARACTER SET latin1 COLLATE latin1_swedish_ci DEFAULT NULL,
  `sname_u8` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  PRIMARY KEY (`suid`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
INSERT INTO p_student VALUES (101, 0xE5, 'å');
SELECT suid, sname, HEX(sname), HEX(sname_u8) FROM p_student;
suid	sname	HEX(sname)	HEX(sname_u8)
101	å	E5	C3A5
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS SELECT
JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id' : suid,
'name' : sname,
'name_u8': sname_u8
) FROM p_student;
SELECT * FROM p_dv1;
data
