# INFORMATION_SCHEMA.JSON_DUALITY_VIEWS with granular tags
# 1. The ALLOW_INSERT, ALLOW_UPDATE and ALLOW_DELETE fields in the
# JSON_DUALITY_VIEWS view should be set to 1 if any projected
# table in the view hierarchy (root or child) is explicitly
# tagged to allow INSERT, UPDATE and DELETE, respectively.
# 2. The READ_ONLY field must be set to 1 if none of the
# INSERT, UPDATE, or DELETE operations are permitted
# in any of the projected table.
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY REFERENCES p_t1(f1), f4 INT);
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (NO INSERT, NO UPDATE, NO DELETE)
"_id" : f3,
"f4" : f4,
"ChildNode" : (SELECT JSON_DUALITY_OBJECT(
WITH (NO INSERT, NO UPDATE, NO DELETE)
"f1" : f1,
"f2" : f2
) FROM p_t1 WHERE p_t1.f1 = p_t2.f3)
) FROM p_t2;
SELECT * FROM INFORMATION_SCHEMA.JSON_DUALITY_VIEWS;
