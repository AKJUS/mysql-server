#
# Test visibility of duality views, tables and columns that are
# not accessible by the current user. We also define an ordinary
# SQL view for comparison to verify the behavior is the same for
# both view types.
#
CREATE SCHEMA jdv;
CREATE TABLE jdv.t1(c1 int primary key);
CREATE TABLE jdv.t2(c2 int primary key);
CREATE VIEW jdv.v1 AS SELECT * FROM jdv.t1, jdv.t2 WHERE jdv.t1.c1 = jdv.t2.c2;
CREATE JSON RELATIONAL DUALITY VIEW jdv.dv1 AS
SELECT JSON_DUALITY_OBJECT(
'_id': jdv.t1.c1,
't2s': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
'pk': jdv.t2.c2)
) FROM jdv.t2 WHERE jdv.t2.c2 = jdv.t1.c1
)
) FROM jdv.t1;
# Create user having no access.
CREATE USER 'jdvuser'@'localhost';
# When nothing is accessible, nothing is listed from I_S.views, view_table_usage, json_*.
# Grant access to the views only, not to the underlying tables. The views are listed in
# I_S.views with the view definition. The view is listed in JSON_DUALITY_VIEWS with hidden
# root table name. Nothing is listed in  the other jdv I_S views.
GRANT ALL ON jdv.v1 TO 'jdvuser'@'localhost';
GRANT ALL ON jdv.dv1 TO 'jdvuser'@'localhost';
# Grant access to table t1. Only t1 will be listed in the view_table_usage
# and jdv I_S views. Nothing listed in the links view since t2 is inaccessible.
GRANT ALL ON jdv.t1 TO 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Grant access also to table t2. Both accessible tables will be listed in
# the view_table_usage and jdv I_S views.
GRANT ALL ON jdv.t2 TO 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Revoke access to t1. Only t2 will be listed in the view_table_usage and jdv I_S views.
# Note that dv1 is listed in I_S.JSON_DUALITY_VIEW with the root table hidden because the
# root table t1 is not accessible.
REVOKE ALL ON jdv.t1 FROM 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Revoke all access to table t2 too. Grant DROP access to t1 and t2 (no select access).
# Revoke view access and grant DROP access to the views as well. Both views are listed
# in I_S.VIEWS, and the duality view is listed in I_S.JSON_DUALITY_VIEWS with the root
# table name hidden.
REVOKE ALL ON jdv.t2 FROM 'jdvuser'@'localhost';
REVOKE ALL ON jdv.v1 FROM 'jdvuser'@'localhost';
REVOKE ALL ON jdv.dv1 FROM 'jdvuser'@'localhost';
GRANT DROP ON jdv.t1 TO 'jdvuser'@'localhost';
GRANT DROP ON jdv.t2 TO 'jdvuser'@'localhost';
GRANT DROP ON jdv.v1 TO 'jdvuser'@'localhost';
GRANT DROP ON jdv.dv1 TO 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Grant full view access and keep the tables having DROP access.
# This means we have table access, but not column access. Hence, both t1 and t2 are listed,
# but the jdv I_S views for columns and links are empty because the columns are inaccessible.
REVOKE DROP ON jdv.v1 FROM 'jdvuser'@'localhost';
REVOKE DROP ON jdv.dv1 FROM 'jdvuser'@'localhost';
GRANT ALL ON jdv.v1 TO 'jdvuser'@'localhost';
GRANT ALL ON jdv.dv1 TO 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Grant select access to column c1.t1. Now, the output is the same as in the
# previous test case, except we will have c1.t1 listed in the jdv columns view.
GRANT SELECT(c1) ON jdv.t1 TO 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Revoke select access to column c1.t1. Grant select access to column c2.t2.
# The output is the same as in the previous test case, except we will have
# c2.t2 listed in the jdv columns view instead of c1.t1.
REVOKE SELECT(c1) ON jdv.t1 FROM 'jdvuser'@'localhost';
GRANT SELECT(c2) ON jdv.t2 TO 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Finally, we grant select access to column c1.t1, making both source tables and
# columns accessible. The output is the same as in the previous test case, except
# we will now have both c1.t1 and c2.t2 listed in the jdv columns view, and we will
# have one entry listed in the links view.
GRANT SELECT(c1) ON jdv.t1 TO 'jdvuser'@'localhost';
FLUSH PRIVILEGES;
Warnings:
Warning	1681	'FLUSH PRIVILEGES' is deprecated and will be removed in a future release.
# Cleanup
DROP VIEW jdv.dv1;
DROP VIEW jdv.v1;
DROP TABLE jdv.t2, jdv.t1;
DROP SCHEMA jdv;
DROP USER 'jdvuser'@'localhost';
#
# Bug#38624596: Table ids reported in I_S do not match those reported
# by ORACLE DB
#
CREATE TABLE parent (i INT PRIMARY KEY);
CREATE TABLE t1 (i INT PRIMARY KEY);
CREATE TABLE t2 (i INT PRIMARY KEY);
CREATE TABLE t3 (i INT PRIMARY KEY);
CREATE JSON DUALITY VIEW dv2 AS SELECT JSON_DUALITY_OBJECT(
'_id' : parent.i,
'k_t1' : (SELECT JSON_DUALITY_OBJECT(
'k_t1i' : t1.i,
'k_t3' : (SELECT JSON_DUALITY_OBJECT( 'k_t3i' : t3.i)
FROM t3 WHERE t3.i = t1.i)
) FROM t1 WHERE t1.i = parent.i),
'k_t2' : (SELECT JSON_DUALITY_OBJECT(
'k_t2i' : t2.i,
'k_t3' : (SELECT JSON_DUALITY_OBJECT( 'k_t3i' : t3.i)
FROM t3 WHERE t3.i = t2.i)
) FROM t2 WHERE t2.i = parent.i)
) FROM parent;
# ORACLE DB assigns the following ids in this case:
# parent:0, t1:1, t3:2, t2:3, t3:4
SELECT TABLE_NAME, REFERENCED_TABLE_NAME, REFERENCED_TABLE_ID,
REFERENCED_TABLE_PARENT_ID, REFERENCED_TABLE_PARENT_RELATIONSHIP  FROM
INFORMATION_SCHEMA.JSON_DUALITY_VIEW_TABLES WHERE TABLE_NAME = 'dv2'
ORDER BY REFERENCED_TABLE_ID;
TABLE_NAME	REFERENCED_TABLE_NAME	REFERENCED_TABLE_ID	REFERENCED_TABLE_PARENT_ID	REFERENCED_TABLE_PARENT_RELATIONSHIP
dv2	parent	0	NULL	NULL
dv2	t1	1	0	singleton
dv2	t3	2	1	singleton
dv2	t2	3	0	singleton
dv2	t3	4	3	singleton
DROP VIEW dv2;
DROP TABLE t1;
DROP TABLE t2;
DROP TABLE t3;
