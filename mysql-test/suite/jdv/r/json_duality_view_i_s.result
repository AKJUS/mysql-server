#
# Parent and child with no relationship.
#
CREATE TABLE t1(pk INT,
CONSTRAINT t1_pk PRIMARY KEY (pk));
CREATE TABLE t2(pk INT, i INT,
CONSTRAINT t2_pk PRIMARY KEY (pk));
INSERT INTO t1 VALUES (1), (2), (3);
INSERT INTO t2 VALUES (1, 2), (3, 4), (5, 6);
CREATE JSON RELATIONAL DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id': t1.pk)
FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv2 AS
# TODO: Support for column level tags was removed.
# SELECT JSON_DUALITY_OBJECT('_id': t1.pk WITH UPDATE)
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id': t1.pk)
FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv3 AS
SELECT JSON_DUALITY_OBJECT(
'_id': t1.pk,
't2s': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'pk': t2.pk,
'i': t2.i)
) FROM t2 WHERE t2.pk = t1.pk
)
) FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv4 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id': t1.pk,
't2s': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'pk': t2.pk,
# Column level tags not supported
#         'i': t2.i WITH UPDATE)
'i': t2.i)
) FROM t2 WHERE t2.pk = t1.pk
)
) FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv5 AS
SELECT JSON_DUALITY_OBJECT(
'_id': t1.pk,
't2s': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'pk': t2.pk,
# Column level tags not supported
#         'i': t2.i WITH UPDATE)
'i': t2.i)
) FROM t2 WHERE t2.pk = t1.pk
)
) FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv6 AS
SELECT JSON_DUALITY_OBJECT(
'_id': t1.pk,
't2s': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
'pk': t2.pk,
'i': t2.i)
) FROM t2 WHERE t2.pk = t1.pk
)
) FROM t1;
