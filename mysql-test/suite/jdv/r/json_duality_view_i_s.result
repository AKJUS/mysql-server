#
# Child having non-PK which is FK to parent.
#
CREATE TABLE t1(pk INT,
CONSTRAINT t1_pk PRIMARY KEY (pk));
CREATE TABLE t2(pk INT, fk int,
CONSTRAINT t2_pk PRIMARY KEY (pk),
CONSTRAINT t2_fk FOREIGN KEY (fk) REFERENCES t1 (pk));
INSERT INTO t1 VALUES (1), (2), (3);
INSERT INTO t2 VALUES (1, 2), (2, 2), (3, 3);
CREATE JSON RELATIONAL DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE) '_id': t1.pk)
FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv2 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id': t1.pk,
't2s': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT('pk': t2.pk)
) FROM t2 WHERE t2.fk = t1.pk
)
)
FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv3 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id': t2.pk,
't1s': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT('pk': t1.pk)
) FROM t1 WHERE t2.pk = t1.pk
)
)
FROM t2;
CREATE JSON RELATIONAL DUALITY VIEW dv4 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id': t2.pk,
't1s': (
SELECT JSON_DUALITY_OBJECT('pk': t1.pk)
FROM t1 WHERE t2.fk = t1.pk
)
)
FROM t2;
