#
# Basic JSON duality views.
#
CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f1 INT PRIMARY KEY, f2 INT, FOREIGN KEY(f1) REFERENCES t1(f1));
CREATE JSON DUALITY VIEW dv1 AS SELECT JSON_DUALITY_OBJECT("_id": t1.f1) FROM t1;
CREATE JSON RELATIONAL DUALITY VIEW dv2 AS SELECT JSON_DUALITY_OBJECT("_id": t1.f1) FROM t1;
CREATE JSON DUALITY VIEW dv3 AS SELECT JSON_DUALITY_OBJECT("_id": t1.f1) FROM t1;
CREATE OR REPLACE JSON DUALITY VIEW dv3 AS SELECT JSON_DUALITY_OBJECT("_id": t2.f1) FROM t2;
SELECT * FROM INFORMATION_SCHEMA.JSON_DUALITY_VIEWS;
