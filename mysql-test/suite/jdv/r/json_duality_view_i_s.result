DROP VIEW dv1, dv2, dv3;
DROP TABLE t1, t2;
#
# Child's PK is also FK to parent.
#
CREATE TABLE t1 (pk INT PRIMARY KEY, c2 INT);
CREATE TABLE t2 (pk INT PRIMARY KEY, c2 INT, FOREIGN KEY (pk) REFERENCES t1(pk));
CREATE TABLE t3 (pk INT PRIMARY KEY, c2 INT, FOREIGN KEY (pk) REFERENCES t2(pk));
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
"_id": t1.pk,
"c2": t1.c2
) FROM t1;
CREATE JSON DUALITY VIEW dv2 AS
SELECT JSON_DUALITY_OBJECT(
"_id": t1.pk,
"c2": t1.c2,
"t2s": (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"pk": t2.pk,
"c2": t2.c2
)
) FROM t2 WHERE t1.pk = t2.pk
)
) FROM t1;
CREATE JSON DUALITY VIEW dv3 AS
SELECT JSON_DUALITY_OBJECT(
"_id": t2.pk,
"c2": t2.c2,
"t1s": (
SELECT JSON_DUALITY_OBJECT(
"pk": t1.pk,
"c2": t1.c2
)
FROM t1 WHERE t2.pk = t1.pk
)
) FROM t2;
CREATE JSON DUALITY VIEW dv4 AS
SELECT JSON_DUALITY_OBJECT(
"_id": t1.pk,
"c2": t1.c2,
"t2s": (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"pk": t2.pk,
"c2": t2.c2,
"t3s": (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"pk": t3.pk,
"c2": t3.c2
)
) FROM t3 WHERE t2.pk = t3.pk
)
)
) FROM t2 WHERE t1.pk = t2.pk
)
) FROM t1;
