# Check invalid json syntax
INSERT INTO dv0 VALUES ('{ "": ]');
ERROR 22032: Invalid JSON text in argument 1 to function get_json_wrapper: "Invalid value." at position 6.
# Check valid non-object json
INSERT INTO dv0 VALUES ('null');
ERROR HY000: Path '$' is not of type 'Json_object'.
INSERT INTO dv0 VALUES ('3');
ERROR HY000: Path '$' is not of type 'Json_object'.
INSERT INTO dv0 VALUES ('[ "foo", 3, 3.14 ]');
ERROR HY000: Path '$' is not of type 'Json_object'.
# Update of Root object
# Check invalid json syntax
UPDATE dv0 SET data = '{ "": ]';
ERROR 22032: Invalid JSON text in argument 1 to function get_json_wrapper: "Invalid value." at position 6.
# Check valid non-object json
UPDATE dv0 SET data = 'null';
ERROR HY000: Path '$' is not of type 'Json_object'.
UPDATE dv0 SET data = '3';
ERROR HY000: Path '$' is not of type 'Json_object'.
UPDATE dv0 SET data = '[ "foo", 3, 3.14 ]';
ERROR HY000: Path '$' is not of type 'Json_object'.
INSERT INTO dv0 VALUES ('{"kt1c2": 6}');
