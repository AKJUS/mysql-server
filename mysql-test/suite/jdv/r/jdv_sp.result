CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);
CREATE TABLE t3 (f1 INT);
CREATE TABLE t4 (f1 JSON);
#
# Test case to verify duality view DDL statements with stored programs.
#
CREATE PROCEDURE p1()
BEGIN
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : f1,
"f2"  : f2) FROM t1;
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : f11,
"f12" : f12,
"child" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"f1" : f1,
"f2" : f2
) FROM t1 WHERE t1.f1 = t2.f11))
FROM t2;
DROP VIEW dv1;
END;
$
CALL p1();
CALL p1();
#
# Test case to verify re-prepare of duality view DDL statements in stored procedure.
#
DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1 (f1 INT, f2 INT);
CREATE TABLE t2 (f11 INT, f12 INT);
CALL p1();
ERROR HY000: Invalid JSON duality view definition: All participating tables should have a primary key, "test.t1" does not have it.
CALL p1();
ERROR HY000: Invalid JSON duality view definition: All participating tables should have a primary key, "test.t1" does not have it.
DROP TABLE t1;
DROP TABLE t2;
CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE t2 (f11 INT PRIMARY KEY, f12 INT);
CALL p1();
CALL p1();
DROP PROCEDURE p1;
#
# Test case to verify duality view DML statements with stored procedure,
# stored function and triggers.
#
CREATE OR REPLACE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : f11,
"f12" : f12,
"child" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"f1" : f1,
"f2" : f2
) FROM t1 WHERE t1.f1 = t2.f11))
FROM t2;
CREATE PROCEDURE p1()
BEGIN
INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
SELECT * FROM dv1;
UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
SELECT * FROM dv1;
DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
END;
$
CREATE FUNCTION f1() RETURNS INT
BEGIN
INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
RETURN 1;
END;
$
CREATE TRIGGER t3_trigger BEFORE INSERT ON t3
FOR EACH ROW
BEGIN
INSERT INTO dv1 VALUES (' { "_id" : 1, "f12" : 1, "child" : {"f1" : 1, "f2" : 1}} ');
UPDATE dv1 SET data = ' { "_id" : 1, "f12" : 2, "child" : { "f1" : 1, "f2" : 2} } ';
INSERT INTO t4 SELECT * FROM dv1;
DELETE FROM dv1 WHERE JSON_VALUE(data, '$._id') = 1;
END;
$
