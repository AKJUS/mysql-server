student_id INT NOT NULL,
name VARCHAR(100) NOT NULL,
email VARCHAR(100) DEFAULT NULL,
age int DEFAULT NULL,
created_at TIMESTAMP NULL DEFAULT CURRENT_TIMESTAMP,
PRIMARY KEY (student_id),
UNIQUE KEY email (email),
CONSTRAINT students_chk_1 CHECK ((age >= 5)));
CREATE TABLE marks (
mark_id INT NOT NULL,
student_id INT DEFAULT NULL,
subject VARCHAR(50) NOT NULL,
score INT DEFAULT NULL,
PRIMARY KEY (mark_id),
KEY student_id (student_id),
CONSTRAINT marks_ibfk_1 FOREIGN KEY (student_id) REFERENCES students (student_id) ON DELETE CASCADE ON UPDATE CASCADE,
CONSTRAINT marks_chk_1 CHECK ((score between 0 and 100)));
INSERT INTO students (student_id, name, email, age)
VALUES
(1, 'Alice', 'alice@example.com', 14),
(2, 'Bob', 'bob@example.com', 15);
