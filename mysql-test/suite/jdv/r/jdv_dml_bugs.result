VALUES
(1, 1, 'Math', 90),
(2, 1, 'Science', 85),
(3, 2, 'Math', 88);
CREATE JSON DUALITY VIEW student_dv AS
SELECT JSON_DUALITY_OBJECT(
'_id'        : student_id,
'name'       : name,
'email'      : email,
'age'        : age,
'created_at' : created_at,
'marks'      : (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
'subject' : subject,
'score'   : score,
'markId'  : mark_id
)
)
FROM marks m
WHERE m.student_id = s.student_id
)
)
FROM students s;
INSERT INTO student_dv VALUES
('{"_id": 2, "age": 15, "name": "Bob", "email": "bob@example.com",
"marks": [{"score": 88, "markId": 3, "subject": "Math"}]}');
