CREATE JSON DUALITY VIEW v3 AS SELECT
JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
"_id": c1,
"c2": c2,
"t2": (SELECT
JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE)
"c1": c1,
"c2": c2)
FROM t2 WHERE (t2.c1 = t1.c2)))
FROM t1;
