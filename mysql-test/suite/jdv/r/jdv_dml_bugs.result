INSERT INTO t2 VALUES (1,1),(2,2),(3,2),(4,2),(10,12);
# Read-only root with modifiable subobject
CREATE JSON DUALITY VIEW v1 AS SELECT
JSON_DUALITY_OBJECT(
"_id": c1,
"c2": c2,
"t2": (SELECT
JSON_DUALITY_OBJECT(
WITH (INSERT,UPDATE)
"c1": c1,
"c2": c2)
FROM t2 WHERE (t2.c1 = t1.c2)))
FROM t1;
# Missing UPDATE_TAG on PK of subobject
UPDATE v1 SET data = '{"c2": 11, "t2": {"c1": 11, "c2": 12}, "_id": 10, "_metadata": {"etag": "e4b53c42d61233f2c5a53b657f1b91a0"}}' WHERE JSON_EXTRACT(data, '$._id') = 10;
ERROR HY000: Missing UPDATE tag on `test`.`t2`.c1, path '$.t2.c1'.
# Insert pk c1=11 into t2
INSERT INTO t2 VALUES (11,11);
# Still missing UPDATE tag on root node
UPDATE v1 SET data = '{"c2": 11, "t2": {"c1": 11, "c2": 12}, "_id": 10, "_metadata": {"etag": "e4b53c42d61233f2c5a53b657f1b91a0"}}' WHERE JSON_EXTRACT(data, '$._id') = 10;
ERROR HY000: Missing UPDATE tag on `test`.`t1`.c2, path '$.c2'.
DROP VIEW v1;
DELETE FROM t2 WHERE c1 = 11;
# Create view where root is modifiable but subobject is readonly
CREATE JSON DUALITY VIEW v2 AS SELECT
JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
"_id": c1,
"c2": c2,
"t2": (SELECT
JSON_DUALITY_OBJECT(
"c1": c1,
"c2": c2)
FROM t2 WHERE (t2.c1 = t1.c2)))
FROM t1;
# Fails due to missing UPDATE TAG on sub-object
UPDATE v2 SET data = '{"c2": 11, "t2": {"c1": 11, "c2": 12}, "_id": 10, "_metadata": {"etag": "e4b53c42d61233f2c5a53b657f1b91a0"}}' WHERE JSON_EXTRACT(data, '$._id') = 10;
