#
# Bug#37825753: If multiple sub-objects are projected from a
# single table, values must be same for given column in all
# sub-objects.
#
CREATE TABLE t1(c1 INT PRIMARY KEY, c2 INT, c3 INT);
INSERT INTO t1 VALUES (1,1,1),(2,2,2),(3,3,3);
CREATE TABLE t2(c1 INT PRIMARY KEY, c2 INT, c3 INT);
INSERT INTO t2 VALUES (1,1,10),(2,2,2),(3,3,3);
CREATE JSON DUALITY VIEW v1 AS SELECT
JSON_DUALITY_OBJECT(
WITH(INSERT, UPDATE, DELETE)
"_id" : c1,
"child1" : (
SELECT JSON_DUALITY_OBJECT(
with(insert, update)
"c1" : c1,
"c2" : c2,
"c3" : c3) FROM t2 WHERE t2.c1 = t1.c2),
"child2" : (
SELECT JSON_DUALITY_OBJECT(
WITH(INSERT, UPDATE)
"c1" : c1,
"c2" : c2,
"c3" : c3) FROM t2 WHERE t2.c1 = t1.c3)
) FROM t1;
SELECT data FROM v1;
