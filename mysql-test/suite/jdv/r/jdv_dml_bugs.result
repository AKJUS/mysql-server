SELECT * FROM t1;
t1c1	t1c2
1	100
2	1
3	1
4	4
SELECT * FROM t2;
t2c1	t2c2	t2c3
1	4	3000
# This is now allowed regardless of the value for kt1c2 which is not
# part of the join condition
INSERT INTO dv1 VALUES ('{"_id": 5, "kt1c2": 3456,
"Multi Child": [{"kt2c1": 1, "kt2c2": 5 }] }');
SELECT * FROM dv1;
data
{"_id": 1, "kt1c2": 100, "_metadata": {"etag": "bdf7412bb4f5da56d3b9c63ed28d8f87"}, "Multi Child": null}
{"_id": 2, "kt1c2": 1, "_metadata": {"etag": "45d4eb582691e784f7a2aec4e785ad14"}, "Multi Child": null}
