# Coverage for ER_JDV_JOIN_CONDITION_VIOLATION
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY, t2c2 INT, t2c3 INT);
INSERT INTO t1 VALUES (2, 1);
INSERT INTO t1 VALUES (3, 1);
INSERT INTO t2 VALUES (1, 1, NULL);
# Multi-child is read-only
CREATE JSON DUALITY VIEW dv0 AS
SELECT JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
"_id" : t1c1,
"kt1c2" : t1c2,
"Multi Child" :
(SELECT
JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
"kt2c1" : t2c1,
"kt2c2" : t2c2,
"kt2c3" : t2c3
)) FROM t2 WHERE t2.t2c2 = t1.t1c1
)) FROM t1;
SELECT * FROM dv0;
data
{"_id": 2, "kt1c2": 1, "_metadata": {"etag": "45d4eb582691e784f7a2aec4e785ad14"}, "Multi Child": null}
{"_id": 3, "kt1c2": 1, "_metadata": {"etag": "736f03540d9064f78ecd40d557f140fd"}, "Multi Child": null}
INSERT INTO dv0 VALUES ('{"_id": 1, "kt1c2": 64,
"Multi Child": [{"kt2c1": 42, "kt2c2": 1 }] }');
ERROR HY000: Read-only subobject with path '$."Multi Child"[0]', maps to row where `test`.`t2`.t2c1 = (42), which does not exist.
# References existing object and no modification of
# subobject is required
INSERT INTO dv0 VALUES ('{"_id": 1, "kt1c2": 100,
"Multi Child": [{"kt2c1": 1, "kt2c2": 1 }] }');
SELECT * FROM dv0;
data
{"_id": 1, "kt1c2": 100, "_metadata": {"etag": "43055ea46f6884fb7ecad06aeebf04d3"}, "Multi Child": [{"kt2c1": 1, "kt2c2": 1, "kt2c3": null}]}
{"_id": 2, "kt1c2": 1, "_metadata": {"etag": "45d4eb582691e784f7a2aec4e785ad14"}, "Multi Child": null}
{"_id": 3, "kt1c2": 1, "_metadata": {"etag": "736f03540d9064f78ecd40d557f140fd"}, "Multi Child": null}
SELECT * FROM t1;
t1c1	t1c2
1	100
2	1
3	1
SELECT * FROM t2;
t2c1	t2c2	t2c3
1	1	NULL
DELETE FROM t1 WHERE t1c1 = 1;
UPDATE t2 SET t2c3 = 3000 WHERE t2c1 = 1;
# References existing read-only object where join condition is satisfied,
# but modifies non-join-condition column. This is allowed, but update is
# ignored.
INSERT INTO dv0 VALUES ('{"_id": 1, "kt1c2": 100,
"Multi Child": [{"kt2c1": 1, "kt2c2": 1, "kt2c3": 5000 }] }');
SELECT * FROM dv0;
data
{"_id": 1, "kt1c2": 100, "_metadata": {"etag": "c72fe3a4a5cf79333ea02eb7e6da2865"}, "Multi Child": [{"kt2c1": 1, "kt2c2": 1, "kt2c3": 3000}]}
{"_id": 2, "kt1c2": 1, "_metadata": {"etag": "45d4eb582691e784f7a2aec4e785ad14"}, "Multi Child": null}
{"_id": 3, "kt1c2": 1, "_metadata": {"etag": "736f03540d9064f78ecd40d557f140fd"}, "Multi Child": null}
SELECT * FROM t1;
t1c1	t1c2
1	100
2	1
3	1
SELECT * FROM t2;
t2c1	t2c2	t2c3
1	1	3000
# Expect to fail since the update needed to preserve
# the join condition is not allowed. Given that the test case above
# succeeds, does not make sense to have a specific error for this
# which is different from missing UPDATE_TAG?
INSERT INTO dv0 VALUES ('{"_id": 6, "kt1c2": 6,
"Multi Child": [{"kt2c1": 1, "kt2c2": 6 }] }');
ERROR HY000: Path '$."Multi Child"[0]' references a READ-ONLY subobject for which column `test`.`t2`.t2c2 violates the join condition of the attempted INSERT.
SELECT * FROM dv0;
data
{"_id": 1, "kt1c2": 100, "_metadata": {"etag": "c72fe3a4a5cf79333ea02eb7e6da2865"}, "Multi Child": [{"kt2c1": 1, "kt2c2": 1, "kt2c3": 3000}]}
{"_id": 2, "kt1c2": 1, "_metadata": {"etag": "45d4eb582691e784f7a2aec4e785ad14"}, "Multi Child": null}
{"_id": 3, "kt1c2": 1, "_metadata": {"etag": "736f03540d9064f78ecd40d557f140fd"}, "Multi Child": null}
SELECT * FROM t1;
t1c1	t1c2
1	100
2	1
3	1
SELECT * FROM t2;
t2c1	t2c2	t2c3
1	1	3000
DROP VIEW dv0;
DELETE FROM t1 WHERE t1c1 = 1;
# On the other hand, if "Multi child" is updatable a modification
# Of the join condition is OK
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
"_id" : t1c1,
"kt1c2" : t1c2,
"Multi Child" :
(SELECT
JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
"kt2c1" : t2c1,
"kt2c2" : t2c2
)) FROM t2 WHERE t2.t2c2 = t1.t1c1
)) FROM t1;
SELECT data FROM dv1;
data
{"_id": 2, "kt1c2": 1, "_metadata": {"etag": "45d4eb582691e784f7a2aec4e785ad14"}, "Multi Child": null}
{"_id": 3, "kt1c2": 1, "_metadata": {"etag": "736f03540d9064f78ecd40d557f140fd"}, "Multi Child": null}
# References existing object and no modification of
# the join condition is required
INSERT INTO dv1 VALUES ('{"_id": 1, "kt1c2": 100,
"Multi Child": [{"kt2c1": 1, "kt2c2": 1 }] }');
SELECT * FROM dv1;
data
{"_id": 1, "kt1c2": 100, "_metadata": {"etag": "110f3429abf06ac24e1d88abccafaacc"}, "Multi Child": [{"kt2c1": 1, "kt2c2": 1}]}
{"_id": 2, "kt1c2": 1, "_metadata": {"etag": "45d4eb582691e784f7a2aec4e785ad14"}, "Multi Child": null}
{"_id": 3, "kt1c2": 1, "_metadata": {"etag": "736f03540d9064f78ecd40d557f140fd"}, "Multi Child": null}
SELECT * FROM t1;
t1c1	t1c2
1	100
2	1
3	1
SELECT * FROM t2;
t2c1	t2c2	t2c3
1	1	3000
# Insert another record into t1 which ALSO references
# the one record in t2. This forces an update t2c2 from 1 -> 4
# breaking the exising association.
INSERT INTO dv1 VALUES ('{"_id": 4, "kt1c2": 4,
"Multi Child": [{"kt2c1": 1, "kt2c2": 4 }] }');
SELECT data FROM dv1;
