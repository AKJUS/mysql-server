#
# Verify that etag can only be supplied for root object, and that
# error is reported if used on subobjects.
#
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);
INSERT INTO p_t1 VALUES (2, 1);
INSERT INTO p_t1 VALUES (3, 1);
INSERT INTO p_t2 VALUES (1, 1);
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : f3,
"f4" : f4,
"ChildNode" : (SELECT JSON_ARRAYAGG(JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"f1" : f1,
"f2" : f2
)) FROM p_t1  WHERE p_t1.f2 = p_t2.f3)
) FROM p_t2 ;
SELECT * FROM p_dv1;
data
{"f4": 1, "_id": 1, "ChildNode": [{"f1": 2, "f2": 1}, {"f1": 3, "f2": 1}], "_metadata": {"etag": "3710d2dcdbdc9eb3af57a53dc3fd2a27"}}
UPDATE p_dv1 SET data = ' {
    "_id" : 1,
    "f4" : 222,
    "_metadata": {"etag": "3710d2dcdbdc9eb3af57a53dc3fd2a27"},
    "ChildNode" : [{
                    "f1" : 33
                   },
                   {
                    "f1" : 4
                   },
                   {
                    "_metadata": 42,
                    "f1" : 5
                   }
                   ]
} ';
ERROR HY000: Path '$.ChildNode[2]._metadata' is not mapped to any column of `test`.`p_t1`.
UPDATE p_dv1 SET data = ' {
    "_id" : 1,
    "f4" : 222,
    "_metadata": {"etag": "3710d2dcdbdc9eb3af57a53dc3fd2a27"},
    "ChildNode" : [{
                    "f1" : 33
                   },
                   {
                    "f1" : 4
                   },
                   {
                    "_metadata": {"etag": "2df8795d587963d9b7c987375c4fc0b1"},
                    "f1" : 5
                   }
                   ]
} ';
ERROR HY000: Path '$.ChildNode[2]._metadata' is not mapped to any column of `test`.`p_t1`.
SELECT * FROM p_dv1;
data
{"f4": 1, "_id": 1, "ChildNode": [{"f1": 2, "f2": 1}, {"f1": 3, "f2": 1}], "_metadata": {"etag": "3710d2dcdbdc9eb3af57a53dc3fd2a27"}}
DROP VIEW p_dv1;
DROP TABLE p_t2;
DROP TABLE p_t1;
# Check that incorrect JSON types is rejected
CREATE TABLE t1 (f1 INT PRIMARY KEY, f2 INT) ;
CREATE TABLE t2 (f11 INT PRIMARY KEY REFERENCES t1(f1), f12 INT);
INSERT INTO t1 VALUES (1, 2);
INSERT INTO t2 VALUES (1, 2);
# Verify that an error is reported if an array is
# passed to a singleton child
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id' : f11,
'f12' : f12,
'childN' : (SELECT JSON_DUALITY_OBJECT(
'Key' : f1,
'f2' : f2
) FROM t1 WHERE t1.f1 = t2.f11)
) FROM t2;
SELECT * FROM dv1;
data
{"_id": 1, "f12": 2, "childN": {"f2": 2, "Key": 1}, "_metadata": {"etag": "0870d1033a923e5f5bedb5463d551126"}}
UPDATE dv1 SET data = '{
    "_id" : 4,
    "f12" : 2,
    "childN" : [{
                "f1" : 1,
                "f2" : 30
               }]
}';
ERROR HY000: Path '$.childN' is not of type 'Json_object'.
INSERT INTO dv1 VALUES ('{
    "_id" : 4,
    "f12" : 2,
    "childN" : [{
                "f1" : 1,
                "f2" : 30
               }]
}');
ERROR HY000: Path '$.childN' is not of type 'Json_object'.
# Verify that an error is reported if an object is
# passed to a multi child
CREATE JSON DUALITY VIEW dv2 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id' : f11,
'f12' : f12,
'childN' : (
SELECT
JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
'Key' : f1,
'f2' : f2
))
FROM t1 WHERE t1.f1 = t2.f11)
) FROM t2;
UPDATE dv2 SET data = '{
    "_id" : 4,
    "f12" : 2,
    "childN" : {
                "f1" : 1,
                "f2" : 30
               }
}';
ERROR HY000: Path '$.childN' is not of type 'Json_array'.
INSERT INTO dv2 VALUES ('{
    "_id" : 4,
    "f12" : 2,
    "childN" : {
                "f1" : 1,
                "f2" : 30
               }
}');
ERROR HY000: Path '$.childN' is not of type 'Json_array'.
DROP VIEW dv2;
DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;
