#################################################################################
# Verify warning messages aggregation for JSON duality view object update.
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);
INSERT INTO p_t1 VALUES (1, 1);
INSERT INTO p_t2 VALUES (1, 1);
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH UPDATE
"_id" : f3,
"f4" : f4,
"ChildNode" : (SELECT JSON_DUALITY_OBJECT(WITH UPDATE
"f1" : f1,
"f2" : f2)
FROM p_t1
WHERE p_t1.f1 = p_t2.f3)
) FROM p_t2 ;
SELECT * FROM p_dv1;
data
{"f4": 1, "_id": 1, "ChildNode": {"f1": 1, "f2": 1}, "_metadata": {"etag": "1ec721700727fedd824e5146fad497e5"}}
UPDATE p_dv1 SET data = ' { "_id" : 1, "f4" : 4, "ChildNode" : {"f1" : 1, "f2" : 4 }, "_metadata": {"etag": "1ec721700727fedd824e5146fad497e5"} }';
SELECT * FROM p_dv1;
data
{"f4": 4, "_id": 1, "ChildNode": {"f1": 1, "f2": 4}, "_metadata": {"etag": "15f0c4620a62701681233686506898a9"}}
UPDATE p_dv1 SET data = JSON_SET(data, '$.f4', 5);
SELECT * FROM p_dv1;
data
{"f4": 5, "_id": 1, "ChildNode": {"f1": 1, "f2": 4}, "_metadata": {"etag": "5b02ec9cc10b96a4e4d9cfa3fe12d718"}}
SET @orig_sql_mode = @@sql_mode;
SET sql_mode = 0;
UPDATE p_dv1 SET data = ' { "_id" : 1, "f4" : "123abcd", "ChildNode" : {"f1" : 1, "f2" : "123abcd" }, "_metadata": {"etag": "5b02ec9cc10b96a4e4d9cfa3fe12d718"} }';
Warnings:
Warning	1265	Data truncated for column 'f2' at row 1
Warning	1265	Data truncated for column 'f4' at row 1
SET @@sql_mode = @orig_sql_mode;
SELECT * FROM p_dv1;
data
{"f4": 123, "_id": 1, "ChildNode": {"f1": 1, "f2": 123}, "_metadata": {"etag": "11d233c5b6686156ff0a867b0f47fa97"}}
DROP TABLE p_t1;
DROP TABLE p_t2;
