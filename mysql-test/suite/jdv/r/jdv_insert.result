SET sql_mode = 0;
INSERT INTO p_dv1 VALUES (' { "_id" : 3, "f4" : "123abcd", "ChildNode" : {"f1" : 3, "f2" : "123abcd" } }');
Warnings:
Warning	1265	Data truncated for column 'f2' at row 1
Warning	1265	Data truncated for column 'f4' at row 1
SET @@sql_mode = @orig_sql_mode;
SELECT * FROM p_dv1;
