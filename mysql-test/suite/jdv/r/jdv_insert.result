# sub-object column.
# Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
# Sub-object - Primary Key   Table annotations: READ ONLY
# Join_condition - Root object.non_pk_column = sub_object.pk_column
################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT, f5 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);
INSERT INTO p_t1 VALUES (1, 1, 11);
INSERT INTO p_t2 VALUES (1, 1);
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : f3,
"f4" : f4,
"ChildNode" : (SELECT JSON_DUALITY_OBJECT(
"f1" : f1,
"f2" : f2,
"f5" : f5
) FROM p_t1 WHERE p_t1.f1 = p_t2.f4)
) FROM p_t2;
SELECT * FROM p_dv1;
data
{"f4": 1, "_id": 1, "ChildNode": {"f1": 1, "f2": 1, "f5": 11}, "_metadata": {"etag": "a252519148c2467425f289a908db0b32"}}
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4"  : 1,
     "ChildNode" : {"f1" : 1, "f2" : 200, "f5" : 555}
  } ');
SELECT * FROM p_dv1;
data
{"f4": 1, "_id": 1, "ChildNode": {"f1": 1, "f2": 1, "f5": 11}, "_metadata": {"etag": "a252519148c2467425f289a908db0b32"}}
{"f4": 1, "_id": 2, "ChildNode": {"f1": 1, "f2": 1, "f5": 11}, "_metadata": {"etag": "21836f8cb2b7da05408dffa8914acd59"}}
DROP TABLE p_t2;
DROP TABLE p_t1;
################################################################################
# Inserting new Root Objects and referencing an existing Sub-object and modifying
# sub-object column.
# Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
# Sub-object - Primary Key   Table annotations: INSERT, UPDATE
# Join_condition - Root object.non_pk_column = sub_object.pk_column
################################################################################
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT, f5 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);
INSERT INTO p_t1 VALUES (1, 1, 11);
INSERT INTO p_t2 VALUES (1, 1);
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : f3,
"f4" : f4,
"ChildNode" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"f1" : f1,
"f2" : f2,
"f5" : f5
) FROM p_t1
WHERE p_t1.f1 = p_t2.f4)
) FROM p_t2;
SELECT * FROM p_dv1;
data
{"f4": 1, "_id": 1, "ChildNode": {"f1": 1, "f2": 1, "f5": 11}, "_metadata": {"etag": "a252519148c2467425f289a908db0b32"}}
INSERT INTO p_dv1 VALUES (
' {
     "_id" : 2,
     "f4"  : 1,
     "ChildNode" : {"f1" : 1, "f2" : 200, "f5" : 555}
  } ');
SELECT * FROM p_dv1;
data
{"f4": 1, "_id": 1, "ChildNode": {"f1": 1, "f2": 200, "f5": 555}, "_metadata": {"etag": "6ba76332697f71ff513b017addd41b6d"}}
{"f4": 1, "_id": 2, "ChildNode": {"f1": 1, "f2": 200, "f5": 555}, "_metadata": {"etag": "9f2cf30a641d388db22d4ca761c595fa"}}
DROP TABLE p_t2;
DROP TABLE p_t1;
DROP VIEW p_dv1;
#
# Bug#38319365: Disallow explicit generation request 0 for AUTO_INCREMENT columns in JDVs
#
CREATE TABLE customers (
customer_id INT PRIMARY KEY AUTO_INCREMENT,
name VARCHAR(100)
);
CREATE TABLE orders (
order_id INT PRIMARY KEY AUTO_INCREMENT,
customer_id INT,
product VARCHAR(100),
amount DECIMAL(10,2),
FOREIGN KEY (customer_id) REFERENCES customers(customer_id)
);
CREATE OR REPLACE JSON RELATIONAL DUALITY VIEW customers_orders_dv AS
SELECT JSON_DUALITY_OBJECT( WITH(INSERT,UPDATE,DELETE)
'_id': customer_id,
'customer_name': name,
'orders': (
SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT( WITH(INSERT,UPDATE,DELETE)
'order_id': order_id,
'product': product,
'amount': amount
)
)
FROM orders
WHERE orders.customer_id = customers.customer_id
)
)
FROM customers;
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Alice",
    "_id": 1,
    "orders": [
      {"order_id": 1, "product": "Laptop", "amount": 1299.99},
      {"order_id": 1, "product": "Mouse", "amount": 19.99}
    ]
}');
ERROR HY000: Path '$.orders[1]' is a duplicate for primary key column `test`.`orders`.order_id but has conflicting values for column product: path '$.orders[1].product' vs path '$.orders[0].product'
SELECT * FROM orders;
order_id	customer_id	product	amount
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Alice",
    "_id": 1,
    "orders": [
      {"order_id": 0, "product": "Laptop", "amount": 1299.99},
      {"order_id": 0, "product": "Mouse", "amount": 19.99}
    ]
}');
SELECT * FROM orders;
order_id	customer_id	product	amount
1	1	Laptop	1299.99
2	1	Mouse	19.99
# The use of 0 here must be rejected as it is transformed
# to a different value. If that value is 1 the check for non-identical
# PK duplicates are lost and the result is that the first record
# inserted gets updated.
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Bob",
    "_id": 2,
    "orders": [
      {"order_id": 0, "product": "Laptop", "amount": 1299.99},
      {"order_id": 3, "product": "Mouse", "amount": 19.99}
    ]
}');
ERROR HY000: Paths $.orders[0] and $.orders[1] use generated and explicit values for the same primary key, which is not allowed.
# Explicitly providing non-0 values for AUTO_INCREMENT column is ok
INSERT INTO customers_orders_dv VALUES (
'{  "customer_name": "Candace",
    "_id": 3,
    "orders": [
      {"order_id": 4, "product": "Laptop", "amount": 1299.99},
      {"order_id": 5, "product": "Mouse", "amount": 19.99}
    ]
}');
SELECT * FROM orders;
order_id	customer_id	product	amount
1	1	Laptop	1299.99
2	1	Mouse	19.99
4	3	Laptop	1299.99
5	3	Mouse	19.99
DROP VIEW customers_orders_dv;
DROP TABLE orders;
DROP TABLE customers;
# With wl#17056 we now allow AUTO_INCREMENT values to be generated
# explicitly by passing 0. But this 0 will not match an explicit 0 for
# a non-AUTO_INCREMENT column.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY, t2c2 INT UNIQUE AUTO_INCREMENT);
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : t2c1,
"k_t2c2" : t2c2,
"k_singleton_t1" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"k_t1c1" : t1c1,
"k_t1c2" : t1c2
) FROM t1  WHERE t1.t1c1 = t2.t2c2)
) FROM t2;
# Note that the two 0s appearing in the join condition here have different
# meanings: k_t2c2 being an AUTO_INCREMENT column is an explicit generation
# request, which will result in the value 1, while k_t1c1 is an ordinary INT
# column with the value 0. Consequently the join condition is not satisfied.
INSERT INTO dv1 VALUES (
' {
     "_id" : 2,
     "k_t2c2": 0,
     "k_singleton_t1" : {
                      "k_t1c1" : 0,
                      "k_t1c2" : 4
                    }
  } ');
ERROR HY000: Join condition is not satisfied as path '$.k_singleton_t1.k_t1c1' for child column `test`.`t1`.t1c1 is not equal to path '$' for parent column `test`.`t2`.t2c2.
DELETE FROM t1;
DELETE FROM t2;
INSERT INTO dv1 VALUES (
' {
     "_id" : 3,
     "k_singleton_t1" : {
                      "k_t1c1": 0,
                      "k_t1c2" : 5
                    }
  } ');
ERROR HY000: Join condition is not satisfied as path '$.k_singleton_t1.k_t1c1' for child column `test`.`t1`.t1c1 is not equal to path '$' for parent column `test`.`t2`.t2c2.
DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;
################################################################################
# Verify that omitting value for auto-increment columns is only permitted
# when column is not part of join-condition.
################################################################################
#
# Bug#38179925: Insert into a JDV with AUTO_INCREMNT colunn is rejected
# even if not part of join condition
#
# Verify that singleton child with non-pk auto-increment parent
# join condition column rejects insert if value is not explicitly
# provided in JSON.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY, t2c2 INT UNIQUE AUTO_INCREMENT);
INSERT INTO t1 VALUES (1, 2);
INSERT INTO t2(t2c1,t2c2) VALUES (200, 1);
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : t2c1,
"k_t2c2" : t2c2,
"k_singleton_t1" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"k_t1c1" : t1c1,
"k_t1c2" : t1c2
) FROM t1  WHERE t1.t1c1 = t2.t2c2)
) FROM t2;
SELECT * FROM dv1;
data
{"_id": 200, "k_t2c2": 1, "_metadata": {"etag": "c58c6bd4f5bcd88b2fa6bf66e3aba3e3"}, "k_singleton_t1": {"k_t1c1": 1, "k_t1c2": 2}}
SELECT * FROM t1;
t1c1	t1c2
1	2
SELECT * FROM t2;
t2c1	t2c2
200	1
INSERT INTO dv1 VALUES (
' {
     "_id" : 2,
     "k_singleton_t1" : {
                      "k_t1c2" : 4
                    }
  } ');
ERROR HY000: Primary key column `test`.`t1`.t1c1 must be provided as path '$.k_singleton_t1.k_t1c1'.
DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;
# Verify that nested child with non-pk auto-increment
# join condition column rejects insert if value is not explicitly
# provided in JSON.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT UNIQUE AUTO_INCREMENT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY, t2c2 INT);
INSERT INTO t1 VALUES (1, 2);
INSERT INTO t2(t2c1,t2c2) VALUES (2, 10);
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : t2c1,
"k_t2c2" : t2c2,
"nested_t1" : (SELECT JSON_ARRAYAGG(
JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
"k_t1c1" : t1c1,
"k_t1c2" : t1c2
)) FROM t1 WHERE t1.t1c2 = t2.t2c1)
) FROM t2;
SELECT * FROM dv1;
data
{"_id": 2, "k_t2c2": 10, "_metadata": {"etag": "2e03cfe134af7f7666279c1c242da3d0"}, "nested_t1": [{"k_t1c1": 1, "k_t1c2": 2}]}
SELECT * FROM t1;
t1c1	t1c2
1	2
SELECT * FROM t2;
t2c1	t2c2
2	10
INSERT INTO dv1 VALUES (
' {
     "k_t2c2" : 400,
     "nested_t1" : [{
                      "k_t1c1" : 42
                    }]
  } ');
ERROR HY000: Primary key column `test`.`t2`.t2c1 must be provided as path '$._id'.
DROP VIEW dv1;
DROP TABLE t2;
DROP TABLE t1;
# Verify that insert is permitted and gives expected results when
# AUTO_INCREMENT is used on a column which is not part of a
# join-condition.
CREATE TABLE t1 (t1c1 INT PRIMARY KEY, t1c2 INT);
CREATE TABLE t2 (t2c1 INT PRIMARY KEY REFERENCES t1(t1c1), t2c2 INT UNIQUE AUTO_INCREMENT);
INSERT INTO t1 VALUES (1, 2);
INSERT INTO t2(t2c1,t2c2) VALUES (1, 200);
CREATE JSON DUALITY VIEW dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
"_id" : t2c1,
"k_t2c2" : t2c2,
"k_singleton_t1" : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
"k_t1c1" : t1c1,
"k_t1c2" : t1c2
) FROM t1  WHERE t1.t1c1 = t2.t2c1)
) FROM t2;
SELECT * FROM dv1;
data
{"_id": 1, "k_t2c2": 200, "_metadata": {"etag": "b9b3923c052020e5b9b2fe00967b65a7"}, "k_singleton_t1": {"k_t1c1": 1, "k_t1c2": 2}}
SELECT * FROM t1;
t1c1	t1c2
1	2
SELECT * FROM t2;
t2c1	t2c2
1	200
