  } ');
SELECT * FROM dv1;
data
{"_id": 1, "k_t2c2": 200, "_metadata": {"etag": "b9b3923c052020e5b9b2fe00967b65a7"}, "k_singleton_t1": {"k_t1c1": 1, "k_t1c2": 2}}
{"_id": 3, "k_t2c2": 201, "_metadata": {"etag": "94e520a5db24c2a0e9c69d89c899bc27"}, "k_singleton_t1": {"k_t1c1": 3, "k_t1c2": 4}}
SELECT * FROM t1;
t1c1	t1c2
1	2
3	4
SELECT * FROM t2;
t2c1	t2c2
1	200
3	201
INSERT INTO dv1 VALUES (
' {

     "_id" : 4,
