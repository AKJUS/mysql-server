################################################################################
# Inserting into Root object and Sub object using table with self referencing FK.
# Root object - Primary Key  Table annotations: INSERT, UPDATE, DELETE
# Sub-object - Foreign Key   Table annotations: INSERT, UPDATE
################################################################################
CREATE TABLE p_employee (empid INT PRIMARY KEY,
name VARCHAR(100),
mgrid INT REFERENCES p_employee(empid));
CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE, DELETE)
'_id' : empid,
'name' : name,
'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
'empid': empid,
'name' : name,
'mgr' : (SELECT JSON_DUALITY_OBJECT(WITH (INSERT, UPDATE)
'empid' : empid,
'name'  : name
) FROM p_employee MM  WHERE MM.empid = M.mgrid)
) FROM p_employee M  WHERE M.empid = emp.mgrid)
) FROM p_employee emp;
