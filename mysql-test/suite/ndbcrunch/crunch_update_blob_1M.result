# Save source binlog position
## Connect to second mysqld, then start replicating from first mysqld
CHANGE REPLICATION SOURCE TO SOURCE_HOST='127.0.0.1', SOURCE_PORT=MYSQLD1_PORT;
START REPLICA IO_THREAD USER = 'root' PASSWORD = '';
Warnings:
