#
# Wait for IO thread to fetch all binlog
#
The IO thread has fetched all binlog!
# Start SQL Thread
START REPLICA SQL_THREAD;
#
# Wait for SQL thread to apply all binlog
#
The SQL thread has applied all binlog!
# Stop Replica after work is done
STOP REPLICA;
RESET REPLICA ALL;
