###############################################################################
# This test verifies that the component
# group_replication_resource_manager remove the member having low
# memory from the group and member rejoins the group.
#
# 0. The test requires three servers: M1 , M2 and M3
# 1. Install component group_replication_resource_manager on M3.
#    Start group replication on M1, M2 and M3.
# 2. Assert Gr_resource_manager_memory_eviction_timestamp
#    and Gr_resource_manager_memory_threshold_hits
#    are not set.
# 3. M3 is ONLINE. Since memory_used_limit = 0, disables the feature.
# 4. Set memory_used_limit to 1 and quarantine_time=3600.
#    Secondary will not leave the group since it joined
#    less than 1 hour ago.
# 5. Set memory_used_limit to 1 and quarantine_time=0.
#    M3 will leave the group and rejoin.
# 6. Assert Gr_resource_manager_memory_eviction_timestamp
#    and Gr_resource_manager_memory_threshold_hits
#    are set.
# 7. Cleanup

--source include/have_group_replication_resource_manager.inc
--source include/big_test.inc
--source include/have_debug.inc
--source include/have_group_replication_plugin.inc
--let $rpl_server_count= 3
--let $rpl_skip_group_replication_start= 1
--let $rpl_group_replication_single_primary_mode=1
--source include/group_replication.inc

--echo
--echo #########################################################
--echo # 1. Install component group_replication_resource_manager on M3.
--echo #    Start group replication on M1, M2 and M3.

--let $rpl_connection_name= server1
--source include/connection.inc

--source include/start_and_bootstrap_group_replication.inc

--let $rpl_connection_name= server2
--source include/connection.inc

--source include/start_group_replication.inc

--let $rpl_connection_name= server3
--source include/connection.inc

--source include/gr_autorejoin_monitoring.inc

SET SESSION sql_log_bin= 0;
call mtr.add_suppression("The server was automatically set into read only mode after an error was detected.");
call mtr.add_suppression("The server was automatically set into offline mode after an error was detected.");
call mtr.add_suppression("Member exiting group: memory used.*");
call mtr.add_suppression("Member threshold exceeded: memory used of .*% exceeded tolerance threshold configured to 1%. However, since it joined .* seconds ago and the quarantine period is configured to 3600 seconds, the member will not leave the group.");
SET SESSION sql_log_bin= 1;

INSTALL COMPONENT 'file://component_group_replication_resource_manager';
SET @quarantine_time= @@global.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
--source include/start_group_replication.inc

--echo
--echo #########################################################
--echo # 2. Assert Gr_resource_manager_memory_eviction_timestamp
--echo #    and Gr_resource_manager_memory_threshold_hits
--echo #    are not set.

--let $rpl_connection_name= server3
--source include/connection.inc

--let $assert_text= 'Eviction timestamp is not set.'
--let $assert_cond= [SELECT COUNT(*) AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_eviction_timestamp" AND VARIABLE_VALUE = "", COUNT, 1] = 1
--source include/assert.inc

--let $assert_text= 'There are no memory used hits.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_threshold_hits", VARIABLE_VALUE, 1] = 0
--source include/assert.inc

--let $assert_text= 'Memory status is visible.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_used", VARIABLE_VALUE, 1] > 0
--source include/assert.inc

--echo
--echo #########################################################
--echo # 3. M3 is ONLINE. Since memory_used_limit = 0, disables the feature.

SET @memory_limit= @@global.group_replication_resource_manager.memory_used_limit;
SET @@GLOBAL.group_replication_resource_manager.memory_used_limit=0;
SET @@GLOBAL.DEBUG='+d,group_replication_stop_before_rejoin_loop';

# Wait for 10 samples.
--sleep 60

--let $group_replication_member_state= ONLINE
--source include/gr_wait_for_member_state.inc

--echo
--echo #########################################################
--echo # 4. Set memory_used_limit to 1 and quarantine_time=3600.
--echo #    Secondary will not leave the group since it joined
--echo #    less than 1 hour ago.

SET GLOBAL group_replication_resource_manager.quarantine_time = 3600;
SET @@GLOBAL.group_replication_resource_manager.memory_used_limit=1;

# Wait for 10 samples.
--sleep 60

--let $group_replication_member_state= ONLINE
--source include/gr_wait_for_member_state.inc

--echo
--echo #########################################################
--echo # 5. Set memory_used_limit to 1 and quarantine_time=0.
--echo #    M3 will leave the group and rejoin.

SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
SET @@GLOBAL.group_replication_resource_manager.memory_used_limit=1;

SET DEBUG_SYNC = "now WAIT_FOR signal.autorejoin_entering_loop";
SET @@GLOBAL.DEBUG='-d,group_replication_stop_before_rejoin_loop';

# Disable memory_used_limit otherwise M3 will keep leaving the group and rejoin.
SET @@GLOBAL.group_replication_resource_manager.memory_used_limit=0;

# Verify that it is currently running
--let $assert_text = Auto-rejoin should be running
--let $assert_cond = [SELECT IS_AUTOREJOIN_RUNNING()] = TRUE
--source include/assert.inc

SET DEBUG_SYNC = "now SIGNAL signal.autorejoin_enter_loop";

--let $group_replication_member_state= ONLINE
--source include/gr_wait_for_member_state.inc

--echo
--echo #########################################################
--echo # 6. Assert Gr_resource_manager_memory_eviction_timestamp
--echo #    and Gr_resource_manager_memory_threshold_hits
--echo #    are set.

--echo 'Eviction timestamp is set.'
--let $wait_condition= SELECT COUNT(*)=1 AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_eviction_timestamp" AND VARIABLE_VALUE <> ""
--source include/wait_condition.inc

--let $assert_text= 'There are memory threshold hits.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_threshold_hits", VARIABLE_VALUE, 1] >= 10
--source include/assert.inc

--let $assert_text= 'Memory status is visible.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_used", VARIABLE_VALUE, 1] > 0
--source include/assert.inc

--echo ############################################################
--echo # 7. Cleanup

--let $rpl_connection_name= server3
--source include/connection.inc
--source include/stop_group_replication.inc

SET @@global.group_replication_resource_manager.memory_used_limit = @memory_limit;
SET @@global.group_replication_resource_manager.quarantine_time = @quarantine_time;

UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
--source include/gr_end_autorejoin_monitoring.inc

--source include/group_replication_end.inc
