################################################################################
# This test checks the component_group_replication_resource_manager persist
# variables with and without component installed.
#
# 0. The test requires one server: M1
# 1. Persist configuration on server1. Uninstall component.
# 2. Restart server1 without component.
#    No variables are shown as persisted.
# 3. Install component and verify that variable_source is shown
#    as PERSISTED.
# 4. Restart server1, 4 variables will be persisted.
# 5. Uninstall component and reset persist variables.
# 6. Install component by setting persist variables.
# 7. Restart server1, 4 variables will be persisted.
# 8. Clean up.
################################################################################
--source include/have_group_replication_resource_manager.inc
--source include/big_test.inc
--source include/force_restart.inc
--source include/have_group_replication_plugin.inc
--let $rpl_skip_group_replication_start= 1
--source include/group_replication.inc

SET SESSION sql_log_bin= 0;
call mtr.add_suppression("Currently unknown variable 'group_replication_resource_manager.applier_channel_lag' was read from the persisted config file.");
call mtr.add_suppression("Currently unknown variable 'group_replication_resource_manager.recovery_channel_lag' was read from the persisted config file.");
call mtr.add_suppression("Currently unknown variable 'group_replication_resource_manager.quarantine_time' was read from the persisted config file.");
call mtr.add_suppression("Currently unknown variable 'group_replication_resource_manager.memory_used_limit' was read from the persisted config file.");
SET SESSION sql_log_bin= 1;


--echo
--echo ############################################################
--echo # 1. Persist configuration on server1. Uninstall component.

--let $rpl_connection_name= server1
--source include/connection.inc

INSTALL COMPONENT 'file://component_group_replication_resource_manager';
RESET PERSIST;
SET PERSIST group_replication_resource_manager.applier_channel_lag= 3600;
SET PERSIST group_replication_resource_manager.recovery_channel_lag= 3600;
SET PERSIST group_replication_resource_manager.quarantine_time= 3600;
SET PERSIST group_replication_resource_manager.memory_used_limit= 100;

--let $assert_text= 'Expect 4 persisted variables.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.persisted_variables, count, 1] = 4
--source include/assert.inc

--echo
--echo ############################################################
--echo # 2. Restart server1 without component.
--echo #    No variables are shown as persisted.

UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
--let $allow_rpl_inited= 1
--source include/restart_mysqld.inc
--let $rpl_server_number= 1
--source include/rpl/reconnect.inc

--echo
--let $assert_text= 'There must be NO variable shown as persisted in variables_info table.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info WHERE variable_source="PERSISTED", count, 1] = 0
--source include/assert.inc

--echo
--echo ############################################################
--echo # 3. Install component and verify that variable_source is shown
--echo #    as PERSISTED.

INSTALL COMPONENT 'file://component_group_replication_resource_manager';

--let $assert_text= 'Expect 4 persisted variables shown as PERSISTED in variables_info table.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info WHERE variable_source="PERSISTED", count, 1] = 4
--source include/assert.inc

--let $assert_text= 'Expect 4 persisted variables with matching persisted and global values.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info vi JOIN performance_schema.persisted_variables pv JOIN performance_schema.global_variables gv ON vi.variable_name=pv.variable_name AND vi.variable_name=gv.variable_name AND pv.variable_value=gv.variable_value WHERE vi.variable_source="PERSISTED", count, 1] = 4
--source include/assert.inc

--echo
--echo ############################################################
--echo # 4. Restart server1, 4 variables will be persisted.

--let $allow_rpl_inited= 1
--let $restart_parameters=
--source include/restart_mysqld.inc
--let $rpl_server_number= 1
--source include/rpl/reconnect.inc
--let $MYSQLD_DATADIR= `select @@datadir;`

--let $assert_text= 'Expect 4 persisted variables shown as PERSISTED in variables_info table.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info WHERE variable_source="PERSISTED", count, 1] = 4
--source include/assert.inc

--let $assert_text= 'Expect 4 persisted variables with matching persisted and global values.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info vi JOIN performance_schema.persisted_variables pv JOIN performance_schema.global_variables gv ON vi.variable_name=pv.variable_name AND vi.variable_name=gv.variable_name AND pv.variable_value=gv.variable_value WHERE vi.variable_source="PERSISTED", count, 1] = 4
--source include/assert.inc

--echo
--echo ############################################################
--echo # 5. Uninstall component and reset persist variables.

UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
RESET PERSIST;

--let $assert_text= 'Expect 0 persisted variables shown as PERSISTED in variables_info table.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info WHERE variable_source="PERSISTED", count, 1] = 0
--source include/assert.inc

--let $assert_text= 'Expect 0 persisted variables with matching persisted and global values.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info vi JOIN performance_schema.persisted_variables pv JOIN performance_schema.global_variables gv ON vi.variable_name=pv.variable_name AND vi.variable_name=gv.variable_name AND pv.variable_value=gv.variable_value WHERE vi.variable_source="PERSISTED", count, 1] = 0
--source include/assert.inc

--echo
--echo ############################################################
--echo # 6. Install component by setting persist variables.

INSTALL COMPONENT 'file://component_group_replication_resource_manager'
SET
PERSIST group_replication_resource_manager.applier_channel_lag= 3600,
PERSIST group_replication_resource_manager.recovery_channel_lag= 3600,
PERSIST group_replication_resource_manager.quarantine_time= 3600,
PERSIST group_replication_resource_manager.memory_used_limit= 100;

--echo
--echo ############################################################
--echo # 7. Restart server1, 4 variables will be persisted.

--let $allow_rpl_inited= 1
--let $restart_parameters=
--source include/restart_mysqld.inc
--let $rpl_server_number= 1
--source include/rpl/reconnect.inc

--let $assert_text= 'Expect 4 persisted variables shown as PERSISTED in variables_info table.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info WHERE variable_source="PERSISTED", count, 1] = 4
--source include/assert.inc

--let $assert_text= 'Expect 4 persisted variables with matching persisted and global values.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.variables_info vi JOIN performance_schema.persisted_variables pv JOIN performance_schema.global_variables gv ON vi.variable_name=pv.variable_name AND vi.variable_name=gv.variable_name AND pv.variable_value=gv.variable_value WHERE vi.variable_source="PERSISTED", count, 1] = 4
--source include/assert.inc

--echo
--echo ############################################################
--echo # 8. Clean up.

--let $rpl_connection_name= server1
--source include/connection.inc

RESET PERSIST;
--remove_file $MYSQLD_DATADIR/mysqld-auto.cnf

--let $assert_text= 'There must be 0 persisted variables.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.persisted_variables, count, 1] = 0
--source include/assert.inc

--source include/group_replication_end.inc
