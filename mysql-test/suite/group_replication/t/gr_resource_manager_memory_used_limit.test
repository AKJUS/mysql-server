###############################################################################
# This test verifies that the component
# group_replication_resource_manager remove the member having the
# high memory consumption threshold hit and put it into ERROR state.
#
# 0. The test requires three servers: M1, M2 and M3
# 1. Install component group_replication_resource_manager on M1, M2 and M3.
#    Start group replication on M1, M2 and M3.
#    Set group_replication_autorejoin_tries to 0.
# 2. Decrease group_replication_resource_manager.memory_used_limit to 1 on server 1.
# 3. Since high memory consumption threshold was hit, component is expected to
#    make the server 1 leave the group.
#    However M1 is primary in the group so member will not leave the group.
# 4. Assert Gr_resource_manager_memory_eviction_timestamp
#    and Gr_resource_manager_memory_threshold_hits
#    are not set on M3, that is, none of the previous steps
#    impacted it.
# 5. Decrease group_replication_resource_manager.memory_used_limit to 1 on server 3.
# 6. Since high memory consumption threshold was hit, component will make the server 3
#    leave the group and move it to ERROR state.
# 7. Assert Gr_resource_manager_memory_eviction_timestamp
#    and Gr_resource_manager_memory_threshold_hits are set.
# 8. Stop server 3.
# 9. Decrease group_replication_resource_manager.memory_used_limit to 1 on server 2.
# 10. Since high memory consumption threshold was hit, component is expected to make the server 2
#    leave the group.
#    However only 2 members are present in the group so member will not leave the group.
# 11. Cleanup

--source include/have_group_replication_resource_manager.inc
--source include/big_test.inc
--source include/have_group_replication_plugin.inc
--let $rpl_server_count= 3
--let $rpl_skip_group_replication_start= 1
--let $rpl_group_replication_single_primary_mode=1
--source include/group_replication.inc

--echo
--echo #########################################################
--echo # 1. Install component group_replication_resource_manager on M1, M2 and M3.
--echo #    Start group replication on M1, M2 and M3.
--echo #    Set group_replication_autorejoin_tries to 0.

--let $rpl_connection_name= server1
--source include/connection.inc

INSTALL COMPONENT 'file://component_group_replication_resource_manager';
SET @autorejoin_retry= @@global.group_replication_autorejoin_tries;
SET @quarantine_time= @@global.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_autorejoin_tries = 0;
SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
--source include/start_and_bootstrap_group_replication.inc

--let $rpl_connection_name= server2
--source include/connection.inc

SET SESSION sql_log_bin= 0;
call mtr.add_suppression("Member threshold exceeded: memory used.*. However, the group has less than 3 members, the member will not leave the group.");
SET SESSION sql_log_bin= 1;

INSTALL COMPONENT 'file://component_group_replication_resource_manager';
SET @autorejoin_retry= @@global.group_replication_autorejoin_tries;
SET @quarantine_time= @@global.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_autorejoin_tries = 0;
SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
--source include/start_group_replication.inc


--let $rpl_connection_name= server3
--source include/connection.inc

SET SESSION sql_log_bin= 0;
call mtr.add_suppression("The server was automatically set into read only mode after an error was detected.");
call mtr.add_suppression("The server was automatically set into offline mode after an error was detected.");
call mtr.add_suppression("Skipping leave operation: concurrent attempt to leave the group is on-going.");
call mtr.add_suppression("Member exiting group: memory used.*");
SET SESSION sql_log_bin= 1;

INSTALL COMPONENT 'file://component_group_replication_resource_manager';
SET @autorejoin_retry= @@global.group_replication_autorejoin_tries;
SET @quarantine_time= @@global.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_autorejoin_tries = 0;
SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
--source include/start_group_replication.inc

--echo
--echo #########################################################
--echo # 2. Decrease group_replication_resource_manager.memory_used_limit to 1 on server 1.

--let $rpl_connection_name= server1
--source include/connection.inc

SET @memory_limit= @@global.group_replication_resource_manager.memory_used_limit;
SET GLOBAL group_replication_resource_manager.memory_used_limit = 1;

--echo
--echo #########################################################
--echo # 3. Since high memory consumption threshold was hit, component is expected
--echo #    to make the server 1 leave the group.
--echo #    However M1 is primary in the group so member will not leave the group.

--let $rpl_connection_name= server1
--source include/connection.inc

--let $group_replication_member_state= ONLINE
--source include/gr_wait_for_member_state.inc

--echo 'Wait for 10 or more memory threshold hits.'
--let $wait_condition= SELECT COUNT(*)=1 AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_threshold_hits" AND VARIABLE_VALUE >= 10
--source include/wait_condition.inc

--let $assert_text= 'Eviction timestamp is not set.'
--let $assert_cond= [SELECT COUNT(*) AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_eviction_timestamp" AND VARIABLE_VALUE = "", COUNT, 1] = 1
--source include/assert.inc

--let $assert_text= 'Memory status is visible.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_used", VARIABLE_VALUE, 1] > 0
--source include/assert.inc

--echo
--echo #########################################################
--echo # 4. Assert Gr_resource_manager_memory_eviction_timestamp
--echo #    and Gr_resource_manager_memory_threshold_hits
--echo #    are not set on M3, that is, none of the previous steps
--echo #    impacted it.

--let $rpl_connection_name= server3
--source include/connection.inc

--let $assert_text= 'Eviction timestamp is not set.'
--let $assert_cond= [SELECT COUNT(*) AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_eviction_timestamp" AND VARIABLE_VALUE = "", COUNT, 1] = 1
--source include/assert.inc

--let $assert_text= 'There are no memory threshold hits.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_threshold_hits", VARIABLE_VALUE, 1] = 0
--source include/assert.inc

--let $assert_text= 'Memory status is visible.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_used", VARIABLE_VALUE, 1] > 0
--source include/assert.inc

--echo
--echo #########################################################
--echo # 5. Decrease group_replication_resource_manager.memory_used_limit to 1 on server 3.
--let $rpl_connection_name= server3
--source include/connection.inc

SET @memory_limit= @@global.group_replication_resource_manager.memory_used_limit;
SET GLOBAL group_replication_resource_manager.memory_used_limit = 1;

--echo
--echo #########################################################
--echo # 6. Since high memory consumption threshold was hit, component will make the server 3
--echo #    leave the group and move it to ERROR state.

--let $rpl_connection_name= server3
--source include/connection.inc

--let $group_replication_member_state= ERROR
--let $wait_timeout= 600
--source include/gr_wait_for_member_state.inc

--echo
--echo #########################################################
--echo # 7. Assert Gr_resource_manager_memory_eviction_timestamp
--echo #    and Gr_resource_manager_memory_threshold_hits
--echo #    are set.

--echo 'Eviction timestamp is set.'
--let $wait_condition= SELECT COUNT(*)=1 AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_eviction_timestamp" AND VARIABLE_VALUE <> ""
--source include/wait_condition.inc

--let $assert_text= 'There are memory threshold hits.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_threshold_hits", VARIABLE_VALUE, 1] >= 10
--source include/assert.inc

--let $assert_text= 'Memory status is visible.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_used", VARIABLE_VALUE, 1] > 0
--source include/assert.inc

--echo
--echo #########################################################
--echo # 8. Stop server 3.

--let $rpl_connection_name= server3
--source include/connection.inc

--source include/stop_group_replication.inc

--echo
--echo #########################################################
--echo # 9. Decrease group_replication_resource_manager.memory_used_limit to 1 on server 2.

--let $rpl_connection_name= server2
--source include/connection.inc

SET @memory_limit= @@global.group_replication_resource_manager.memory_used_limit;
SET GLOBAL group_replication_resource_manager.memory_used_limit=1;

--echo
--echo #########################################################
--echo # 10. Since high memory consumption threshold was hit, component is expected
--echo #     to make the server 2 leave the group.
--echo #     However only 2 members are present in the group so member will not leave the group.

--let $rpl_connection_name= server2
--source include/connection.inc

--echo 'There are memory threshold hits.'
--let $wait_timeout= 300
--let $wait_condition= SELECT COUNT(*)=1 AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_threshold_hits" AND VARIABLE_VALUE >= 10
--source include/wait_condition.inc

--let $assert_text= 'Eviction timestamp is not set.'
--let $assert_cond= [SELECT COUNT(*) AS COUNT FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_eviction_timestamp" AND VARIABLE_VALUE = "", COUNT, 1] = 1
--source include/assert.inc

--let $assert_text= 'Memory status is visible.'
--let $assert_cond= [SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_resource_manager_memory_used", VARIABLE_VALUE, 1] > 0
--source include/assert.inc

--let $group_replication_member_state= ONLINE
--source include/gr_wait_for_member_state.inc

--echo ############################################################
--echo # 11. Cleanup

--let $rpl_connection_name= server3
--source include/connection.inc

SET GLOBAL group_replication_resource_manager.memory_used_limit = @memory_limit;
SET @@global.group_replication_autorejoin_tries = @autorejoin_retry;
SET @@global.group_replication_resource_manager.quarantine_time = @quarantine_time;

UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';

--let $rpl_connection_name= server2
--source include/connection.inc
--source include/stop_group_replication.inc

SET GLOBAL group_replication_resource_manager.memory_used_limit = @memory_limit;
SET @@global.group_replication_autorejoin_tries = @autorejoin_retry;
SET @@global.group_replication_resource_manager.quarantine_time = @quarantine_time;

UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';


--let $rpl_connection_name= server1
--source include/connection.inc
--source include/stop_group_replication.inc

SET GLOBAL group_replication_resource_manager.memory_used_limit = @memory_limit;
SET @@global.group_replication_autorejoin_tries = @autorejoin_retry;
SET @@global.group_replication_resource_manager.quarantine_time = @quarantine_time;

UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';

--source include/group_replication_end.inc
