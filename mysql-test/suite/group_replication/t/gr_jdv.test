## This test is based on a test example provided by the replication team.
## The initial setup starts three servers with all the prerequisites required
## for GR to start

--echo ################################################
--source include/have_group_replication_plugin.inc
--let $rpl_skip_group_replication_start= 1
--let $rpl_server_count= 3
--let $rpl_group_replication_single_primary_mode=1
--source include/group_replication.inc

--let $rpl_connection_name= server1
--source include/connection.inc
--let $server1_uuid= `SELECT @@server_uuid`
--source include/start_and_bootstrap_group_replication.inc

--let $rpl_connection_name= server2
--source include/connection.inc
--source include/start_group_replication.inc

--let $rpl_connection_name= server3
--source include/connection.inc
--source include/start_group_replication.inc

--echo ################################################

--echo # Make sure server1 is primary
--let $assert_text= Verify server1 is primary
--let $assert_cond= "[SELECT MEMBER_ID FROM performance_schema.replication_group_members WHERE MEMBER_ROLE=\'PRIMARY\', MEMBER_ID, 1]" = "$server1_uuid"
--source include/assert.inc

--echo # Create tables and a JSON duality view on the primary
--let $rpl_connection_name= server1
--source include/connection.inc
use test;
CREATE TABLE p_t1 (f1 INT PRIMARY KEY, f2 INT);
CREATE TABLE p_t2 (f3 INT PRIMARY KEY, f4 INT);

CREATE OR REPLACE JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
        "_id" : f3,
        "f4"  : f4,
        "ChildNode" : (
            SELECT JSON_DUALITY_OBJECT(
            WITH (INSERT, UPDATE)
                    "f1" : f1,
                    "f2" : f2)
            FROM p_t1
            WHERE p_t1.f1 = p_t2.f3
        )
) FROM p_t2;

--echo # Insert new row in the JSON duality view (on the primary)
--echo # In effect, it should enter values in the underlying tables.
INSERT INTO p_dv1 VALUES ('{
    "_id" : 2,
    "f4" : 300,
    "ChildNode" : {
        "f1" : 2,
        "f2" : 300
    }
}');

--echo # Compute checksum for I_S views
--source include/rpl_jdv_checksum_i_s.inc

--echo # Sync to secondaries
--source include/rpl/sync.inc

--echo ################################################
--echo # Connect to secondary server2
--let $rpl_connection_name= server2
--source include/connection.inc

--echo # Set server2 as primary.
--let $server2_uuid= query_get_value(SELECT @@SERVER_UUID, @@SERVER_UUID, 1)
--replace_result $server2_uuid SERVER2_UUID
--eval SELECT group_replication_set_as_primary("$server2_uuid")
--source include/gr_assert_primary_member.inc

--echo # Print the view definition stored on the replica
--echo # This makes sure that view exists on the replica
--echo # and has the same definition as source.
SHOW CREATE VIEW p_dv1;

--echo # Verify checksum for I_S views
--source include/rpl_jdv_checksum_i_s.inc

--echo # SELECT the data from JSON duality view on
--echo # replica.
--echo # This makes sure that INSERT was replicated
--echo # successfully (on the replica).

--let $diff_tables=server1:p_t1, server2:p_t1, server3:p_t1
--source include/diff_tables.inc

--let $diff_tables=server1:p_t2, server2:p_t2, server3:p_t2
--source include/diff_tables.inc

--echo # Server2 is acting as primary,
--echo # hence we are allowed to ALTER the view
ALTER JSON DUALITY VIEW p_dv1 AS
SELECT JSON_DUALITY_OBJECT(
WITH (INSERT, UPDATE, DELETE)
        "_id" : f3,
        "ChildNode" : (
            SELECT JSON_DUALITY_OBJECT(
            WITH (INSERT, UPDATE)
                    "f1" : f1,
                    "f2" : f2
            )
            FROM p_t1
            WHERE p_t1.f1 = p_t2.f3
        )
) FROM p_t2;

--echo # Compute new checksum for I_S views
--source include/rpl_jdv_checksum_i_s.inc

--echo # It must generate below output:
--echo # {
--echo #    "_id": 2,
--echo #    "ChildNode": {"f1": 2, "f2": 300},
--echo #    "_metadata": {"etag": "b0cf66f4ef72fc205c0b9b874842a7ca"}
--echo # }
SELECT * FROM p_dv1 WHERE JSON_EXTRACT(data, "$._id") = 2;

--echo # Sync to secondaries
--source include/rpl/sync.inc

--echo ################################################

--echo # Connect to secondary server3
--let $rpl_connection_name= server3
--source include/connection.inc

--echo # Set server3 as primary
--let $server3_uuid= query_get_value(SELECT @@SERVER_UUID, @@SERVER_UUID, 1)
--replace_result $server3_uuid SERVER3_UUID
--eval SELECT group_replication_set_as_primary("$server3_uuid")
--source include/gr_assert_primary_member.inc

--echo # Print the view definition stored on the replica
--echo # This makes sure that view exists on the replica
--echo # and has the same definition as source.
SHOW CREATE VIEW p_dv1;

--echo # Verify checksum for I_S views
--source include/rpl_jdv_checksum_i_s.inc

--echo # Setting ChildNode.f2 = 400,
--echo # using the same etag which was generated on server2
--echo # when it was primary.
UPDATE p_dv1 SET data = '
{
"_id": 2,
"ChildNode": {"f1": 2, "f2": 400},
"_metadata": {"etag": "b0cf66f4ef72fc205c0b9b874842a7ca"}
}';

--echo # Sync to secondaries
--source include/rpl/sync.inc

--echo ################################################

--echo # Connect to secondary server1
--let $rpl_connection_name= server1
--source include/connection.inc

--echo # SELECT data from view to make sure that the data
--echo # got UPDATE-d (on the replica)

--let $diff_tables=server3:p_t1, server1:p_t1, server3:p_t1
--source include/diff_tables.inc

--let $diff_tables=server3:p_t2, server1:p_t2, server3:p_t2
--source include/diff_tables.inc

--echo # Set server1 as primary
--let $server1_uuid= query_get_value(SELECT @@SERVER_UUID, @@SERVER_UUID, 1)
--replace_result $server1_uuid SERVER1_UUID
--eval SELECT group_replication_set_as_primary("$server1_uuid")
--source include/gr_assert_primary_member.inc

DELETE FROM p_dv1
WHERE json_value(data, '$._id') = 2;

--echo ################################################
--echo # Connect to secondary server2

--let $rpl_connection_name= server2
--source include/connection.inc

--echo # SELECT data from view to make sure that the data
--echo # got DELETE-d (on the replica)

--let $diff_tables=server3:p_t1, server1:p_t1, server3:p_t1
--source include/diff_tables.inc

--let $diff_tables=server3:p_t2, server1:p_t2, server3:p_t2
--source include/diff_tables.inc

--echo ################################################
--echo # Cleanup

--echo # Connect to server1
--let $rpl_connection_name= server1
--source include/connection.inc

DROP VIEW p_dv1;
DROP TABLE p_t1, p_t2;

# Wait for synchronization between the nodes.
--source include/rpl/sync.inc
--source include/group_replication_end.inc
--echo ################################################
