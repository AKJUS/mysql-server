################################################################################
# This test is to verify that SYSTEM_VARIABLES_ADMIN is needed to set the
# component variables.
#
# 0. The test requires one server. Check that there are no persisted variables.
# 1. Create an user which lacks privileges.
# 2. Expect ER_SPECIFIC_ACCESS_DENIED_ERROR when setting
#    group_replication_resource_manager
#    global variables since user lacks SUPER or
#    SYSTEM_VARIABLES_ADMIN privileges.
# 3. Grant SYSTEM_VARIABLES_ADMIN and verify setting
#    group_replication_resource_manager
#    variables at global scope succeed.
# 4. Clean up.
################################################################################
--source include/have_group_replication_resource_manager.inc


--echo
--echo ############################################################
--echo # 1. Create an user which lacks privileges.

RESET PERSIST;
INSTALL COMPONENT 'file://component_group_replication_resource_manager';

--let $assert_text= 'Expect 0 persisted variables.'
--let $assert_cond= [SELECT COUNT(*) as count FROM performance_schema.persisted_variables, count, 1] = 0
--source include/assert.inc

CREATE USER 'no_priv_user'@localhost IDENTIFIED BY '';
GRANT ALL ON *.* TO 'no_priv_user'@localhost;
--disable_warnings
REVOKE SUPER, SYSTEM_VARIABLES_ADMIN, SESSION_VARIABLES_ADMIN ON *.* FROM 'no_priv_user'@localhost;
--enable_warnings

--echo
--echo ############################################################
--echo # 2. Expect ER_SPECIFIC_ACCESS_DENIED_ERROR when setting
--echo #    group_replication_resource_manager
--echo #    global variables since user lacks SUPER or
--echo #    SYSTEM_VARIABLES_ADMIN privileges.

CREATE TABLE gr_vars (id INT PRIMARY KEY AUTO_INCREMENT, var_name VARCHAR(64), var_value VARCHAR(256));
INSERT INTO gr_vars (var_name, var_value)
 SELECT * FROM performance_schema.global_variables
 WHERE VARIABLE_NAME LIKE 'group_replication_resource_manager%'
 ORDER BY VARIABLE_NAME;

--let $count_vars= `SELECT COUNT(*) FROM gr_vars;`

--connect (no_priv_user_con,localhost,no_priv_user,,test,$MASTER_MYPORT,,)
--connection no_priv_user_con

--echo
--echo # Expect ER_SPECIFIC_ACCESS_DENIED_ERROR for global variables.
--let $var_id=1
while ( $var_id <= $count_vars )
{
  --let $var_names= `SELECT var_name FROM gr_vars WHERE id=$var_id`
  --error ER_SPECIFIC_ACCESS_DENIED_ERROR
  --eval SET GLOBAL $var_names = @@GLOBAL.$var_names
  --inc $var_id
}

--echo
--echo ############################################################
--echo # 3. Grant SYSTEM_VARIABLES_ADMIN and SESSION_VARIABLES_ADMIN,
--echo #    verify setting group_replication_resource_manager
--echo #    variables at global scope succeed.

--connection default
GRANT SYSTEM_VARIABLES_ADMIN, SESSION_VARIABLES_ADMIN ON *.* TO 'no_priv_user'@localhost;

--connection no_priv_user_con
--echo
--let $var_id=1
while ( $var_id <= $count_vars )
{
  --let $var_names= `SELECT var_name FROM gr_vars WHERE id=$var_id`
  --eval SET GLOBAL $var_names = @@GLOBAL.$var_names
  --inc $var_id
}

--echo
--echo ############################################################
--echo # 4. Clean up.
--connection default

--disconnect no_priv_user_con
--let $count_vars=
--let $var_id=
--let $var_names=

DROP TABLE gr_vars;
REVOKE ALL PRIVILEGES, GRANT OPTION FROM 'no_priv_user'@localhost;
DROP USER 'no_priv_user'@localhost;
UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
