
############################################################
# 1. Create an user which lacks privileges.
RESET PERSIST;
INSTALL COMPONENT 'file://component_group_replication_resource_manager';
include/assert.inc ['Expect 0 persisted variables.']
CREATE USER 'no_priv_user'@localhost IDENTIFIED BY '';
GRANT ALL ON *.* TO 'no_priv_user'@localhost;
REVOKE SUPER, SYSTEM_VARIABLES_ADMIN, SESSION_VARIABLES_ADMIN ON *.* FROM 'no_priv_user'@localhost;

############################################################
# 2. Expect ER_SPECIFIC_ACCESS_DENIED_ERROR when setting
#    group_replication_resource_manager
#    global variables since user lacks SUPER or
#    SYSTEM_VARIABLES_ADMIN privileges.
CREATE TABLE gr_vars (id INT PRIMARY KEY AUTO_INCREMENT, var_name VARCHAR(64), var_value VARCHAR(256));
INSERT INTO gr_vars (var_name, var_value)
SELECT * FROM performance_schema.global_variables
WHERE VARIABLE_NAME LIKE 'group_replication_resource_manager%'
 ORDER BY VARIABLE_NAME;

# Expect ER_SPECIFIC_ACCESS_DENIED_ERROR for global variables.
SET GLOBAL group_replication_resource_manager.applier_channel_lag = @@GLOBAL.group_replication_resource_manager.applier_channel_lag;
ERROR 42000: Access denied; you need (at least one of) the SUPER or SYSTEM_VARIABLES_ADMIN privilege(s) for this operation
SET GLOBAL group_replication_resource_manager.memory_used_limit = @@GLOBAL.group_replication_resource_manager.memory_used_limit;
ERROR 42000: Access denied; you need (at least one of) the SUPER or SYSTEM_VARIABLES_ADMIN privilege(s) for this operation
SET GLOBAL group_replication_resource_manager.quarantine_time = @@GLOBAL.group_replication_resource_manager.quarantine_time;
ERROR 42000: Access denied; you need (at least one of) the SUPER or SYSTEM_VARIABLES_ADMIN privilege(s) for this operation
SET GLOBAL group_replication_resource_manager.recovery_channel_lag = @@GLOBAL.group_replication_resource_manager.recovery_channel_lag;
ERROR 42000: Access denied; you need (at least one of) the SUPER or SYSTEM_VARIABLES_ADMIN privilege(s) for this operation

############################################################
# 3. Grant SYSTEM_VARIABLES_ADMIN and SESSION_VARIABLES_ADMIN,
#    verify setting group_replication_resource_manager
#    variables at global scope succeed.
GRANT SYSTEM_VARIABLES_ADMIN, SESSION_VARIABLES_ADMIN ON *.* TO 'no_priv_user'@localhost;

SET GLOBAL group_replication_resource_manager.applier_channel_lag = @@GLOBAL.group_replication_resource_manager.applier_channel_lag;
SET GLOBAL group_replication_resource_manager.memory_used_limit = @@GLOBAL.group_replication_resource_manager.memory_used_limit;
SET GLOBAL group_replication_resource_manager.quarantine_time = @@GLOBAL.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_resource_manager.recovery_channel_lag = @@GLOBAL.group_replication_resource_manager.recovery_channel_lag;

############################################################
# 4. Clean up.
DROP TABLE gr_vars;
REVOKE ALL PRIVILEGES, GRANT OPTION FROM 'no_priv_user'@localhost;
DROP USER 'no_priv_user'@localhost;
UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
