include/group_replication.inc [rpl_server_count=3]
Warnings:
Note	####	Sending passwords in plain text without SSL/TLS is extremely insecure.
Note	####	Storing MySQL user name or password information in the connection metadata repository is not secure and is therefore not recommended. Please consider using the USER and PASSWORD connection options for START REPLICA; see the 'START REPLICA Syntax' in the MySQL Manual for more information.
[connection server1]

############################################################
# 1. Install component and bootstrap group with member M1
[connection server1]
INSTALL COMPONENT 'file://component_group_replication_elect_prefers_most_updated';
include/start_and_bootstrap_group_replication.inc
SELECT * FROM performance_schema.global_status WHERE VARIABLE_NAME LIKE '%most_uptodate%';
VARIABLE_NAME	VARIABLE_VALUE
Gr_latest_primary_election_by_most_uptodate_member_timestamp	
Gr_latest_primary_election_by_most_uptodate_members_trx_delta	0

############################################################
# 2. Install component, join to group member M2 and increase
#    to have highest priority on primary election
[connection server2]
INSTALL COMPONENT 'file://component_group_replication_elect_prefers_most_updated';
SET @member_weight2_save= @@GLOBAL.group_replication_member_weight;
SET GLOBAL group_replication_member_weight= 90;
include/start_group_replication.inc
SELECT * FROM performance_schema.global_status WHERE VARIABLE_NAME LIKE '%most_uptodate%';
VARIABLE_NAME	VARIABLE_VALUE
Gr_latest_primary_election_by_most_uptodate_member_timestamp	
Gr_latest_primary_election_by_most_uptodate_members_trx_delta	0

############################################################
# 3. Force member to suspend applying transactions until
#    sending an unblock signal
SET @@GLOBAL.DEBUG='+d,group_replication_before_apply_data_packet';

############################################################
# 4. Install component and join to group member M3
[connection server3]
INSTALL COMPONENT 'file://component_group_replication_elect_prefers_most_updated';
include/start_group_replication.inc
SELECT * FROM performance_schema.global_status WHERE VARIABLE_NAME LIKE '%most_uptodate%';
VARIABLE_NAME	VARIABLE_VALUE
Gr_latest_primary_election_by_most_uptodate_member_timestamp	
Gr_latest_primary_election_by_most_uptodate_members_trx_delta	0

############################################################
# 5. Insert transactions on the group and confirm twenty
#    entries
[connection server1]
set sql_log_bin=0;
call mtr.add_suppression("Error in Log_event::read_log_event()");
set sql_log_bin=1;
CREATE TABLE t1(a int primary key);
CREATE PROCEDURE dml_operations()
BEGIN
declare x INT;
set x=1;
while x<=48 do
insert into t1 values (x);
set x=x+1;
end  while;
end$$

----call procedure----
call dml_operations();

[connection server_1]

############################################################
# 6. Force member to error out when using most
#    uptodate primary election method
[connection server3]
# Adding debug point 'group_replication_primary_election_most_uptodate_fail' to @@GLOBAL.debug

############################################################
# 7. Force a failover primary election by restarting primary
[connection server_1]
# killing
# Kill and restart:--group_replication_local_address=GROUP_REPLICATION_LOCAL_ADDRESS --group_replication_group_seeds=GROUP_REPLICATION_GROUP_SEEDS --group_replication_group_name=GROUP_REPLICATION_GROUP_NAME --group_replication_single_primary_mode=TRUE --group_replication_enforce_update_everywhere_checks=FALSE
# restarting
[connection server_1]
include/rpl/reconnect.inc
[connection server2]
# check that there are 2 members in the group
include/rpl/gr_wait_for_number_of_members.inc

############################################################
# 8. Unblock M2 from applying transactions
SET @@GLOBAL.DEBUG='-d,group_replication_before_apply_data_packet';
SET DEBUG_SYNC='now SIGNAL continue_apply';

############################################################
# 9. Remove debug point that make most uptodate method fail
[connection server3]
# Removing debug point 'group_replication_primary_election_most_uptodate_fail' from @@GLOBAL.debug

############################################################
# 10. Primary election fail on M3 and it will change state
#     to error
include/gr_wait_for_member_state.inc

############################################################
# 11. Confirm global status variables are still on defaults,
#     call to service failed.
SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_latest_primary_election_by_most_uptodate_members_trx_delta";
VARIABLE_VALUE
0
SELECT VARIABLE_VALUE FROM performance_schema.global_status WHERE VARIABLE_NAME="Gr_latest_primary_election_by_most_uptodate_member_timestamp";
VARIABLE_VALUE


############################################################
# 12. Confirm global status variables were updated due usage
#     of most up to date primary election method
[connection server2]
include/assert.inc ['At least twenty transactions delta from two members']
include/assert.inc ['Time of last use of most up-to-date usage is not empty']

############################################################
# 13. M2 will be primary after M3 leave group on failure

############################################################
# 14. Confirm error log contain message that states most
#     uptodate method was used to elect new primary
[connection server3]
include/assert_grep.inc [Server 3 do not use most uptodate method, it fails to elect new primary.]
[connection server2]
include/assert_grep.inc [Server 2 used most uptodate method to elect new primary.]

############################################################
# 15. Cleanup
[connection server1]
DROP TABLE t1;
DROP PROCEDURE dml_operations;
UNINSTALL COMPONENT 'file://component_group_replication_elect_prefers_most_updated';
[connection server2]
include/stop_group_replication.inc
SET GLOBAL SUPER_READ_ONLY=OFF;
UNINSTALL COMPONENT 'file://component_group_replication_elect_prefers_most_updated';
SET GLOBAL group_replication_member_weight= @member_weight2_save;
SET GLOBAL SUPER_READ_ONLY=ON;
[connection server3]
include/stop_group_replication.inc
SET GLOBAL SUPER_READ_ONLY=OFF;
UNINSTALL COMPONENT 'file://component_group_replication_elect_prefers_most_updated';
set session sql_log_bin=0;
call mtr.add_suppression("There was an issue when cloning from another server: Error number: 1317 Error message: Query execution was interrupted'");
call mtr.add_suppression("Fatal error during the primary election process of Group Replication. The server will leave the group.");
call mtr.add_suppression("The server was automatically set into read only mode after an error was detected.");
call mtr.add_suppression("While leaving the group due to a stop, shutdown or failure there was a timeout receiving a view change. This can lead to a possible inconsistent state. Check the log for more details");
call mtr.add_suppression("The server was automatically set into offline mode after an error was detected.");
set session sql_log_bin=1;
SET GLOBAL SUPER_READ_ONLY=ON;
include/group_replication_end.inc
