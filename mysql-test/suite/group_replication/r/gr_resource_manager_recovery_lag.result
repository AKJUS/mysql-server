include/group_replication.inc [rpl_server_count=3]
Warnings:
Note	####	Sending passwords in plain text without SSL/TLS is extremely insecure.
Note	####	Storing MySQL user name or password information in the connection metadata repository is not secure and is therefore not recommended. Please consider using the USER and PASSWORD connection options for START REPLICA; see the 'START REPLICA Syntax' in the MySQL Manual for more information.
[connection server1]

#########################################################
# 1. Install component group_replication_resource_manager on M1, M2 and M3.
#    Start group replication on M1, M2 and M3.
#    Set group_replication_autorejoin_tries to 0.
[connection server1]
INSTALL COMPONENT 'file://component_group_replication_resource_manager';
SET @autorejoin_retry= @@global.group_replication_autorejoin_tries;
SET @quarantine_time= @@global.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_autorejoin_tries = 0;
SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
include/start_and_bootstrap_group_replication.inc
[connection server2]
SET SESSION sql_log_bin= 0;
call mtr.add_suppression("Member threshold exceeded: recovery channel lag.*. However, the group has less than 3 members, the member will not leave the group.");
SET SESSION sql_log_bin= 1;
INSTALL COMPONENT 'file://component_group_replication_resource_manager';
SET @autorejoin_retry= @@global.group_replication_autorejoin_tries;
SET @quarantine_time= @@global.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_autorejoin_tries = 0;
SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
include/start_group_replication.inc
[connection server3]
SET SESSION sql_log_bin= 0;
call mtr.add_suppression("The server was automatically set into read only mode after an error was detected.");
call mtr.add_suppression("The server was automatically set into offline mode after an error was detected.");
call mtr.add_suppression("Skipping leave operation: concurrent attempt to leave the group is on-going.");
call mtr.add_suppression("Member exiting group: recovery channel lag.*");
SET SESSION sql_log_bin= 1;
INSTALL COMPONENT 'file://component_group_replication_resource_manager';
SET @autorejoin_retry= @@global.group_replication_autorejoin_tries;
SET @quarantine_time= @@global.group_replication_resource_manager.quarantine_time;
SET GLOBAL group_replication_autorejoin_tries = 0;
SET GLOBAL group_replication_resource_manager.quarantine_time = 0;
include/start_group_replication.inc

#########################################################
# 2. Set debug point on M1 to return lag.
[connection server1]
SET @@GLOBAL.DEBUG= '+d,GR_RM_recovery_force_lag';
SET @queue_lag= @@global.group_replication_resource_manager.recovery_channel_lag;
SET @@GLOBAL.group_replication_resource_manager.recovery_channel_lag=1;

#########################################################
# 3. Since recovery lag was returned, component is expected to make the M1
#    leave the group.
#    However M1 is primary in the group so member will not leave the group.
[connection server1]
include/assert.inc ['Eviction timestamp is not set.']
include/assert.inc ['There are no applier channel threshold hits.']
include/assert.inc ['Lag is 0.']
include/gr_wait_for_member_state.inc

#########################################################
# 4. Assert Gr_resource_manager_recovery_channel_eviction_timestamp
#    and Gr_resource_manager_recovery_channel_threshold_hits
#    are not set on M3, that is, none of the previous steps
#    impacted it.
[connection server3]
include/assert.inc ['Eviction timestamp is not set.']
include/assert.inc ['There are no applier channel threshold hits.']
include/assert.inc ['Lag is 0.']

#########################################################
# 5. Set debug point on M3 to return lag.
SET @queue_lag= @@global.group_replication_resource_manager.recovery_channel_lag;
SET @@GLOBAL.group_replication_resource_manager.recovery_channel_lag=1;
SET @@GLOBAL.DEBUG= '+d,GR_RM_recovery_force_lag';

#########################################################
# 6. Since recovery lag was returned, component will make the M3
#    leave the group and move it to ERROR state.
[connection server3]
include/gr_wait_for_member_state.inc

#########################################################
# 7. Assert Gr_resource_manager_recovery_channel_eviction_timestamp
#    and Gr_resource_manager_recovery_channel_threshold_hits
#    are set. Lag will be 1000 or 0.
'Eviction timestamp is set.'
include/assert.inc ['There are no applier channel threshold hits.']
include/assert.inc ['Lag is 1000 or 0.']
SET @@GLOBAL.DEBUG= '-d,GR_RM_recovery_force_lag';

#########################################################
# 8. Stop M3.
[connection server3]
include/stop_group_replication.inc

#########################################################
# 9. Set debug point on M2 to return lag.
[connection server2]
SET @@GLOBAL.DEBUG= '+d,GR_RM_recovery_force_lag';
SET @queue_lag= @@global.group_replication_resource_manager.recovery_channel_lag;
SET @@GLOBAL.group_replication_resource_manager.recovery_channel_lag=1;

#########################################################
# 10. Since recovery lag was returned, component is expected to make the M2
#    leave the group.
#    However only 2 members are present in the group so member will not leave the group.
[connection server2]
'There are recovery channel threshold hits.'
include/assert.inc ['Eviction timestamp is not set.']
include/assert.inc ['Lag is 1000.']
include/gr_wait_for_member_state.inc
############################################################
# 11. Cleanup
[connection server3]
SET @@global.group_replication_resource_manager.recovery_channel_lag = @queue_lag;
SET @@global.group_replication_autorejoin_tries = @autorejoin_retry;
SET @@global.group_replication_resource_manager.quarantine_time = @quarantine_time;
UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
[connection server2]
include/stop_group_replication.inc
SET @@global.group_replication_resource_manager.recovery_channel_lag = @queue_lag;
SET @@global.group_replication_autorejoin_tries = @autorejoin_retry;
SET @@global.group_replication_resource_manager.quarantine_time = @quarantine_time;
SET @@GLOBAL.DEBUG= '-d,GR_RM_recovery_force_lag';
UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
[connection server1]
include/stop_group_replication.inc
SET @@global.group_replication_resource_manager.recovery_channel_lag = @queue_lag;
SET @@global.group_replication_autorejoin_tries = @autorejoin_retry;
SET @@global.group_replication_resource_manager.quarantine_time = @quarantine_time;
SET @@GLOBAL.DEBUG= '-d,GR_RM_recovery_force_lag';
UNINSTALL COMPONENT 'file://component_group_replication_resource_manager';
include/group_replication_end.inc
