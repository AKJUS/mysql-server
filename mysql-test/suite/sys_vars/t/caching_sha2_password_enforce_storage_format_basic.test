# Save the initial number of concurrent sessions
--source include/count_sessions.inc

--let SAVED_ENFORCE_STORAGE_FORMAT=`SELECT @@global.caching_sha2_password_enforce_storage_format`

# Global
SET GLOBAL caching_sha2_password_enforce_storage_format = 1;
SET GLOBAL caching_sha2_password_enforce_storage_format = 0;

# Persist only
SET PERSIST_ONLY caching_sha2_password_enforce_storage_format = 1;
SELECT @@global.caching_sha2_password_enforce_storage_format;

# Persistance
SET PERSIST caching_sha2_password_enforce_storage_format = 1;
SELECT @@global.caching_sha2_password_enforce_storage_format;

RESET PERSIST caching_sha2_password_enforce_storage_format;
SELECT @@global.caching_sha2_password_enforce_storage_format;

# Default
SET GLOBAL caching_sha2_password_enforce_storage_format = DEFAULT;

# Session value
--error ER_GLOBAL_VARIABLE
SET caching_sha2_password_enforce_storage_format = 1;
--error ER_GLOBAL_VARIABLE
SET caching_sha2_password_enforce_storage_format = 0;

# Invaid value
--error ER_WRONG_VALUE_FOR_VAR
SET GLOBAL caching_sha2_password_enforce_storage_format = "haha";

# Clean up
--eval SET GLOBAL caching_sha2_password_enforce_storage_format=$SAVED_ENFORCE_STORAGE_FORMAT
# Wait for initial session count
--source include/wait_until_count_sessions.inc
