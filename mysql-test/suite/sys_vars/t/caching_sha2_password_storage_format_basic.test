# Save the initial number of concurrent sessions
--source include/count_sessions.inc

--let SAVED_PASSWORD_STORAGE_FORMAT=`SELECT @@global.caching_sha2_password_storage_format`

--echo
# default: CRYPT5
SELECT @@global.caching_sha2_password_storage_format;
CREATE USER foo IDENTIFIED WITH caching_sha2_password BY 'abcd';
SELECT SUBSTRING(authentication_string, 1, 3) AS length FROM mysql.user WHERE user='foo';
DROP USER foo;

# Other format
SET GLOBAL caching_sha2_password_storage_format="PBKDF2_SHA512";
SELECT @@global.caching_sha2_password_storage_format;
CREATE USER foo IDENTIFIED WITH caching_sha2_password BY 'abcd';
SELECT SUBSTRING(authentication_string, 1, 3) AS length FROM mysql.user WHERE user='foo';
DROP USER foo;

# Persist only
SET PERSIST_ONLY caching_sha2_password_storage_format="CRYPT5";
SELECT @@global.caching_sha2_password_storage_format;
CREATE USER foo IDENTIFIED WITH caching_sha2_password BY 'abcd';
SELECT SUBSTRING(authentication_string, 1, 3) AS length FROM mysql.user WHERE user='foo';
DROP USER foo;
--source include/restart_mysqld.inc
SELECT @@global.caching_sha2_password_storage_format;
CREATE USER foo IDENTIFIED WITH caching_sha2_password BY 'abcd';
SELECT SUBSTRING(authentication_string, 1, 3) AS length FROM mysql.user WHERE user='foo';
DROP USER foo;

# Persistance
SET PERSIST caching_sha2_password_storage_format="PBKDF2_SHA512";
--source include/restart_mysqld.inc
SELECT @@global.caching_sha2_password_storage_format;
CREATE USER foo IDENTIFIED WITH caching_sha2_password BY 'abcd';
SELECT SUBSTRING(authentication_string, 1, 3) AS length FROM mysql.user WHERE user='foo';
DROP USER foo;

# Back to default
RESET PERSIST caching_sha2_password_storage_format;
--source include/restart_mysqld.inc
SELECT @@global.caching_sha2_password_storage_format;
CREATE USER foo IDENTIFIED WITH caching_sha2_password BY 'abcd';
SELECT SUBSTRING(authentication_string, 1, 3) AS length FROM mysql.user WHERE user='foo';
DROP USER foo;

# Session value
--error ER_GLOBAL_VARIABLE
SET caching_sha2_password_storage_format="PBKDF2_SHA512";
--error ER_GLOBAL_VARIABLE
SET caching_sha2_password_storage_format="CRYPT5";

# Invalid values
--error ER_WRONG_VALUE_FOR_VAR
SET GLOBAL caching_sha2_password_storage_format="PBKDF2";
SELECT @@global.caching_sha2_password_storage_format;
--error ER_WRONG_VALUE_FOR_VAR
SET GLOBAL caching_sha2_password_storage_format="haha";
SELECT @@global.caching_sha2_password_storage_format;

SET GLOBAL caching_sha2_password_storage_format="PBKDF2_SHA512";

--error ER_WRONG_VALUE_FOR_VAR
SET GLOBAL caching_sha2_password_storage_format="PBKDF2";
SELECT @@global.caching_sha2_password_storage_format;
--error ER_WRONG_VALUE_FOR_VAR
SET GLOBAL caching_sha2_password_storage_format="haha";
SELECT @@global.caching_sha2_password_storage_format;

# Revert to initial setting

--eval SET GLOBAL caching_sha2_password_storage_format='$SAVED_PASSWORD_STORAGE_FORMAT'

# Wait for initial session count
--source include/wait_until_count_sessions.inc
