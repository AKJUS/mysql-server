-- source include/rpl/init_source_replica.inc

--echo # WL#17024 Activate triggers on child table during FK cascade
--echo # FR 10 Replication with FK cascade triggers

--echo # FR 10.1: In Row Based Replication mode, triggers must not be executed on
--echo # the replica as a consequence of cascades applied by the applier thread.

--echo # FR 10.2: In Statement Based Replication mode, the binlog applier thread
--echo # in replica node must use the source setting of enable_cascade_triggers
--echo # variable.

--echo # Source sets the session enable_cascade_triggers to ON and performs
--echo # cascading operations on parent table whereas replica uses
--echo # default setting of enable_cascade_triggers(OFF)

--echo #Source
--echo #t1 - Parent table
eval CREATE TABLE t1 (f1 INT PRIMARY KEY) ENGINE=$engine_type;
--echo #t2(f1) -> t1(f1) -  ON DELETE | UPDATE CASCADE
eval CREATE TABLE t2 (f1 INT PRIMARY KEY, f2 INT,
FOREIGN KEY(f1) REFERENCES t1(f1) ON DELETE CASCADE ON UPDATE CASCADE) ENGINE=$engine_type;

eval CREATE TABLE logtable (action VARCHAR(128), oldval INT, newval INT);


INSERT INTO t1 VALUES (10), (20), (30);
INSERT INTO t2 VALUES (10, 10), (20, 20), (30, 30);
SELECT * FROM t1 ORDER BY f1;
SELECT * FROM t2 ORDER BY f1;

delimiter //;
CREATE TRIGGER trg1 AFTER DELETE ON t1
FOR EACH ROW BEGIN
    INSERT INTO logtable VALUES("t1-AFTER-DELETE", OLD.f1, 0);
END//

CREATE TRIGGER trg2 AFTER DELETE ON t2
FOR EACH ROW BEGIN
    SET FOREIGN_KEY_CHECKS = ON;
    INSERT INTO logtable VALUES("t2-AFTER-DELETE", OLD.f2, 0);
END//

CREATE TRIGGER trg3 AFTER UPDATE ON t1
FOR EACH ROW BEGIN
    INSERT INTO logtable VALUES("t1-AFTER-UPDATE", OLD.f1, NEW.f1);
END//

CREATE TRIGGER trg4 AFTER UPDATE ON t2
FOR EACH ROW BEGIN
    SET FOREIGN_KEY_CHECKS = ON;
    INSERT INTO logtable VALUES("t2-AFTER-UPDATE", OLD.f2, NEW.f2);
END//
delimiter ;//

--echo # Update row in t1 and verify that it cascades to t2 correctly on
--echo # both the master and replica.
SET enable_cascade_triggers = ON;
UPDATE t1 SET f1=50 where f1=20;
--echo # Delete a row from t1 and verify that it cascades to t2 correctly on
--echo # both the master and replica.
DELETE FROM t1 where f1=10;
SET enable_cascade_triggers = DEFAULT;

SELECT * FROM t1 ORDER BY f1;
SELECT * FROM t2 ORDER BY f1;
SELECT * FROM logtable;

--source include/rpl/sync_to_replica.inc
--echo #Replica

SELECT * FROM t1 ORDER BY f1;
SELECT * FROM t2 ORDER BY f1;
SELECT * FROM logtable;

connection master;

--let $diff_tables = master:t1, slave:t1
--source include/diff_tables.inc

--let $diff_tables = master:t2, slave:t2
--source include/diff_tables.inc

--let $diff_tables = master:logtable, slave:logtable
--source include/diff_tables.inc

drop table logtable, t2, t1;
--source include/rpl/deinit.inc
