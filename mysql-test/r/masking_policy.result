#
# WL#16525: Dynamic Datamasking Support in MySQL
#
# Test cases for CREATE/DROP/SHOW MASKING POLICY.
CREATE MASKING POLICY mak_pol(i)
CASE WHEN CURRENT_ROLE_IN('admin') THEN sha2('abc', 224) ELSE i END;
ERROR HY000: MASKING POLICY component error: component is unavailable.
CREATE MASKING POLICY IF NOT EXISTS pol_if_not_exists(i)
CASE WHEN CURRENT_ROLE_IN('admin') THEN sha2('abc', 224) ELSE i END;
ERROR HY000: MASKING POLICY component error: component is unavailable.
CREATE MASKING POLICY p1(i)
CASE WHEN CURRENT_USER_IN ('admin, app') THEN sha2('abc', i) ELSE i END;
ERROR HY000: MASKING POLICY component error: component is unavailable.
SHOW CREATE MASKING POLICY p1;
ERROR HY000: MASKING POLICY component error: component is unavailable.
CREATE MASKING POLICY p1_1(i)
CASE WHEN CURRENT_USER_IN('admin, app') THEN sha2('abc', 224) ELSE i END;
ERROR HY000: MASKING POLICY component error: component is unavailable.
SHOW CREATE MASKING POLICY p1_1;
ERROR HY000: MASKING POLICY component error: component is unavailable.
CREATE MASKING POLICY p2(i)
CASE WHEN CURRENT_USER_IN('admin, app') THEN i ELSE sha2('abc', i) END;
ERROR HY000: MASKING POLICY component error: component is unavailable.
SHOW CREATE MASKING POLICY p2;
ERROR HY000: MASKING POLICY component error: component is unavailable.
CREATE MASKING POLICY p2_2(i)
CASE WHEN CURRENT_USER_IN('admin, app') THEN i ELSE sha2('abc', 224) END;
ERROR HY000: MASKING POLICY component error: component is unavailable.
SHOW CREATE MASKING POLICY p2_2;
ERROR HY000: MASKING POLICY component error: component is unavailable.
DROP MASKING POLICY pol_does_not_exist;
ERROR HY000: MASKING POLICY component error: component is unavailable.
DROP MASKING POLICY IF EXISTS pol_does_not_exist;
ERROR HY000: MASKING POLICY component error: component is unavailable.
SHOW CREATE MASKING POLICY pol_does_not_exist;
ERROR HY000: MASKING POLICY component error: component is unavailable.
# Test cases for assigning/unassigning masking policies on columns
# with CREATE TABLE and ALTER TABLE.
CREATE TABLE t1(i VARCHAR(256) MASKING POLICY p1);
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `i` varchar(256) MASKING POLICY `p1` DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
DROP TABLE t1;
CREATE TABLE t2(i VARCHAR(256));
ALTER TABLE t2 ALTER COLUMN i DROP MASKING POLICY;
SHOW CREATE TABLE t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `i` varchar(256) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
ALTER TABLE t2 ALTER COLUMN i SET MASKING POLICY p2;
SHOW CREATE TABLE t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `i` varchar(256) MASKING POLICY `p2` DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
DROP TABLE t2;
CREATE TABLE t1(i VARCHAR(256));
ALTER TABLE t1 ADD COLUMN j VARCHAR(256) MASKING POLICY p1;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `i` varchar(256) DEFAULT NULL,
  `j` varchar(256) MASKING POLICY `p1` DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
DROP TABLE t1;
CREATE TABLE t1(i VARCHAR(256) MASKING POLICY p1);
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `i` varchar(256) MASKING POLICY `p1` DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
DROP TABLE t1;
CREATE TABLE t2(i VARCHAR(256) MASKING POLICY p3);
SHOW CREATE TABLE t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `i` varchar(256) MASKING POLICY `p3` DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
ALTER TABLE t2 ALTER COLUMN i DROP MASKING POLICY;
SHOW CREATE TABLE t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `i` varchar(256) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
ALTER TABLE t2 ALTER COLUMN i SET MASKING POLICY p2;
SHOW CREATE TABLE t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `i` varchar(256) MASKING POLICY `p2` DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
DROP TABLE t2;
CREATE TABLE t1(i VARCHAR(256) MASKING POLICY p1);
ALTER TABLE t1 ADD COLUMN j VARCHAR(256) MASKING POLICY p1;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `i` varchar(256) MASKING POLICY `p1` DEFAULT NULL,
  `j` varchar(256) MASKING POLICY `p1` DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
ALTER TABLE t1 DROP COLUMN j;
DROP TABLE t1;
CREATE TABLE t3(i INT);
ALTER TABLE t3 MODIFY COLUMN i INT MASKING POLICY p1;
SHOW CREATE TABLE t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `i` int MASKING POLICY `p1` DEFAULT NULL
