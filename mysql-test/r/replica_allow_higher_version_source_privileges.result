##
## WL#17202: Allow/disallow asynchronous replication from a higher version source
##
## For different clients, test that REPLICA_ALLOW_HIGHER_VERSION_SOURCE can only be modified by those
## who have REPLICATION_SLAVE_ADMIN plus SYSTEM_VARIABLES_ADMIN or SUPER privileges.
## Of the following, only those with + prefix should be able to modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE:
## - base_session:       having no privileges
## - regular_session:    having SYSTEM_VARIABLES_ADMIN privilege
## - rpl_admin_session:  having REPLICATION_SLAVE_ADMIN privilege
## - power_session:      having SYSTEM_VARIABLES_ADMIN and SYSTEM_USER privileges
## + super_session:      having SUPER privileges
## + admin_session:      having SYSTEM_VARIABLES_ADMIN and REPLICATION_SLAVE_ADMIN privileges
## + superadmin_session: having SYSTEM_VARIABLES_ADMIN and SUPER and REPLICATION_SLAVE_ADMIN privileges
## + sysadmin_session:   having SYSTEM_VARIABLES_ADMIN, REPLICATION_SLAVE_ADMIN, SYSTEM_USER privileges
##
SET @original_REPLICA_ALLOW_HIGHER_VERSION_SOURCE = @@global.REPLICA_ALLOW_HIGHER_VERSION_SOURCE;

### Setup ###

# Create base_session user
CREATE USER base@localhost IDENTIFIED BY 'base';

# Create regular_session user
CREATE USER regular@localhost IDENTIFIED BY 'regular';
GRANT SYSTEM_VARIABLES_ADMIN ON *.* TO regular@localhost;

# Create rpl_admin_session user
CREATE USER rpl_admin@localhost IDENTIFIED BY 'rpl_admin';
GRANT REPLICATION_SLAVE_ADMIN ON *.* TO rpl_admin@localhost;

# Create power_session user
CREATE USER power@localhost IDENTIFIED BY 'power';
GRANT SYSTEM_USER, SYSTEM_VARIABLES_ADMIN ON *.* TO power@localhost;

# Create super_session user
CREATE USER super@localhost IDENTIFIED BY 'super';
GRANT SUPER ON *.* TO super@localhost;
Warnings:
Warning	1287	The SUPER privilege identifier is deprecated

# Create admin_session user
CREATE USER admin@localhost IDENTIFIED BY 'admin';
GRANT SYSTEM_VARIABLES_ADMIN, REPLICATION_SLAVE_ADMIN ON *.* TO admin@localhost;

# Create superadmin_session user
CREATE USER superadmin@localhost IDENTIFIED BY 'superadmin';
GRANT SYSTEM_VARIABLES_ADMIN, REPLICATION_SLAVE_ADMIN, SUPER ON *.* TO superadmin@localhost;
Warnings:
Warning	1287	The SUPER privilege identifier is deprecated

# Create sysadmin_session user (max privileges)
CREATE USER sysadmin@localhost IDENTIFIED BY 'sysadmin';
GRANT SYSTEM_VARIABLES_ADMIN, REPLICATION_SLAVE_ADMIN, SYSTEM_USER ON *.* TO sysadmin@localhost;

## TEST 1: base_session can not modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=ON;
ERROR 42000: Access denied; you need (at least one of) the SUPER or SYSTEM_VARIABLES_ADMIN privilege(s) for this operation

## TEST 2: regular_session can not modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=ON;
ERROR 42000: Access denied; you need (at least one of) the SYSTEM_VARIABLES_ADMIN plus REPLICATION_SLAVE_ADMIN, or SUPER privilege(s) for this operation

## TEST 3: rpl_admin_session can not modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=ON;
ERROR 42000: Access denied; you need (at least one of) the SUPER or SYSTEM_VARIABLES_ADMIN privilege(s) for this operation

## TEST 4: power_session can not modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=ON;
ERROR 42000: Access denied; you need (at least one of) the SYSTEM_VARIABLES_ADMIN plus REPLICATION_SLAVE_ADMIN, or SUPER privilege(s) for this operation

## TEST 5: super_session can modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=ON;

## TEST 6: admin_session can modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=OFF;

## TEST 7: superadmin_session can modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=ON;

## TEST 8: sysadmin_session can modify REPLICA_ALLOW_HIGHER_VERSION_SOURCE

SET GLOBAL REPLICA_ALLOW_HIGHER_VERSION_SOURCE=OFF;

# CLEAN UP

DROP USER base@localhost;
DROP USER regular@localhost;
DROP USER rpl_admin@localhost;
DROP USER power@localhost;
DROP USER super@localhost;
DROP USER admin@localhost;
DROP USER superadmin@localhost;
DROP USER sysadmin@localhost;
SET @@global.REPLICA_ALLOW_HIGHER_VERSION_SOURCE = @original_REPLICA_ALLOW_HIGHER_VERSION_SOURCE;
