# SET optimizer_switch fails with ER_HYPERGRAPH_NOT_SUPPORTED_YET
# Error text should mention WITH_HYPERGRAPH_OPTIMIZER=OFF
SET SESSION optimizer_switch='hypergraph_optimizer=on';
ERROR 42000: The hypergraph optimizer does not yet support 'this build configuration; to enable it, build with CMake option WITH_HYPERGRAPH_OPTIMIZER=ON'
SET GLOBAL optimizer_switch='hypergraph_optimizer=on';
ERROR 42000: The hypergraph optimizer does not yet support 'this build configuration; to enable it, build with CMake option WITH_HYPERGRAPH_OPTIMIZER=ON'
SET PERSIST optimizer_switch='hypergraph_optimizer=on';
ERROR 42000: The hypergraph optimizer does not yet support 'this build configuration; to enable it, build with CMake option WITH_HYPERGRAPH_OPTIMIZER=ON'
# SET PERSIST fails on repeated attempts
SET PERSIST optimizer_switch='hypergraph_optimizer=on';
ERROR 42000: The hypergraph optimizer does not yet support 'this build configuration; to enable it, build with CMake option WITH_HYPERGRAPH_OPTIMIZER=ON'
# SET_VAR should execute but produce warning
CREATE TABLE t1 (a INT PRIMARY KEY, b INT);
CREATE TABLE t2 (a INT PRIMARY KEY, c INT);
INSERT INTO t1 VALUES (1,10),(2,20),(3,30);
INSERT INTO t2 VALUES (1,100),(2,200),(4,400);
SELECT /*+ SET_VAR(optimizer_switch='hypergraph_optimizer=on') */ t1.a
FROM t1 JOIN t2 ON t1.a=t2.a
WHERE t1.b >= 20;
SHOW WARNINGS;
Level	Code	Message
Warning	3999	The hypergraph optimizer does not yet support 'this build configuration; to enable it, build with CMake option WITH_HYPERGRAPH_OPTIMIZER=ON'
# Hypergraph optimizer should not be used when compiled out
SET SESSION optimizer_trace='enabled=on';
SET SESSION optimizer_trace_max_mem_size=1048576;
SELECT /*+ SET_VAR(optimizer_switch='hypergraph_optimizer=on') */ t1.a
FROM t1 JOIN t2 ON t1.a=t2.a
WHERE t1.b >= 20;
# Expect COUNT(*) = 0 (no 'Constructed hypergraph' marker)
SELECT COUNT(*)
FROM INFORMATION_SCHEMA.OPTIMIZER_TRACE
WHERE TRACE LIKE '%Constructed hypergraph%';
COUNT(*)
0
DROP TABLE t2;
DROP TABLE t1;
