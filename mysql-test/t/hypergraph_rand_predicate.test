--source include/have_hypergraph.inc

#
# Bug#38866140: Inconsistent row counts assertion with RAND
#              predicates in hypergraph optimizer
#
# Non-deterministic predicates (containing RAND() etc.) must not be
# pushed down from the WHERE clause into join conditions, as that
# turns them into hypergraph join edges. Since these predicates are
# excluded from delayed_predicates (Bug#36032958), using one as a
# join edge creates an asymmetry in row count estimates between
# different access paths for the same set of tables.
#
# All tests below verify no assertion failure during optimization.
# RAND() makes query results non-deterministic, so we suppress
# result comparison for SELECT statements.
#

CREATE TABLE t (i INT);
INSERT INTO t VALUES (1), (2), (3);
ANALYZE TABLE t;

CREATE TABLE t1 (
  col_date3 DATE DEFAULT NULL,
  col_int INT DEFAULT NULL,
  col_datetime6 DATETIME DEFAULT NULL,
  col_tinytext_character_set_utf8mb4_key TINYTEXT
);
INSERT INTO t1 VALUES
  ('2024-01-01', 1, '2024-01-01 00:00:00', 'abc'),
  ('2024-02-01', 2, '2024-02-01 00:00:00', 'def'),
  ('2024-03-01', 3, '2024-03-01 00:00:00', 'ghi');
ANALYZE TABLE t1;

#
# Test 1: Simplified reproducer.
# RAND() in a WHERE predicate between two tables (3-table inner join).
#
--disable_result_log
SELECT 1 FROM t AS t1, t AS t2, t AS t3
WHERE t1.i <> t2.i AND t2.i = t3.i + RAND() AND t1.i <> t3.i;
--enable_result_log

#
# Test 2: Original bug report query.
# RAND() in an ON clause of an outer join spanning multiple join nests.
#
--disable_result_log
SELECT table2.col_date3 AS field2
FROM t1 AS table1
RIGHT JOIN t1 AS table2
  LEFT JOIN t1 AS table3 ON table2.col_date3 <> table3.col_int
ON REPLACE(table1.col_date3, '', RAND(table3.col_int))
   LIKE table3.col_tinytext_character_set_utf8mb4_key
WHERE table1.col_tinytext_character_set_utf8mb4_key >
      table2.col_tinytext_character_set_utf8mb4_key;
--enable_result_log

#
# Test 3: RAND() in ON clause of explicit INNER JOIN.
# Inner join ON conditions get flattened into WHERE during
# hypergraph construction, exercising the same pushdown path.
#
--disable_result_log
SELECT 1 FROM t AS t1
INNER JOIN t AS t2 ON t1.i <> t2.i
INNER JOIN t AS t3 ON t2.i = t3.i + RAND()
WHERE t1.i <> t3.i;
--enable_result_log

#
# Test 4: RAND() as the ONLY predicate between a specific table pair.
# 4 tables: t2↔t3 connected only by RAND, but alternative deterministic
# path exists via t2↔t4↔t3. This creates multiple ways to reach the
# subgraph {t2,t3,t4}, triggering the row count comparison.
#
--disable_result_log
SELECT 1 FROM t AS t1, t AS t2, t AS t3, t AS t4
WHERE t1.i <> t2.i
  AND t2.i <> t4.i
  AND t3.i <> t4.i
  AND t2.i = t3.i + RAND();
--enable_result_log

#
# Test 5: Multiple RAND predicates in the same query.
# Two RAND predicates plus two deterministic edges create enough
# path alternatives for the row count comparison to fire.
#
--disable_result_log
SELECT 1 FROM t AS t1, t AS t2, t AS t3
WHERE t1.i + RAND() = t2.i
  AND t2.i + RAND() = t3.i
  AND t1.i <> t3.i
  AND t1.i <> t2.i;
--enable_result_log

#
# Test 6: RAND() with 4 tables.
# Bigger hypergraph, RAND predicate spans middle tables.
#
--disable_result_log
SELECT 1 FROM t AS t1, t AS t2, t AS t3, t AS t4
WHERE t1.i <> t2.i
  AND t2.i = t3.i + RAND()
  AND t3.i <> t4.i
  AND t1.i <> t4.i;
--enable_result_log

#
# Test 7: RAND() in LEFT JOIN ON clause with 3 tables.
# The ON clause RAND is an actual join condition
# (is_join_condition_for_expr=true), which the fix intentionally
# does NOT block. Adding a third table with deterministic edges
# creates multiple join paths, verifying no assertion fires.
#
--disable_result_log
SELECT * FROM t AS t1
INNER JOIN t AS t3 ON t1.i <> t3.i
LEFT JOIN t AS t2 ON t1.i = t2.i + RAND()
WHERE t2.i IS NULL OR t2.i <> t3.i;
--enable_result_log

#
# Test 8: RAND() combined with a deterministic predicate in WHERE.
# The deterministic part should still become a join edge normally;
# only the RAND predicate stays as a final filter.
#
--disable_result_log
SELECT 1 FROM t AS t1, t AS t2, t AS t3
WHERE t1.i = t2.i AND t2.i = t3.i + RAND() AND t1.i <> t3.i;
--enable_result_log

#
# Test 9: Non-RAND nondeterministic function (UUID_SHORT).
# The fix uses is_non_deterministic() which checks RAND_TABLE_BIT.
# UUID_SHORT() also sets RAND_TABLE_BIT, so the same fix must
# prevent it from becoming a join edge.
#
--disable_result_log
SELECT 1 FROM t AS t1, t AS t2, t AS t3
WHERE t1.i <> t2.i AND t2.i = t3.i + UUID_SHORT() AND t1.i <> t3.i;
--enable_result_log

# Cleanup
DROP TABLE t, t1;

--source include/disable_hypergraph.inc
