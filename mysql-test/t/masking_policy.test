--echo #
--echo # WL#16525: Dynamic Datamasking Support in MySQL
--echo #

--echo # Test cases for CREATE/DROP/SHOW MASKING POLICY.

--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY mak_pol(i)
  CASE WHEN CURRENT_ROLE_IN('admin') THEN sha2('abc', 224) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY IF NOT EXISTS pol_if_not_exists(i)
  CASE WHEN CURRENT_ROLE_IN('admin') THEN sha2('abc', 224) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p1(i)
  CASE WHEN CURRENT_USER_IN ('admin, app') THEN sha2('abc', i) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p1;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p1_1(i)
  CASE WHEN CURRENT_USER_IN('admin, app') THEN sha2('abc', 224) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p1_1;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p2(i)
  CASE WHEN CURRENT_USER_IN('admin, app') THEN i ELSE sha2('abc', i) END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p2;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p2_2(i)
  CASE WHEN CURRENT_USER_IN('admin, app') THEN i ELSE sha2('abc', 224) END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p2_2;
--error ER_MASKING_POLICY_COMPONENT_ERROR
DROP MASKING POLICY pol_does_not_exist;
--error ER_MASKING_POLICY_COMPONENT_ERROR
DROP MASKING POLICY IF EXISTS pol_does_not_exist;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY pol_does_not_exist;
