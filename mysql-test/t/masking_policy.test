--echo #
--echo # WL#16525: Dynamic Datamasking Support in MySQL
--echo #

--echo # Test cases for CREATE/DROP/SHOW MASKING POLICY.

--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY mak_pol(i)
  CASE WHEN CURRENT_ROLE_IN('admin') THEN sha2('abc', 224) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY IF NOT EXISTS pol_if_not_exists(i)
  CASE WHEN CURRENT_ROLE_IN('admin') THEN sha2('abc', 224) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p1(i)
  CASE WHEN CURRENT_USER_IN ('admin, app') THEN sha2('abc', i) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p1;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p1_1(i)
  CASE WHEN CURRENT_USER_IN('admin, app') THEN sha2('abc', 224) ELSE i END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p1_1;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p2(i)
  CASE WHEN CURRENT_USER_IN('admin, app') THEN i ELSE sha2('abc', i) END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p2;
--error ER_MASKING_POLICY_COMPONENT_ERROR
CREATE MASKING POLICY p2_2(i)
  CASE WHEN CURRENT_USER_IN('admin, app') THEN i ELSE sha2('abc', 224) END;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY p2_2;
--error ER_MASKING_POLICY_COMPONENT_ERROR
DROP MASKING POLICY pol_does_not_exist;
--error ER_MASKING_POLICY_COMPONENT_ERROR
DROP MASKING POLICY IF EXISTS pol_does_not_exist;
--error ER_MASKING_POLICY_COMPONENT_ERROR
SHOW CREATE MASKING POLICY pol_does_not_exist;

--echo # Test cases for assigning/unassigning masking policies on columns
--echo # with CREATE TABLE and ALTER TABLE.

CREATE TABLE t1(i VARCHAR(256) MASKING POLICY p1);
SHOW CREATE TABLE t1;
DROP TABLE t1;

CREATE TABLE t2(i VARCHAR(256));
ALTER TABLE t2 ALTER COLUMN i DROP MASKING POLICY;
SHOW CREATE TABLE t2;

ALTER TABLE t2 ALTER COLUMN i SET MASKING POLICY p2;
SHOW CREATE TABLE t2;
DROP TABLE t2;

CREATE TABLE t1(i VARCHAR(256));
ALTER TABLE t1 ADD COLUMN j VARCHAR(256) MASKING POLICY p1;
SHOW CREATE TABLE t1;
DROP TABLE t1;

CREATE TABLE t1(i VARCHAR(256) MASKING POLICY p1);
SHOW CREATE TABLE t1;
DROP TABLE t1;

CREATE TABLE t2(i VARCHAR(256) MASKING POLICY p3);
SHOW CREATE TABLE t2;

ALTER TABLE t2 ALTER COLUMN i DROP MASKING POLICY;
SHOW CREATE TABLE t2;

ALTER TABLE t2 ALTER COLUMN i SET MASKING POLICY p2;
SHOW CREATE TABLE t2;
DROP TABLE t2;

CREATE TABLE t1(i VARCHAR(256) MASKING POLICY p1);
ALTER TABLE t1 ADD COLUMN j VARCHAR(256) MASKING POLICY p1;
SHOW CREATE TABLE t1;
ALTER TABLE t1 DROP COLUMN j;
DROP TABLE t1;

CREATE TABLE t3(i INT);
ALTER TABLE t3 MODIFY COLUMN i INT MASKING POLICY p1;
SHOW CREATE TABLE t3;
ALTER TABLE t3 MODIFY COLUMN i INT MASKING POLICY p2;
SHOW CREATE TABLE t3;
ALTER TABLE t3 MODIFY COLUMN i INT;
SHOW CREATE TABLE t3;
DROP TABLE t3;

# Masking policy names cannot be empty or end in a space. And they
# cannot exceed 64 characters.
--error ER_SP_WRONG_NAME
CREATE TABLE t(col INT MASKING POLICY ``);
--error ER_SP_WRONG_NAME
CREATE TABLE t(col INT MASKING POLICY ` `);
--error ER_SP_WRONG_NAME
CREATE TABLE t(col INT MASKING POLICY `x `);
--error ER_TOO_LONG_IDENT
CREATE TABLE t(col INT
MASKING POLICY aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
);

# The same invalid names should also be rejected by ALTER TABLE variants.
CREATE TABLE t(i INT);
--error ER_SP_WRONG_NAME
ALTER TABLE t ALTER COLUMN i SET MASKING POLICY ``;
--error ER_SP_WRONG_NAME
ALTER TABLE t ALTER COLUMN i SET MASKING POLICY ` `;
--error ER_SP_WRONG_NAME
ALTER TABLE t ALTER COLUMN i SET MASKING POLICY `x `;
--error ER_TOO_LONG_IDENT
ALTER TABLE t ALTER COLUMN i SET MASKING POLICY
aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;

--error ER_SP_WRONG_NAME
ALTER TABLE t MODIFY COLUMN i INT MASKING POLICY ``;
--error ER_SP_WRONG_NAME
ALTER TABLE t MODIFY COLUMN i INT MASKING POLICY ` `;
--error ER_SP_WRONG_NAME
ALTER TABLE t MODIFY COLUMN i INT MASKING POLICY `x `;
--error ER_TOO_LONG_IDENT
ALTER TABLE t MODIFY COLUMN i INT MASKING POLICY
aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;

--error ER_SP_WRONG_NAME
ALTER TABLE t ADD COLUMN j INT MASKING POLICY ``;
--error ER_SP_WRONG_NAME
ALTER TABLE t ADD COLUMN k INT MASKING POLICY ` `;
--error ER_SP_WRONG_NAME
ALTER TABLE t ADD COLUMN l INT MASKING POLICY `x `;
--error ER_TOO_LONG_IDENT
ALTER TABLE t ADD COLUMN l INT MASKING POLICY
aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;

DROP TABLE t;
